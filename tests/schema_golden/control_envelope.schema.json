{
  "$defs": {
    "AgentState": {
      "additionalProperties": false,
      "description": "Snapshot of an agent at a given tick.\n\nStatic persona information (traits, cognitive habits) lives in\n:class:`PersonaSpec` and is joined at read time via ``persona_id``.",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "cognitive": {
          "$ref": "#/$defs/Cognitive"
        },
        "erre": {
          "$ref": "#/$defs/ERREMode"
        },
        "persona_id": {
          "title": "Persona Id",
          "type": "string"
        },
        "physical": {
          "$ref": "#/$defs/Physical"
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "relationships": {
          "items": {
            "$ref": "#/$defs/RelationshipBond"
          },
          "title": "Relationships",
          "type": "array"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "wall_clock": {
          "format": "date-time",
          "title": "Wall Clock",
          "type": "string"
        }
      },
      "required": [
        "agent_id",
        "persona_id",
        "tick",
        "position",
        "erre"
      ],
      "title": "AgentState",
      "type": "object"
    },
    "AgentUpdateMsg": {
      "additionalProperties": false,
      "description": "Bulk snapshot of an agent (G-GEAR → MacBook).",
      "properties": {
        "agent_state": {
          "$ref": "#/$defs/AgentState"
        },
        "kind": {
          "const": "agent_update",
          "default": "agent_update",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "agent_state"
      ],
      "title": "AgentUpdateMsg",
      "type": "object"
    },
    "AnimationMsg": {
      "additionalProperties": false,
      "description": "Animation state change (walk / idle / sit_seiza / bow …).",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "animation_name": {
          "title": "Animation Name",
          "type": "string"
        },
        "kind": {
          "const": "animation",
          "default": "animation",
          "title": "Kind",
          "type": "string"
        },
        "loop": {
          "default": false,
          "title": "Loop",
          "type": "boolean"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "agent_id",
        "animation_name"
      ],
      "title": "AnimationMsg",
      "type": "object"
    },
    "Cognitive": {
      "additionalProperties": false,
      "description": "Short-timescale mental state (tick-level).",
      "properties": {
        "active_goals": {
          "description": "Free-form short goal strings; promoted to a structured Goal type in M4 (this is a planned breaking change).",
          "items": {
            "type": "string"
          },
          "maxItems": 10,
          "title": "Active Goals",
          "type": "array"
        },
        "arousal": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Arousal",
          "type": "number"
        },
        "curiosity": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Curiosity",
          "type": "number"
        },
        "dmn_activation": {
          "default": 0.3,
          "description": "Default Mode Network activation proxy.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Dmn Activation",
          "type": "number"
        },
        "dominant_emotion": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlutchikDimension"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "motivation": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Motivation",
          "type": "number"
        },
        "shuhari_stage": {
          "$ref": "#/$defs/ShuhariStage",
          "default": "shu"
        },
        "stress": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Stress",
          "type": "number"
        },
        "valence": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Valence",
          "type": "number"
        }
      },
      "title": "Cognitive",
      "type": "object"
    },
    "DialogCloseMsg": {
      "additionalProperties": false,
      "description": "A dialog has ended (M4 foundation).\n\n``reason`` is a closed literal set so the gateway and the scheduler can\ndispatch on it without string matching.",
      "properties": {
        "dialog_id": {
          "title": "Dialog Id",
          "type": "string"
        },
        "kind": {
          "const": "dialog_close",
          "default": "dialog_close",
          "title": "Kind",
          "type": "string"
        },
        "reason": {
          "enum": [
            "completed",
            "interrupted",
            "timeout"
          ],
          "title": "Reason",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "dialog_id",
        "reason"
      ],
      "title": "DialogCloseMsg",
      "type": "object"
    },
    "DialogInitiateMsg": {
      "additionalProperties": false,
      "description": "An agent requests to start a dialog with another agent (M4 foundation).\n\nThe scheduler decides whether to admit the request (backpressure, zone\nconstraints, existing dialog state). Admission logic lives in\n``m4-multi-agent-orchestrator``; this envelope only captures the intent.",
      "properties": {
        "initiator_agent_id": {
          "title": "Initiator Agent Id",
          "type": "string"
        },
        "kind": {
          "const": "dialog_initiate",
          "default": "dialog_initiate",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "target_agent_id": {
          "title": "Target Agent Id",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "zone": {
          "$ref": "#/$defs/Zone"
        }
      },
      "required": [
        "tick",
        "initiator_agent_id",
        "target_agent_id",
        "zone"
      ],
      "title": "DialogInitiateMsg",
      "type": "object"
    },
    "DialogTurnMsg": {
      "additionalProperties": false,
      "description": "A single turn inside an ongoing dialog (M4 foundation).\n\n``speaker_id`` and ``addressee_id`` are both carried so Godot can drive\nthe correct animations (speech bubble / head-turn) without re-deriving\norientation from world state.",
      "properties": {
        "addressee_id": {
          "title": "Addressee Id",
          "type": "string"
        },
        "dialog_id": {
          "title": "Dialog Id",
          "type": "string"
        },
        "kind": {
          "const": "dialog_turn",
          "default": "dialog_turn",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "speaker_id": {
          "title": "Speaker Id",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "utterance": {
          "title": "Utterance",
          "type": "string"
        }
      },
      "required": [
        "tick",
        "dialog_id",
        "speaker_id",
        "addressee_id",
        "utterance"
      ],
      "title": "DialogTurnMsg",
      "type": "object"
    },
    "ERREMode": {
      "additionalProperties": false,
      "description": "The agent's current ERRE mode with its sampling overrides.",
      "properties": {
        "dmn_bias": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Dmn Bias",
          "type": "number"
        },
        "entered_at_tick": {
          "minimum": 0,
          "title": "Entered At Tick",
          "type": "integer"
        },
        "name": {
          "$ref": "#/$defs/ERREModeName"
        },
        "sampling_overrides": {
          "$ref": "#/$defs/SamplingDelta"
        },
        "zone_trigger": {
          "anyOf": [
            {
              "$ref": "#/$defs/Zone"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "entered_at_tick"
      ],
      "title": "ERREMode",
      "type": "object"
    },
    "ERREModeName": {
      "description": "Eight ERRE cognitive modes (see ``persona-erre`` skill for semantics).",
      "enum": [
        "peripatetic",
        "chashitsu",
        "zazen",
        "shu_kata",
        "ha_deviate",
        "ri_create",
        "deep_work",
        "shallow"
      ],
      "title": "ERREModeName",
      "type": "string"
    },
    "ErrorMsg": {
      "additionalProperties": false,
      "description": "Structured error for observability.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "kind": {
          "const": "error",
          "default": "error",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "code",
        "detail"
      ],
      "title": "ErrorMsg",
      "type": "object"
    },
    "HandshakeMsg": {
      "additionalProperties": false,
      "description": "First message exchanged on a new WebSocket connection.",
      "properties": {
        "capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "kind": {
          "const": "handshake",
          "default": "handshake",
          "title": "Kind",
          "type": "string"
        },
        "peer": {
          "enum": [
            "g-gear",
            "macbook",
            "godot"
          ],
          "title": "Peer",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "peer"
      ],
      "title": "HandshakeMsg",
      "type": "object"
    },
    "MoveMsg": {
      "additionalProperties": false,
      "description": "Locomotion intent for an agent (G-GEAR → MacBook → Godot nav).",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "kind": {
          "const": "move",
          "default": "move",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "speed": {
          "description": "Metres per second.",
          "minimum": 0.0,
          "title": "Speed",
          "type": "number"
        },
        "target": {
          "$ref": "#/$defs/Position"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "agent_id",
        "target",
        "speed"
      ],
      "title": "MoveMsg",
      "type": "object"
    },
    "Physical": {
      "additionalProperties": false,
      "description": "Long-timescale somatic state (CSDG HumanCondition adopted as skeleton).\n\nAll fields move on a daily / half-life scale. Instantaneous affect lives in\n:class:`Cognitive` (``valence`` / ``arousal``) instead.",
      "properties": {
        "breath_rate": {
          "default": 0.25,
          "description": "Normalised respiration; varies during walk / zazen.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Breath Rate",
          "type": "number"
        },
        "cognitive_load": {
          "default": 0.2,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Cognitive Load",
          "type": "number"
        },
        "emotional_conflict": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Emotional Conflict",
          "type": "number"
        },
        "fatigue": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Fatigue",
          "type": "number"
        },
        "hunger": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Hunger",
          "type": "number"
        },
        "mood_baseline": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Mood Baseline",
          "type": "number"
        },
        "physical_energy": {
          "default": 0.7,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Physical Energy",
          "type": "number"
        },
        "sleep_quality": {
          "default": 0.7,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Sleep Quality",
          "type": "number"
        }
      },
      "title": "Physical",
      "type": "object"
    },
    "PlutchikDimension": {
      "description": "Plutchik's eight primary emotions.",
      "enum": [
        "joy",
        "trust",
        "fear",
        "surprise",
        "sadness",
        "disgust",
        "anger",
        "anticipation"
      ],
      "title": "PlutchikDimension",
      "type": "string"
    },
    "Position": {
      "additionalProperties": false,
      "description": "3D position within the world, annotated with the containing zone.",
      "properties": {
        "pitch": {
          "default": 0.0,
          "description": "Head tilt in radians (bow, gaze).",
          "title": "Pitch",
          "type": "number"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "yaw": {
          "default": 0.0,
          "description": "Facing angle in radians.",
          "title": "Yaw",
          "type": "number"
        },
        "z": {
          "title": "Z",
          "type": "number"
        },
        "zone": {
          "$ref": "#/$defs/Zone"
        }
      },
      "required": [
        "x",
        "y",
        "z",
        "zone"
      ],
      "title": "Position",
      "type": "object"
    },
    "RelationshipBond": {
      "additionalProperties": false,
      "description": "Per-other-agent relational state.",
      "properties": {
        "affinity": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Affinity",
          "type": "number"
        },
        "familiarity": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Familiarity",
          "type": "number"
        },
        "ichigo_ichie_count": {
          "default": 0,
          "minimum": 0,
          "title": "Ichigo Ichie Count",
          "type": "integer"
        },
        "last_interaction_tick": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Interaction Tick"
        },
        "other_agent_id": {
          "title": "Other Agent Id",
          "type": "string"
        }
      },
      "required": [
        "other_agent_id"
      ],
      "title": "RelationshipBond",
      "type": "object"
    },
    "SamplingDelta": {
      "additionalProperties": false,
      "description": "Additive overrides applied on top of ``SamplingBase`` per ERRE mode.\n\nAll fields default to ``0.0`` meaning \"no override\". The ``persona-erre``\nskill tabulates the canonical deltas per mode. Composition\n(``base + delta``) is the caller's responsibility; T11 / T12 must clamp\nthe result back into ``SamplingBase``'s valid ranges.",
      "properties": {
        "repeat_penalty": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Repeat Penalty",
          "type": "number"
        },
        "temperature": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Temperature",
          "type": "number"
        },
        "top_p": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Top P",
          "type": "number"
        }
      },
      "title": "SamplingDelta",
      "type": "object"
    },
    "ShuhariStage": {
      "description": "Three stages of skill acquisition in Japanese arts (shu-ha-ri).",
      "enum": [
        "shu",
        "ha",
        "ri"
      ],
      "title": "ShuhariStage",
      "type": "string"
    },
    "SpeechMsg": {
      "additionalProperties": false,
      "description": "An agent uttered something (G-GEAR → MacBook → Godot speech bubble).",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "emotion": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlutchikDimension"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "kind": {
          "const": "speech",
          "default": "speech",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "utterance": {
          "title": "Utterance",
          "type": "string"
        },
        "zone": {
          "$ref": "#/$defs/Zone"
        }
      },
      "required": [
        "tick",
        "agent_id",
        "utterance",
        "zone"
      ],
      "title": "SpeechMsg",
      "type": "object"
    },
    "WorldTickMsg": {
      "additionalProperties": false,
      "description": "Global clock pulse (G-GEAR → MacBook, heartbeat).",
      "properties": {
        "active_agents": {
          "minimum": 0,
          "title": "Active Agents",
          "type": "integer"
        },
        "kind": {
          "const": "world_tick",
          "default": "world_tick",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.2.0-m4",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "wall_clock": {
          "format": "date-time",
          "title": "Wall Clock",
          "type": "string"
        }
      },
      "required": [
        "tick",
        "active_agents"
      ],
      "title": "WorldTickMsg",
      "type": "object"
    },
    "Zone": {
      "description": "Five spatial zones of the world (see ``docs/glossary.md``).",
      "enum": [
        "study",
        "peripatos",
        "chashitsu",
        "agora",
        "garden"
      ],
      "title": "Zone",
      "type": "string"
    }
  },
  "discriminator": {
    "mapping": {
      "agent_update": "#/$defs/AgentUpdateMsg",
      "animation": "#/$defs/AnimationMsg",
      "dialog_close": "#/$defs/DialogCloseMsg",
      "dialog_initiate": "#/$defs/DialogInitiateMsg",
      "dialog_turn": "#/$defs/DialogTurnMsg",
      "error": "#/$defs/ErrorMsg",
      "handshake": "#/$defs/HandshakeMsg",
      "move": "#/$defs/MoveMsg",
      "speech": "#/$defs/SpeechMsg",
      "world_tick": "#/$defs/WorldTickMsg"
    },
    "propertyName": "kind"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/HandshakeMsg"
    },
    {
      "$ref": "#/$defs/AgentUpdateMsg"
    },
    {
      "$ref": "#/$defs/SpeechMsg"
    },
    {
      "$ref": "#/$defs/MoveMsg"
    },
    {
      "$ref": "#/$defs/AnimationMsg"
    },
    {
      "$ref": "#/$defs/WorldTickMsg"
    },
    {
      "$ref": "#/$defs/ErrorMsg"
    },
    {
      "$ref": "#/$defs/DialogInitiateMsg"
    },
    {
      "$ref": "#/$defs/DialogTurnMsg"
    },
    {
      "$ref": "#/$defs/DialogCloseMsg"
    }
  ]
}
