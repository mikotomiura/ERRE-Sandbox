{
  "$defs": {
    "AgentState": {
      "additionalProperties": false,
      "description": "Snapshot of an agent at a given tick.\n\nStatic persona information (traits, cognitive habits) lives in\n:class:`PersonaSpec` and is joined at read time via ``persona_id``.",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "cognitive": {
          "$ref": "#/$defs/Cognitive"
        },
        "erre": {
          "$ref": "#/$defs/ERREMode"
        },
        "persona_id": {
          "title": "Persona Id",
          "type": "string"
        },
        "physical": {
          "$ref": "#/$defs/Physical"
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "relationships": {
          "items": {
            "$ref": "#/$defs/RelationshipBond"
          },
          "title": "Relationships",
          "type": "array"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "wall_clock": {
          "format": "date-time",
          "title": "Wall Clock",
          "type": "string"
        }
      },
      "required": [
        "agent_id",
        "persona_id",
        "tick",
        "position",
        "erre"
      ],
      "title": "AgentState",
      "type": "object"
    },
    "AgentUpdateMsg": {
      "additionalProperties": false,
      "description": "Bulk snapshot of an agent (G-GEAR â†’ MacBook).",
      "properties": {
        "agent_state": {
          "$ref": "#/$defs/AgentState"
        },
        "kind": {
          "const": "agent_update",
          "default": "agent_update",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "agent_state"
      ],
      "title": "AgentUpdateMsg",
      "type": "object"
    },
    "AnimationMsg": {
      "additionalProperties": false,
      "description": "Animation state change (walk / idle / sit_seiza / bow â€¦).",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "animation_name": {
          "title": "Animation Name",
          "type": "string"
        },
        "kind": {
          "const": "animation",
          "default": "animation",
          "title": "Kind",
          "type": "string"
        },
        "loop": {
          "default": false,
          "title": "Loop",
          "type": "boolean"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "agent_id",
        "animation_name"
      ],
      "title": "AnimationMsg",
      "type": "object"
    },
    "Cognitive": {
      "additionalProperties": false,
      "description": "Short-timescale mental state (tick-level).",
      "properties": {
        "active_goals": {
          "description": "Free-form short goal strings; promoted to a structured Goal type in M4 (this is a planned breaking change).",
          "items": {
            "type": "string"
          },
          "maxItems": 10,
          "title": "Active Goals",
          "type": "array"
        },
        "arousal": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Arousal",
          "type": "number"
        },
        "curiosity": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Curiosity",
          "type": "number"
        },
        "dialog_turn_budget": {
          "default": 6,
          "description": "Remaining dialog turns before the agent auto-closes its current dialog with ``DialogCloseMsg.reason='exhausted'``. Default 6 was validated empirically in the M5 LLM spike (.steering/20260420-m5-llm-spike/decisions.md judgement 4). 0 means 'no more turns permitted'.",
          "minimum": 0,
          "title": "Dialog Turn Budget",
          "type": "integer"
        },
        "dmn_activation": {
          "default": 0.3,
          "description": "Default Mode Network activation proxy.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Dmn Activation",
          "type": "number"
        },
        "dominant_emotion": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlutchikDimension"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "motivation": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Motivation",
          "type": "number"
        },
        "shuhari_stage": {
          "$ref": "#/$defs/ShuhariStage",
          "default": "shu"
        },
        "stress": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Stress",
          "type": "number"
        },
        "valence": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Valence",
          "type": "number"
        }
      },
      "title": "Cognitive",
      "type": "object"
    },
    "DialogCloseMsg": {
      "additionalProperties": false,
      "description": "A dialog has ended (M4 foundation).\n\n``reason`` is a closed literal set so the gateway and the scheduler can\ndispatch on it without string matching.\n\nM5 adds ``\"exhausted\"`` to signal that the agent hit its\n:attr:`Cognitive.dialog_turn_budget` cap (distinct from the\nscheduler's ``\"timeout\"``, which is driven by wall-clock).",
      "properties": {
        "dialog_id": {
          "title": "Dialog Id",
          "type": "string"
        },
        "kind": {
          "const": "dialog_close",
          "default": "dialog_close",
          "title": "Kind",
          "type": "string"
        },
        "reason": {
          "enum": [
            "completed",
            "interrupted",
            "timeout",
            "exhausted"
          ],
          "title": "Reason",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "dialog_id",
        "reason"
      ],
      "title": "DialogCloseMsg",
      "type": "object"
    },
    "DialogInitiateMsg": {
      "additionalProperties": false,
      "description": "An agent requests to start a dialog with another agent (M4 foundation).\n\nThe scheduler decides whether to admit the request (backpressure, zone\nconstraints, existing dialog state). Admission logic lives in\n``m4-multi-agent-orchestrator``; this envelope only captures the intent.",
      "properties": {
        "initiator_agent_id": {
          "title": "Initiator Agent Id",
          "type": "string"
        },
        "kind": {
          "const": "dialog_initiate",
          "default": "dialog_initiate",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "target_agent_id": {
          "title": "Target Agent Id",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "zone": {
          "$ref": "#/$defs/Zone"
        }
      },
      "required": [
        "tick",
        "initiator_agent_id",
        "target_agent_id",
        "zone"
      ],
      "title": "DialogInitiateMsg",
      "type": "object"
    },
    "DialogTurnMsg": {
      "additionalProperties": false,
      "description": "A single turn inside an ongoing dialog (M4 foundation).\n\n``speaker_id`` and ``addressee_id`` are both carried so Godot can drive\nthe correct animations (speech bubble / head-turn) without re-deriving\norientation from world state.\n\n``turn_index`` was added in M5 (0.3.0-m5) so consumers can (a) detect\nout-of-order delivery over WebSocket and (b) correlate with\n:attr:`Cognitive.dialog_turn_budget` for exhaustion close-out. The first\nturn of a dialog is ``turn_index=0`` and the value increases by 1 per\nemitted :class:`DialogTurnMsg`.",
      "properties": {
        "addressee_id": {
          "title": "Addressee Id",
          "type": "string"
        },
        "dialog_id": {
          "title": "Dialog Id",
          "type": "string"
        },
        "kind": {
          "const": "dialog_turn",
          "default": "dialog_turn",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "speaker_id": {
          "title": "Speaker Id",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        },
        "turn_index": {
          "description": "Monotonic 0-based index within the dialog. Increments by 1 per emitted turn across both speakers. Paired with ``Cognitive.dialog_turn_budget`` to drive the exhaustion close.",
          "minimum": 0,
          "title": "Turn Index",
          "type": "integer"
        },
        "utterance": {
          "title": "Utterance",
          "type": "string"
        }
      },
      "required": [
        "tick",
        "dialog_id",
        "speaker_id",
        "addressee_id",
        "utterance",
        "turn_index"
      ],
      "title": "DialogTurnMsg",
      "type": "object"
    },
    "ERREMode": {
      "additionalProperties": false,
      "description": "The agent's current ERRE mode with its sampling overrides.",
      "properties": {
        "dmn_bias": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Dmn Bias",
          "type": "number"
        },
        "entered_at_tick": {
          "minimum": 0,
          "title": "Entered At Tick",
          "type": "integer"
        },
        "name": {
          "$ref": "#/$defs/ERREModeName"
        },
        "sampling_overrides": {
          "$ref": "#/$defs/SamplingDelta"
        },
        "zone_trigger": {
          "anyOf": [
            {
              "$ref": "#/$defs/Zone"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "entered_at_tick"
      ],
      "title": "ERREMode",
      "type": "object"
    },
    "ERREModeName": {
      "description": "Eight ERRE cognitive modes (see ``persona-erre`` skill for semantics).",
      "enum": [
        "peripatetic",
        "chashitsu",
        "zazen",
        "shu_kata",
        "ha_deviate",
        "ri_create",
        "deep_work",
        "shallow"
      ],
      "title": "ERREModeName",
      "type": "string"
    },
    "ErrorMsg": {
      "additionalProperties": false,
      "description": "Structured error for observability.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "kind": {
          "const": "error",
          "default": "error",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "code",
        "detail"
      ],
      "title": "ErrorMsg",
      "type": "object"
    },
    "HandshakeMsg": {
      "additionalProperties": false,
      "description": "First message exchanged on a new WebSocket connection.",
      "properties": {
        "capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Capabilities",
          "type": "array"
        },
        "kind": {
          "const": "handshake",
          "default": "handshake",
          "title": "Kind",
          "type": "string"
        },
        "peer": {
          "enum": [
            "g-gear",
            "macbook",
            "godot"
          ],
          "title": "Peer",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "peer"
      ],
      "title": "HandshakeMsg",
      "type": "object"
    },
    "MoveMsg": {
      "additionalProperties": false,
      "description": "Locomotion intent for an agent (G-GEAR â†’ MacBook â†’ Godot nav).",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "kind": {
          "const": "move",
          "default": "move",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
          "title": "Sent At",
          "type": "string"
        },
        "speed": {
          "description": "Metres per second.",
          "minimum": 0.0,
          "title": "Speed",
          "type": "number"
        },
        "target": {
          "$ref": "#/$defs/Position"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "tick",
        "agent_id",
        "target",
        "speed"
      ],
      "title": "MoveMsg",
      "type": "object"
    },
    "Physical": {
      "additionalProperties": false,
      "description": "Long-timescale somatic state (CSDG HumanCondition adopted as skeleton).\n\nAll fields move on a daily / half-life scale. Instantaneous affect lives in\n:class:`Cognitive` (``valence`` / ``arousal``) instead.",
      "properties": {
        "breath_rate": {
          "default": 0.25,
          "description": "Normalised respiration; varies during walk / zazen.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Breath Rate",
          "type": "number"
        },
        "cognitive_load": {
          "default": 0.2,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Cognitive Load",
          "type": "number"
        },
        "emotional_conflict": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Emotional Conflict",
          "type": "number"
        },
        "fatigue": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Fatigue",
          "type": "number"
        },
        "hunger": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Hunger",
          "type": "number"
        },
        "mood_baseline": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": -1.0,
          "title": "Mood Baseline",
          "type": "number"
        },
        "physical_energy": {
          "default": 0.7,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Physical Energy",
          "type": "number"
        },
        "sleep_quality": {
          "default": 0.7,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Sleep Quality",
          "type": "number"
        }
      },
      "title": "Physical",
      "type": "object"
    },
    "PlutchikDimension": {
      "description": "Plutchik's eight primary emotions.",
      "enum": [
        "joy",
        "trust",
        "fear",
        "surprise",
        "sadness",
        "disgust",
        "anger",
        "anticipation"
      ],
      "title": "PlutchikDimension",
      "type": "string"
    },
    "Position": {
      "additionalProperties": false,
      "description": "3D position within the world, annotated with the containing zone.",
      "properties": {
        "pitch": {
          "default": 0.0,
          "description": "Head tilt in radians (bow, gaze).",
          "title": "Pitch",
          "type": "number"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "yaw": {
          "default": 0.0,
          "description": "Facing angle in radians.",
          "title": "Yaw",
          "type": "number"
        },
        "z": {
          "title": "Z",
          "type": "number"
        },
        "zone": {
          "$ref": "#/$defs/Zone"
        }
      },
      "required": [
        "x",
        "y",
        "z",
        "zone"
      ],
      "title": "Position",
      "type": "object"
    },
    "PropLayout": {
      "additionalProperties": false,
      "description": "One static prop row in :class:`WorldLayoutMsg` (M7Îł).\n\nMirrors :class:`~erre_sandbox.world.zones.PropSpec` over the wire and\nmatches the affordance fields of :class:`AffordanceEvent` so Godot can\nplace the prop without a separate prop-catalogue lookup.",
      "properties": {
        "prop_id": {
          "title": "Prop Id",
          "type": "string"
        },
        "prop_kind": {
          "title": "Prop Kind",
          "type": "string"
        },
        "salience": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Salience",
          "type": "number"
        },
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "z": {
          "title": "Z",
          "type": "number"
        },
        "zone": {
          "$ref": "#/$defs/Zone"
        }
      },
      "required": [
        "prop_id",
        "prop_kind",
        "zone",
        "x",
        "y",
        "z"
      ],
      "title": "PropLayout",
      "type": "object"
    },
    "ReasoningTrace": {
      "additionalProperties": false,
      "description": "One tick of structured reasoning rationale (M6-A-3).\n\nProduced alongside an :class:`LLMPlan` by the cognition cycle's Step 5\nwhen the LLM fills the optional ``salient`` / ``decision`` /\n``next_intent`` fields. Unlike :class:`ReflectionEvent` (which distils\nmany ticks into one stored memory), this trace captures per-tick\nself-explanation â€” primarily for xAI observability in the Godot UI.\n\nAll three narrative fields are optional because stable Ollama output is\nnever 100%; downstream consumers must tolerate ``None``. The trace is\nsafe to discard if missing â€” :class:`LLMPlan` parsing is independent,\nso a persona can produce a valid plan without producing a trace.",
      "properties": {
        "agent_id": {
          "title": "Agent Id",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "decision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The one-sentence rationale behind the chosen action.",
          "title": "Decision"
        },
        "mode": {
          "$ref": "#/$defs/ERREModeName"
        },
        "nearby_agents": {
          "description": "Up to two ``ProximityEvent.other_agent_id`` values with crossing=\"enter\" that informed this tick (M7Îł). Order is insertion order from the observation stream.",
          "items": {
            "type": "string"
          },
          "title": "Nearby Agents",
          "type": "array"
        },
        "next_intent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Forward-looking intent surfaced for upcoming ticks.",
          "title": "Next Intent"
        },
        "observed_objects": {
          "description": "Top-3 ``AffordanceEvent.prop_id`` values by salience that informed this tick's decision (M7Îł). Empty list means the tick had no affordance signal worth surfacing â€” not a missing field.",
          "items": {
            "type": "string"
          },
          "title": "Observed Objects",
          "type": "array"
        },
        "persona_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Persona this trace belongs to (matches ``PersonaSpec.persona_id``). M7Î¶-added so the Godot ``ReasoningPanel`` can render the persona identity alongside the trace without joining ``AgentState``. Older M7Îµ producers (pre-0.9.0-m7z) deserialise as ``None``; consumers must tolerate the missing case and fall back to ``agent_id``.",
          "title": "Persona Id"
        },
        "retrieved_memories": {
          "description": "Top-3 ``MemoryEntry.id`` values surfaced by recall calls during this tick (M7Îł). Lets the xAI panel link the decision back to the specific memory rows it leaned on.",
          "items": {
            "type": "string"
          },
          "title": "Retrieved Memories",
          "type": "array"
        },
        "salient": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "What the agent noticed as most salient this tick.",
          "title": "Salient"
        },
        "tick": {
          "minimum": 0,
          "title": "Tick",
          "type": "integer"
        }
      },
      "required": [
        "agent_id",
        "tick",
        "mode"
      ],
      "title": "ReasoningTrace",
      "type": "object"
    },
    "ReasoningTraceMsg": {
      "additionalProperties": false,
      "description": "The cognition cycle emitted structured reasoning for this agent (M6-A-3).\n\nCarries a :class:`ReasoningTrace` over the wire to the Godot xAI\nvisualisation (``ReasoningPanel`` / ``SynapseGraph``). Independent of\n:class:`AgentUpdateMsg` because the trace may be absent on any given\ntick (the LLM is free to fill or omit the rationale fields); bundling\nit into ``AgentUpdateMsg`` would force every tick to pay the schema\ncost of always-optional fields.",
      "properties": {
        "kind": {
          "const": "reasoning_trace",
          "default": "reasoning_trace",
          "title": "Kind",
          "type": "string"
        },
        "schema_version": {
          "default": "0.9.0-m7z",
          "title": "Schema Version",
          "type": "string"
        },
        "sent_at": {
          "format": "date-time",
