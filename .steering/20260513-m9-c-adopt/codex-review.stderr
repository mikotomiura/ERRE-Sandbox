    # ------------------------------------------------------------------
    # Chat -- OpenAI-compatible request
    # ------------------------------------------------------------------

    async def chat(
        self,
        messages: Sequence[ChatMessage],
        *,
        sampling: ResolvedSampling,
        model: str | None = None,
        options: dict[str, Any] | None = None,
        adapter: str | None = None,
