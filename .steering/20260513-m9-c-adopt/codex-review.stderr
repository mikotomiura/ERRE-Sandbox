 244:         # for multi-agent orchestration (#6) that want to share a single
 245:         # policy across all agents.
 246:         self._reflector = reflector or Reflector(
 247:             store=store,
 248:             embedding=embedding,
 249:             llm=llm,
 250:         )
 251:         # Optional ERRE mode FSM (M5 `m5-world-zone-triggers`). When None
 252:         # (default) the cycle preserves pre-M5 behaviour: ``agent_state.erre``
 253:         # is only set at boot and never changes thereafter. Wiring the
 254:         # concrete :class:`~erre_sandbox.erre.DefaultERREModePolicy` is the
 255:         # responsibility of ``m5-orchestrator-integration``.
 256:         self._erre_policy = erre_policy
 257:         # Override the per-mode sampling delta table. Defaults to the
 258:         # production :data:`SAMPLING_DELTA_BY_MODE`. Tests may inject a
 259:         # custom mapping (e.g. all-zero deltas) to isolate FSM-transition
 260:         # behaviour from the production table without monkey-patching the
 261:         # module constant. ``is not None`` rather than ``or`` so an
 262:         # explicitly-empty mapping does not silently fall back to production.
 263:         self._erre_sampling_deltas = (
 264:             erre_sampling_deltas
 265:             if erre_sampling_deltas is not None
 266:             else SAMPLING_DELTA_BY_MODE
 267:         )
 268:         # Slice ﾎｲ: probability that a destination_zone landing outside the
 269:         # persona's preferred_zones is resampled toward the preferred list.
 270:         # Read once at construction 窶・per-tick env reads would obscure the
 271:         # experiment's knob and violate the "cognition has no env
 272:         # dependencies" invariant the rest of this module relies on. Tune
 273:         # via ``ERRE_ZONE_BIAS_P`` between runs; see
 274:         # ``.steering/20260424-m7-differentiation-observability/design-final.md``.
 275:         self._zone_bias_p = float(os.environ.get("ERRE_ZONE_BIAS_P", "0.2"))
 276:         # Bias uses a persistent RNG (shared with ``self._rng`` when one is
 277:         # injected, otherwise its own ``Random()`` so consecutive ticks draw
 278:         # from a coherent sequence rather than fresh entropy per step).
 279:         # Separate field from ``self._rng`` so the ``apply_llm_delta`` noise
 280:         # contract ("no rng 竊・deterministic") stays intact for callers that
 281:         # deliberately pass ``None``.
 282:         self._bias_rng = rng or Random()  # noqa: S311 窶・non-crypto bias nudge
 283:         # M8 baseline-quality-metric: optional sink receiving one
 284:         # :class:`BiasFiredEvent` per firing. None in unit tests and the
 285:         # pre-M8 bootstrap; the production bootstrap wires it to a closure
 286:         # that persists events via ``MemoryStore.add_bias_event_sync``
 287:         # (see decisions D2/D5 in
 288:         # ``.steering/20260425-m8-baseline-quality-metric/decisions.md``).
 289:         self._bias_sink = bias_sink
 290: 
 291:     async def step(
 292:         self,
 293:         agent_state: AgentState,
 294:         persona: PersonaSpec,
 295:         observations: Sequence[Observation],
 296:         *,
 297:         tick_seconds: float = DEFAULT_TICK_SECONDS,
 298:     ) -> CycleResult:
 299:         """Run the 9-step cognition pipeline for one tick.
 300: 
 301:         ``tick_seconds`` is accepted for symmetry with T13 (which may pass a
 302:         measured wall-clock delta) but is not yet consumed by the MVP math 窶・        :mod:`cognition.state` expects a fixed tick. It is deliberately left
 303:         in the signature so T13 doesn't have to reshape the call.
 304:         """
 305:         _ = tick_seconds  # reserved for T13, intentionally unused here
 306: 
 307:         # Step 1: write observations as Episodic memories.
 308:         new_memory_ids = await self._write_observations(
 309:             observations,
 310:             agent_id=agent_state.agent_id,
 311:         )
 312: 
 313:         # Step 2: update Physical (pure, CSDG half-step).
 314:         new_physical = advance_physical(
 315:             agent_state.physical,
 316:             observations,
 317:             config=self._update_config,
 318:             rng=self._rng,
 319:         )
 320: 
 321:         # Step 2.25 (M6-A-2b): detect biorhythm threshold crossings. Emitted
 322:         # BEFORE the FSM / retrieve / LLM so the mode policy can react to the
 323:         # crossing and the LLM prompt can surface "I got tired" to the agent
 324:         # narrating in first person. Stress crossings live in Cognitive and
 325:         # are deferred 窶・Cognitive is assembled post-LLM (Step 8), so stress
 326:         # biorhythm would arrive a tick late and is not wired here.
 327:         biorhythm_events = _detect_biorhythm_crossings(
 328:             previous=agent_state.physical,
 329:             current=new_physical,
 330:             agent_id=agent_state.agent_id,
 331:             tick=agent_state.tick,
 332:         )
 333:         if biorhythm_events:
 334:             observations = [*observations, *biorhythm_events]
 335: 
 336:         # Step 2.5 (M5): ERRE mode FSM transition.
 337:         #
 338:         # Runs BEFORE retrieve / LLM so the sampling at Step 5 reflects the
 339:         # newly-selected mode (zero-tick latency). When no policy is wired the
 340:         # call is a no-op, preserving pre-M5 behaviour.
 341:         #
 342:         # M6-A-1: when a transition occurs, the emitted ERREModeShiftEvent is
 343:         # appended to ``observations`` so Steps 4-10 (retrieve / prompt /
 344:         # reflection) see the mode-shift signal alongside the inputs that
 345:         # caused it. The upstream sequence is not mutated 窶・we build a new
 346:         # list and rebind the local.
 347:         agent_state, shift_event = self._maybe_apply_erre_fsm(
 348:             agent_state,
 349:             observations,
 350:         )
 351:         if shift_event is not None:
 352:             observations = [*observations, shift_event]
 353: 
 354:         # Step 3: reflection trigger detection (execution is M4+).
 355:         importance_sum = sum(estimate_importance(o) for o in observations)
 356:         entered_reflective = _detect_zone_entry(observations, _REFLECTION_ZONES)
 357:         reflection_triggered = bool(
 358:             importance_sum > self.REFLECTION_IMPORTANCE_THRESHOLD or entered_reflective,
 359:         )
 360:         if reflection_triggered:
 361:             logger.info(
 362:                 "Reflection trigger for agent %s (sum=%.2f, zone_entry=%s)",
 363:                 agent_state.agent_id,
 364:                 importance_sum,
 365:                 entered_reflective,
 366:             )
 367: 
 368:         # Step 4: retrieve memories (Unavailable 竊・proceed with empty list).
 369:         memories = await self._retrieve_safely(agent_state, observations)
 370: 
 371:         # Step 5-6: build prompts and call the LLM.
 372:         sampling = compose_sampling(
 373:             persona.default_sampling,
 374:             agent_state.erre.sampling_overrides,
 375:         )
 376:         system_prompt = build_system_prompt(persona, agent_state)
 377:         user_prompt = build_user_prompt(observations, memories)
 378:         try:
 379:             resp = await self._llm.chat(
 380:                 [
 381:                     ChatMessage(role="system", content=system_prompt),
 382:                     ChatMessage(role="user", content=user_prompt),
 383:                 ],
 384:                 sampling=sampling,
 385:             )
 386:         except OllamaUnavailableError as exc:
 387:             logger.warning(
 388:                 "LLM unavailable for agent %s: %s 窶・continuing current action",
 389:                 agent_state.agent_id,
 390:                 exc,
 391:             )
 392:             return self._fallback(
 393:                 agent_state,
 394:                 new_memory_ids=new_memory_ids,
 395:                 reflection_triggered=reflection_triggered,
 396:                 new_physical=new_physical,
 397:             )
 398: 
 399:         # Step 7: parse the LLM plan (malformed 竊・same fallback branch).

