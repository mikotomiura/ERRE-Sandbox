    48	def test_focal_turn_count_handles_odd_and_even() -> None:
    49	    """``ceil(n/2)`` matches the driver's alternating-speaker layout."""
    50	    assert _focal_turn_count({"expected_turn_count": 1}) == 1
    51	    assert _focal_turn_count({"expected_turn_count": 2}) == 1
    52	    assert _focal_turn_count({"expected_turn_count": 3}) == 2
    53	    assert _focal_turn_count({}) == 1  # default expected_turn_count = 1
