from erre_sandbox.cli.eval_run_golden import _resolve_memory_db_path

persona = 'codex-broken-symlink-check'
default = Path(f'/tmp/p3a_natural_{persona}_run0.sqlite')
target = Path('/tmp/erre-nonexistent-target-for-broken-symlink-check.sqlite')
default.unlink(missing_ok=True)
target.unlink(missing_ok=True)
default.symlink_to(target)
try:
    result = _resolve_memory_db_path(None, persona=persona, run_idx=0, overwrite=False)
    print('result', result)
    print('Path.exists', result.exists())
    print('os.path.lexists', os.path.lexists(result))
    print('is_symlink', result.is_symlink())
finally:
    default.unlink(missing_ok=True)
    target.unlink(missing_ok=True)
