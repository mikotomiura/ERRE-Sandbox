273:markers = [
[build-system]
requires = ["uv_build>=0.4,<2.0"]
build-backend = "uv_build"

[project]
name = "erre-sandbox"
version = "0.0.1"
description = "Autonomous 3D Society Emerging from the Cognitive Habits of Great Thinkers"
readme = "README.md"
requires-python = ">=3.11,<3.12"
license = "Apache-2.0 OR MIT"
license-files = ["LICENSE", "LICENSE-MIT", "NOTICE"]
authors = [
    { name = "mikotomiura", email = "mmiura.network@gmail.com" },
]
keywords = ["llm", "agent", "cognitive-architecture", "godot", "research"]
classifiers = [
    "Development Status :: 2 - Pre-Alpha",
    "Intended Audience :: Developers",
    "Intended Audience :: Science/Research",
    "Operating System :: POSIX :: Linux",
    "Operating System :: MacOS :: MacOS X",
    "Programming Language :: Python :: 3 :: Only",
    "Programming Language :: Python :: 3.11",
    "Topic :: Scientific/Engineering :: Artificial Intelligence",
]
dependencies = [
    "pydantic>=2.7,<3",
    "fastapi>=0.115,<1",
    "uvicorn[standard]>=0.30,<1",
    "websockets>=13,<15",
    "httpx>=0.27,<1",
    "sqlite-vec>=0.1,<1",
    "pyyaml>=6,<7",
    "numpy>=2,<3",
    # Evaluation data layer (m9-eval-system Phase 0). DuckDB is the single
    # store for Tier 0 ``raw_dialog`` + ``metrics`` schemas; Parquet export
    # is a downstream artefact. Kept in core (not eval extras) so the
    # ``contracts.eval_paths`` schema-guard contract is always exercised by
    # CI; heavy ML deps (sentence-transformers, scipy, ollama, empath, arch)
    # remain isolated under ``optional-dependencies.eval``.
    "duckdb>=1.1,<2",
]

[project.optional-dependencies]
ui = [
    "streamlit>=1.39,<2",
]
# m9-eval-system Tier A/B/C heavy ML deps (Codex MEDIUM-4: keep core
# dependencies lightweight, isolate eval-only stack behind an extras
# group). Install with ``uv sync --extra eval`` on the Mac when running
# tier-a real-model tests; CI default keeps the resolution slim.
eval = [
    "scipy>=1.13,<2",                # bootstrap resample / stats helpers (P5)
    "sentence-transformers>=3,<4",   # MPNet (novelty) + transformers pipeline (NLI)
    "ollama>=0.3,<1",                # Tier C judge LLM HTTP client
    "empath>=0.89",                  # Tier A secondary diagnostic (Big5 claim 不使用)
    "arch>=7,<8",                    # 時系列 bootstrap helpers (HIGH-2)
]
# m9-c-spike — SGLang multi-LoRA serving (CS-1, decisions.md). Pinned to
# the PyPI 2026-04-08 release; G-GEAR install + ``--enable-lora`` smoke
# is verified in Phase K-α (.steering/20260508-m9-c-spike/k-alpha-handoff-prompt.md).
# Kept off the default install — CI runs the SGLang adapter unit tests
# via ``httpx.MockTransport`` so the heavy CUDA wheel stays optional.
inference = [
    "sglang==0.5.10.post1",
]
# m9-c-spike — Bounded Kant LoRA training stack (CS-3..CS-6, decisions.md).
# Phase β (real Kant training) only fires after blockers B-1
# (m9-individual-layer-schema-add) and B-2 (M9-eval P3 採取) clear; the
# adapter scaffold + 4-種 hard-fail gate ship in this PR but consume
# this extras stack only when ``train_kant_lora`` actually runs (peft /
# transformers / datasets / accelerate / bitsandbytes are imported lazily
# inside the function body, keeping the default ``import erre_sandbox.training``
# free of GPU-stack dependencies).
training = [
    "transformers>=4.45,<5",
    "accelerate>=0.34,<1",
    "bitsandbytes>=0.43,<1",
    "peft>=0.13,<1",
    "datasets>=3,<4",
]

[project.scripts]
erre-sandbox = "erre_sandbox.__main__:cli"

[project.urls]
Homepage = "https://github.com/mikotomiura/erre-sandbox"
Repository = "https://github.com/mikotomiura/erre-sandbox"
Issues = "https://github.com/mikotomiura/erre-sandbox/issues"

[dependency-groups]
lint = [
    "ruff>=0.6,<1.0",
]
typecheck = [
    "mypy>=1.11,<2",
    "types-pyyaml>=6,<7",
]
test = [
    "pytest>=8,<9",
    "pytest-asyncio>=0.24,<1",
]
dev = [
    { include-group = "lint" },
    { include-group = "typecheck" },
    { include-group = "test" },
]

# m9-c-spike — sglang==0.5.10.post1 ([inference]) ships its own
# transformers==5.3.0 pin which collides with both [training] (peft +
# transformers>=4.45,<5) and [eval] (sentence-transformers requires
# transformers<5). Operationally these stacks never co-reside on the
# same GPU host anyway: training runs first (peft saves a checkpoint),
# then the SGLang server boots with the adapter loaded, and Tier C
# judge LLM (eval, ollama-based) lives in a separate process. uv
# ``conflicts`` splits the lockfile universe pairwise so the resolver
# can pin transformers per-extra without forcing a single global
# version. Callers run ``uv sync --extra inference`` or
# ``uv sync --extra training`` (and may combine training+eval) but not
# inference+training or inference+eval. Adapter unit tests use
# httpx.MockTransport and do not import sglang, so CI default install
# (no extras) still exercises the SGLangChatClient surface.
[tool.uv]
# sglang==0.5.10.post1 transitively requires flash-attn-4>=4.0.0b4
# (pre-release). uv's default prerelease policy rejects unsolicited
# pre-releases; allow them so the [inference] universe can resolve.
# This only affects the [inference] extras universe — core / [eval] /
# [training] resolutions still prefer stable releases by other constraints.
prerelease = "allow"
conflicts = [
    [
        { extra = "inference" },
        { extra = "training" },
    ],
    [
        { extra = "inference" },
        { extra = "eval" },
    ],
]

