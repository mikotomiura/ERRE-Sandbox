   719	    async def recv_envelope(self) -> ControlEnvelope:
   720	        """Await and return the next envelope (FIFO).
   721	
   722	        Blocking variant intended for T14's WebSocket producer. Main queue
   723	        (``_envelopes``) is prioritised over heartbeat
   724	        (``_heartbeat_envelopes``) when both are ready, so dialog and error
   725	        envelopes never starve under a heartbeat-heavy load. The losing
   726	        getter is cancelled; Python 3.11+ ``asyncio.Queue.get()`` is
   727	        cancellation-safe — a cancelled getter does not pop from the queue.
   728	        """
   729	        main_task = asyncio.create_task(self._envelopes.get())
   730	        hb_task = asyncio.create_task(self._heartbeat_envelopes.get())
   731	        try:
   732	            done, pending = await asyncio.wait(
   733	                (main_task, hb_task),
   734	                return_when=asyncio.FIRST_COMPLETED,
   735	            )
   736	            if main_task in done:
   737	                for task in pending:
   738	                    task.cancel()
   739	                    with contextlib.suppress(asyncio.CancelledError):
   740	                        await task
   741	                return main_task.result()
   742	            for task in pending:
   743	                task.cancel()
   744	                with contextlib.suppress(asyncio.CancelledError):
   745	                    await task
   746	            return hb_task.result()
   747	        except BaseException:
   748	            for task in (main_task, hb_task):
   749	                if not task.done():
   750	                    task.cancel()
   751	            raise
