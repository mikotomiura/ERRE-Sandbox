One runtime issue is now concrete enough to test directly: when both queues are readable, `recv_envelope()` can complete both `Queue.get()` tasks and return the main item while silently consuming the heartbeat. I’m checking that behavior with a throwaway script before marking severity.
exec
/bin/zsh -lc ".venv/bin/python - <<'PY'
import asyncio
from erre_sandbox.world.tick import WorldRuntime
from erre_sandbox.schemas import WorldTickMsg

class DummyCycle:
    async def step(self, *args, **kwargs):
        raise NotImplementedError

async def main():
    rt = WorldRuntime(cycle=DummyCycle())
    await rt._on_heartbeat_tick()
    rt.inject_envelope(WorldTickMsg(tick=42, active_agents=0))
    got = await rt.recv_envelope()
    rest = rt.drain_envelopes()
    print('got', got.kind, got.tick)
    print('rest', [(e.kind, getattr(e, 'tick', None)) for e in rest])

asyncio.run(main())
