    86	# =============================================================================
    87	# Simulated time-of-day (M6-A-2b)
    88	# =============================================================================
    89	
    90	# Ordered ascending by phase. The period covering ``phase ∈ [phase, next_phase)``
    91	# is the one returned by :func:`_time_of_day`. The six buckets map a
    92	# continuous wall-time into the same vocabulary ``TimeOfDay`` uses so the
    93	# FSM and LLM prompt can reason about "morning" without comparing floats.
    94	# Boundaries skew toward daylight because research-session relevance peaks
    95	# around noon / afternoon — night is the short tail.
    96	_PERIOD_BOUNDARIES: tuple[tuple[float, TimeOfDay], ...] = (
    97	    (0.00, TimeOfDay.DAWN),
    98	    (0.10, TimeOfDay.MORNING),
    99	    (0.40, TimeOfDay.NOON),
   100	    (0.55, TimeOfDay.AFTERNOON),
   101	    (0.80, TimeOfDay.DUSK),
   102	    (0.90, TimeOfDay.NIGHT),
   103	)
   104	
   105	
   106	_PROXIMITY_THRESHOLD_M: Final[float] = 5.0
   107	"""Distance at which an agent pair is considered "proximate" (M6-A-2b).
   108	
   109	One :class:`ProximityEvent` is emitted per threshold crossing (``enter``
   110	when the distance falls below, ``leave`` when it rises back above) so
   111	co-walking agents do not spam the observation stream.  The value is
   112	deliberately larger than a conversational radius so the FSM can react
   113	**before** the dialog scheduler kicks in — five metres is the MASTER-PLAN
   114	reading of "same room but not yet engaged".
   115	"""
   116	
   117	_SEP_PUSH_M: Final[float] = 0.4
   118	"""Per-tick separation nudge in metres (M7ζ-3).
   119	
   120	Sized so two ticks of pushing (0.8 m) is well inside the 1.5 m default
   121	``separation_radius_m`` *and* well below :data:`_PROXIMITY_THRESHOLD_M`
   122	(5 m), so dialog-scheduler proximity events are not displaced by
   123	collapse correction.
   124	"""
   125	
   126	
   127	_AFFORDANCE_RADIUS_M: Final[float] = 2.0
   128	"""Distance at which an agent is considered to notice a static world prop (M7 B1).
   129	
   130	Mirrors the crossing-only semantics of :data:`_PROXIMITY_THRESHOLD_M`: a
   131	single :class:`AffordanceEvent` is emitted when the agent's XZ distance to
   132	a prop first falls below this radius. Until the agent has moved back out
   133	of range and re-entered, no further event fires. The value is tighter than
   134	proximity (5 m) because props are spot-like salience markers — a tea bowl
   135	is noticed when the agent is *at* it, not merely in the same zone."""
   136	
   137	
   138	_NEGATIVE_DELTA_TRIGGER: Final[float] = -0.05
   139	"""M7δ threshold below which a negative affinity delta raises emotional_conflict.
   140	
   141	Calibrated so the antagonism table's -0.10 magnitude (kant↔nietzsche)
   142	fires the bump while transient negative noise from decay alone (decay
   143	contribution at low ``prev`` is well above -0.05) does not. Value as of
   144	the C5 retune; see ``.steering/20260426-m7-slice-delta/observation.md``
   145	for the full calibration trajectory."""
   146	
   147	_EMOTIONAL_CONFLICT_GAIN: Final[float] = 0.5
