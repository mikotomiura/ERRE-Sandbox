    55	
    56	def test_stratified_slice_preserves_category_proportions() -> None:
    57	    """Slice should keep the same per-category share as the full battery."""
    58	    battery = load_stimulus_battery("kant")
    59	    full_focal = sum(_focal_turn_count(s) for s in battery)
    60	    target = full_focal // 2
    61	    sliced = _stratified_stimulus_slice(battery, target_focal_per_cycle=target)
    62	
    63	    def by_cat(items: list[dict[str, Any]]) -> dict[str, int]:
    64	        out: dict[str, int] = {}
    65	        for stim in items:
    66	            cat = str(stim.get("category", ""))
    67	            out[cat] = out.get(cat, 0) + _focal_turn_count(stim)
    68	        return out
    69	
    70	    full_share = by_cat(battery)
    71	    sliced_share = by_cat(sliced)
    72	    # Each category must appear in the slice (proportional ≠ all-or-nothing)
    73	    # which is the Codex HIGH-1 contract — naive YAML-prefix slicing would
    74	    # drop roleeval / moral_dilemma entirely.
    75	    for cat, count in full_share.items():
    76	        assert count > 0
    77	        assert sliced_share.get(cat, 0) > 0, (
    78	            f"category {cat} disappeared from stratified slice"
    79	        )
    80	    sliced_focal = sum(_focal_turn_count(s) for s in sliced)
    81	    # Allow ±15% relative drift from rounded category shares.
    82	    assert abs(sliced_focal - target) <= max(2, target * 15 // 100)
