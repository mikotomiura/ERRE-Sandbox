   157	def _time_of_day(elapsed: float, day_duration: float) -> TimeOfDay:
   158	    """Map an elapsed-time scalar to the containing :class:`TimeOfDay` bucket.
   159	
   160	    ``day_duration`` is the wall-clock length (seconds) of one simulated day
   161	    — the runtime passes its configured value so tests can compress a day
   162	    into milliseconds. The function is pure and cheap; called once per
   163	    physics tick.
   164	    """
   165	    if day_duration <= 0.0:
   166	        return TimeOfDay.DAWN  # degenerate — avoid divide-by-zero
   167	    phase = (elapsed % day_duration) / day_duration
   168	    current = _PERIOD_BOUNDARIES[0][1]
   169	    for boundary, period in _PERIOD_BOUNDARIES:
   170	        if phase >= boundary:
   171	            current = period
   172	    return current
