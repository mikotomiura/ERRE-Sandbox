   103	class TestWorldRuntimeEnvelopeQueue:
   104	    """SH-5: bounded main queue + coalescing heartbeat queue."""
   105	
   106	    def test_envelope_queue_overflow_emits_warning_and_drops_oldest(
   107	        self, world_harness: RuntimeHarness
   108	    ) -> None:
   109	        runtime = world_harness.runtime
   110	        for i in range(1024):
   111	            runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   112	        runtime.inject_envelope(WorldTickMsg(tick=9999, active_agents=0))
   113	        drained = runtime.drain_envelopes()
   114	        ticks = [e.tick for e in drained if isinstance(e, WorldTickMsg)]
   115	        assert 9999 in ticks
   116	        errors = [e for e in drained if isinstance(e, ErrorMsg)]
   117	        assert len(errors) >= 1
   118	        assert errors[0].code == "runtime_backlog_overflow"
   119	        assert "drops=" in errors[0].detail
   120	        # The very first envelope (tick=0) was dropped to make room.
   121	        assert 0 not in ticks
