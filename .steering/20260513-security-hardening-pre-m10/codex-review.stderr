   753	    def drain_envelopes(self) -> list[ControlEnvelope]:
   754	        """Non-blocking drain of all currently queued envelopes.
   755	
   756	        Drains the (coalesced, latest-only) heartbeat queue first, then the
   757	        bounded main queue. Existing callers asserted that the periodic
   758	        heartbeat appeared at the head of the drain when both clocks had
   759	        advanced — that contract is preserved by emitting heartbeat first.
   760	        Strict FIFO across both streams is not promised: the heartbeat
   761	        queue collapses to the latest tick (SH-5).
   762	        """
   763	        out: list[ControlEnvelope] = []
   764	        while not self._heartbeat_envelopes.empty():
   765	            out.append(self._heartbeat_envelopes.get_nowait())
   766	        while not self._envelopes.empty():
   767	            out.append(self._envelopes.get_nowait())
   768	        return out
