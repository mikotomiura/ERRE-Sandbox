  99:   --sglang-adapter "kant_r${r}_real" --temperature 0.7 --window-size 100 \
 100:   --output ".steering/20260514-.../tier-b-icc-multiturn-kant-r${r}.json"
 101: 
 102: # Burrows (Option A、langdetect)
 103: .venv/Scripts/python.exe scripts/m9-c-adopt/compute_burrows_delta.py \
 104:   --persona kant --shards-glob "..." --window-size 100 \
 105:   --output ".steering/20260514-.../tier-b-pilot-multiturn-kant-r${r}-burrows.json"
 106: ```
