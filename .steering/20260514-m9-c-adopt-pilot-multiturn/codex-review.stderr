 100: 
 101: # ---------------------------------------------------------------------------
 102: # Stimulus loading + stratified slice (self-contained replica of
 103: # eval_run_golden._stratified_stimulus_slice to avoid heavy import surface)
 104: # ---------------------------------------------------------------------------
 105: 
 106: 
 107: def _load_stimulus_battery(persona_id: str, root: Path) -> list[dict[str, Any]]:
 108:     path = root / f"{persona_id}.yaml"
 109:     parsed = yaml.safe_load(path.read_text(encoding="utf-8"))
 110:     if not isinstance(parsed, dict) or not isinstance(parsed.get("stimuli"), list):
 111:         msg = f"{path}: malformed stimulus YAML"
 112:         raise ValueError(msg)
 113:     return list(parsed["stimuli"])
 114: 
 115: 
 116: def _focal_turn_count(stimulus: dict[str, Any]) -> int:
 117:     """Folded to 1 — multi-turn stimuli are evaluated as single focal turn."""
 118:     del stimulus
 119:     return 1
 120: 
 121: 
 122: def _stratified_slice(
 123:     battery: list[dict[str, Any]], target_focal_per_cycle: int
 124: ) -> list[dict[str, Any]]:
 125:     if target_focal_per_cycle <= 0:
 126:         return []
 127:     by_cat: dict[str, list[dict[str, Any]]] = defaultdict(list)
 128:     for stim in battery:
 129:         by_cat[str(stim.get("category", ""))].append(stim)
 130:     total = sum(_focal_turn_count(s) for s in battery)
 131:     if total == 0 or target_focal_per_cycle >= total:
 132:         return list(battery)
 133:     selected: list[dict[str, Any]] = []
 134:     chosen = 0
 135:     for stims in by_cat.values():
 136:         cat_total = sum(_focal_turn_count(s) for s in stims)
 137:         share = round(cat_total / total * target_focal_per_cycle)
 138:         cum = 0
 139:         for stim in stims:
 140:             cf = _focal_turn_count(stim)
 141:             if cum + cf > share:
 142:                 break
 143:             selected.append(stim)
 144:             cum += cf
 145:         chosen += cum
 146:     if chosen < target_focal_per_cycle:
 147:         for stim in battery:
 148:             if chosen >= target_focal_per_cycle:
 149:                 break
 150:             if stim in selected:
 151:                 continue
 152:             selected.append(stim)
 153:             chosen += _focal_turn_count(stim)
 154:     selected_ids = {s.get("stimulus_id") for s in selected}
 155:     return [s for s in battery if s.get("stimulus_id") in selected_ids]
 156: 
 157: 
 158: # ---------------------------------------------------------------------------
 159: # Persona prompt — minimal, mirrors eval_run_golden._build_stimulus_system_prompt
 160: # spirit so baseline (no-LoRA) and pilot (LoRA-on) shards are apples-to-apples
 161: # on the prompt axis. The LoRA's contribution is the only conditional variable.
 162: # ---------------------------------------------------------------------------
 163: 
 164: 
 165: def _load_persona_yaml(personas_dir: Path, persona_id: str) -> dict[str, Any]:
 166:     path = personas_dir / f"{persona_id}.yaml"
 167:     return yaml.safe_load(path.read_text(encoding="utf-8")) or {}
 168: 
 169: 
 170: def _build_system_prompt(persona: dict[str, Any]) -> str:
 171:     display = persona.get("display_name", persona.get("persona_id", "agent"))
 172:     era = persona.get("era", "")
 173:     habits_seq: list[Any] = persona.get("cognitive_habits") or []
 174:     habit_lines: list[str] = []
 175:     for habit in list(habits_seq)[:3]:
 176:         if isinstance(habit, dict):
 177:             desc = habit.get("description", "")
 178:             flag = habit.get("flag", "")
 179:             habit_lines.append(f"- {desc} [{flag}]")
 180:     habits_block = "\n".join(habit_lines) if habit_lines else "(no habits recorded)"
 181:     common = (
 182:         "You are an autonomous agent in ERRE-Sandbox. A researcher hands you "
 183:         "a curated stimulus from a Toulmin / Theory-of-Mind / RoleEval / "
 184:         "moral-dilemma battery. Stay in character; speak as yourself, not "
 185:         "about yourself."
 186:     )
 187:     persona_block = (
 188:         f"Persona: {display} ({era}).\nCognitive habits:\n{habits_block}"
 189:     )
 190:     closing = (
 191:         "Respond in a single concise utterance: at most 80 Japanese characters "
 192:         "or 160 Latin characters. Return ONLY the utterance text — no names, "
 193:         "no quotation marks, no stage directions, no JSON, no chain-of-thought."
 194:     )
 195:     return f"{common}\n\n{persona_block}\n\n{closing}"
 196: 
 197: 
 198: def _build_user_prompt(stimulus: dict[str, Any], cycle_idx: int) -> str:
 199:     prompt_text = str(stimulus.get("prompt_text", "")).strip()
 200:     category = str(stimulus.get("category", ""))
 201:     return (
 202:         f"[stimulus_id={stimulus.get('stimulus_id', '?')} "
 203:         f"category={category} cycle={cycle_idx} turn=0]\n\n{prompt_text}"
 204:     )
 205: 
 206: 
 207: # ---------------------------------------------------------------------------
 208: # SGLang HTTP client (urllib only, no httpx dep)
 209: # ---------------------------------------------------------------------------
 210: 
 211: 
 212: @dataclasses.dataclass(frozen=True)
 213: class SGLangChatResponse:
 214:     text: str
 215:     finish_reason: str | None
 216:     raw: dict[str, Any]
 217: 
 218: 
 219: def _sglang_chat(
 220:     *,
 221:     host: str,
 222:     model_name: str,
 223:     system_prompt: str,
 224:     user_prompt: str,
 225:     temperature: float,
 226:     seed: int,
 227:     timeout_s: float,
 228: ) -> SGLangChatResponse:
 229:     """One blocking POST to SGLang ``/v1/chat/completions``."""
 230:     # qwen3 emits <think>...</think> CoT by default; baseline shards were
 231:     # captured via Ollama think=false. Disable thinking for apples-to-apples
 232:     # parity through the chat_template_kwargs hook (qwen3 chat template
 233:     # honours enable_thinking).
 234:     payload = {
 235:         "model": model_name,
 236:         "messages": [
 237:             {"role": "system", "content": system_prompt},
 238:             {"role": "user", "content": user_prompt},
 239:         ],
 240:         "max_tokens": _FOCAL_NUM_PREDICT,
 241:         "temperature": temperature,
 242:         "seed": seed,
 243:         "stop": list(_FOCAL_STOP),
 244:         "chat_template_kwargs": {"enable_thinking": False},
 245:     }
 246:     body = json.dumps(payload).encode("utf-8")
 247:     req = urllib.request.Request(  # noqa: S310 — fixed scheme via host arg
 248:         f"{host.rstrip('/')}/v1/chat/completions",
 249:         data=body,
 250:         headers={"Content-Type": "application/json"},
 251:         method="POST",
 252:     )
 253:     last_exc: Exception | None = None
 254:     for attempt in range(_INFERENCE_RETRY_MAX):
 255:         try:
 256:             with urllib.request.urlopen(req, timeout=timeout_s) as resp:  # noqa: S310
 257:                 raw = json.loads(resp.read().decode("utf-8"))
 258:             choices = raw.get("choices") or []
 259:             if not choices:
 260:                 msg = f"sglang returned no choices: {raw}"
 261:                 raise RuntimeError(msg)
 262:             choice = choices[0]
 263:             text = str(choice.get("message", {}).get("content", "")).strip()
 264:             # Defensive: strip <think>...</think> blocks if leaked despite
 265:             # enable_thinking=False (qwen3 occasionally emits them when the
 266:             # template kwarg is silently ignored by an upstream layer).
 267:             if "</think>" in text:
 268:                 text = text.split("</think>", 1)[1].strip()
 269:             if text.startswith("<think>"):
 270:                 text = text.removeprefix("<think>").strip()
 271:             finish = choice.get("finish_reason")
 272:             return SGLangChatResponse(text=text, finish_reason=finish, raw=raw)
 273:         except (urllib.error.URLError, TimeoutError, RuntimeError, OSError) as exc:
 274:             last_exc = exc
 275:             wait_s = _INFERENCE_RETRY_BACKOFF_S * (2**attempt)
 276:             logger.warning(
 277:                 "sglang chat failed attempt=%d/%d: %s — backing off %.1fs",
 278:                 attempt + 1,
 279:                 _INFERENCE_RETRY_MAX,
 280:                 exc,
 281:                 wait_s,
 282:             )
 283:             time.sleep(wait_s)
 284:     msg = f"sglang chat exhausted {_INFERENCE_RETRY_MAX} attempts: {last_exc!r}"
 285:     raise RuntimeError(msg)
 286: 
 287: 
 288: # ---------------------------------------------------------------------------
 289: # Adapter health check
 290: # ---------------------------------------------------------------------------
 291: 
 292: 
 293: def _ensure_adapter_loaded(*, host: str, adapter_name: str, timeout_s: float) -> None:
 294:     """Verify ``adapter_name`` is in SGLang ``/get_server_info`` loaded set.
 295: 
 296:     Pilot does NOT load adapters itself — operator must launch SGLang with
 297:     ``--max-loras-per-batch >= rank_count`` and POST ``/load_lora_adapter`` for
 298:     each rank ahead of time (re-using ``multi_pin_sanity.sh``). This check
 299:     surfaces a misconfiguration before burning compute on 600 turns.
 300:     """
 301:     req = urllib.request.Request(  # noqa: S310 — fixed host
 302:         f"{host.rstrip('/')}/v1/models",
 303:         headers={"Accept": "application/json"},
 304:     )
 305:     try:
 306:         with urllib.request.urlopen(req, timeout=timeout_s) as resp:  # noqa: S310
 307:             info = json.loads(resp.read().decode("utf-8"))
 308:     except (urllib.error.URLError, TimeoutError, OSError) as exc:
 309:         msg = f"sglang /v1/models unreachable at {host}: {exc!r}"
 310:         raise RuntimeError(msg) from exc
 311:     entries: Iterable[dict[str, Any]] = info.get("data") or []
 312:     loaded_set = {str(entry.get("id", "")) for entry in entries if entry.get("id")}
 313:     if adapter_name not in loaded_set:
 314:         msg = (
 315:             f"adapter {adapter_name!r} not in sglang loaded set"
 316:             f" {sorted(loaded_set)} — POST /load_lora_adapter first"
 317:         )
 318:         raise RuntimeError(msg)
 319: 
