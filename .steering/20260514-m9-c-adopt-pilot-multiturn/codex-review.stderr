  99: def _windowize(utterances: list[str], window_size: int) -> list[list[str]]:
 100:     n = len(utterances)
 101:     full = n // window_size
 102:     return [
 103:         utterances[i * window_size : (i + 1) * window_size] for i in range(full)
 104:     ]
