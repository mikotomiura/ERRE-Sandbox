  65: _INFERENCE_RETRY_MAX: Final = 3
  66: _INFERENCE_RETRY_BACKOFF_S: Final = 1.5
  67: _RAW_DIALOG_TABLE_DDL: Final = """
  68: CREATE SCHEMA IF NOT EXISTS raw_dialog;
  69: CREATE TABLE IF NOT EXISTS raw_dialog.dialog (
  70:     "id" TEXT,
  71:     "run_id" TEXT,
  72:     "dialog_id" TEXT,
  73:     "tick" INTEGER,
  74:     "turn_index" INTEGER,
  75:     "speaker_agent_id" TEXT,
  76:     "speaker_persona_id" TEXT,
  77:     "addressee_agent_id" TEXT,
  78:     "addressee_persona_id" TEXT,
  79:     "utterance" TEXT,
