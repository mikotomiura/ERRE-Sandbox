 686: 
 687: def _initial_state_for_natural(persona: PersonaSpec) -> AgentState:
 688:     """Build the AgentState used to register a persona for the natural run.
 689: 
 690:     Mirrors :func:`erre_sandbox.bootstrap._build_initial_state` but pins
 691:     the spawn ``Position`` to a non-overlapping seat inside :attr:`Zone.AGORA`
 692:     so the M5/M6 separation nudge does not fire on the first physics tick.
 693:     """
 694:     pid = persona.persona_id
 695:     seat = _NATURAL_AGORA_POSITIONS.get(pid, (0.0, 0.0, 0.0))

