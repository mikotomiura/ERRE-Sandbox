  89:     last_stimulus_id TEXT,
  90:     completed_turns INTEGER,
  91:     updated_at TIMESTAMP
  92: );
  93: """
  94: 
  95: _INTERLOCUTOR_ID: Final = "_stimulus"
  96: _AGENT_ID_FMT: Final = "a_{persona_id}_001"
  97: _FOCAL_NUM_PREDICT: Final = 240
  98: _FOCAL_STOP: Final = ("\n\n",)
