 364:             )
 365: 
 366:         mcq_shuffled_options: dict[str, str] | None = None
 367:         shuffled_order: list[str] | None = None
 368:         raw_options = stimulus.get("options")
 369:         if stimulus.get("category") == "roleeval" and isinstance(raw_options, dict):
 370:             shuffled_order = shuffled_mcq_order(
 371:                 self.seed_root, str(stimulus.get("stimulus_id", ""))
 372:             )
 373:             mcq_shuffled_options = shuffled_mcq_options(raw_options, shuffled_order)
 374: 
 375:         open_tick = self._allocate_tick()
 376:         admitted = self.scheduler.schedule_initiate(
 377:             persona_id, self.interlocutor_id, zone, open_tick
 378:         )
 379:         if admitted is None:
 380:             raise RuntimeError(
 381:                 f"scheduler refused initiate for stimulus "
 382:                 f"{stimulus.get('stimulus_id')!r} at tick={open_tick}; "
 383:                 "check golden_baseline_mode is True and the prior "
 384:                 "dialog closed"
 385:             )
 386:         dialog_id = self.scheduler.get_dialog_id(persona_id, self.interlocutor_id)
 387:         if dialog_id is None:
 388:             raise RuntimeError(
 389:                 "scheduler admitted initiate but get_dialog_id returned None"
 390:             )
 391: 
 392:         prior_turns: list[DialogTurnMsg] = []
 393:         for turn_index in range(expected_turn_count):
 394:             turn_tick = self._allocate_tick()
 395:             speaker_id, addressee_id = (
 396:                 (persona_id, self.interlocutor_id)
 397:                 if turn_index % 2 == 0
 398:                 else (self.interlocutor_id, persona_id)
 399:             )
 400:             utterance = self.inference_fn(
 401:                 persona_id=persona_id,
 402:                 stimulus=stimulus,
 403:                 cycle_idx=cycle_idx,
 404:                 turn_index=turn_index,
 405:                 prior_turns=tuple(prior_turns),
