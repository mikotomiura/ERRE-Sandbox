  49: import yaml
  50: 
  51: logger = logging.getLogger(__name__)
  52: 
  53: # ---------------------------------------------------------------------------
  54: # Constants
  55: # ---------------------------------------------------------------------------
  56: 
  57: _REPO_ROOT: Final = Path(__file__).resolve().parents[2]
  58: _DEFAULT_STIMULUS_DIR: Final = _REPO_ROOT / "golden" / "stimulus"
  59: _DEFAULT_PERSONAS_DIR: Final = _REPO_ROOT / "personas"
  60: _DEFAULT_SGLANG_HOST: Final = "http://127.0.0.1:30000"
  61: _DEFAULT_TIMEOUT_S: Final = 120.0
  62: _DEFAULT_TURN_COUNT: Final = 300
  63: _DEFAULT_CYCLE_COUNT: Final = 6
