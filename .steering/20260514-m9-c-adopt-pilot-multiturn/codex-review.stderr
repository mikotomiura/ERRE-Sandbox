 123: # Constants
 124: # ---------------------------------------------------------------------------
 125: 
 126: _DEFAULT_TURN_COUNT: Final[int] = 200
 127: """Focal speaker turn budget per ``(persona, condition)`` cell (P3a target)."""
 128: 
 129: _DEFAULT_CYCLE_COUNT: Final[int] = 3
 130: """Stimulus battery cycle count — matches design-final.md P3 production."""
 131: 
 132: _DEFAULT_WALL_TIMEOUT_MIN: Final[float] = 120.0
 133: """Default wall budget (minutes) for the natural capture phase.
 134: 
 135: m9-eval-system P3a-decide v2 (ME-8 amendment 2026-05-01): G-GEAR re-capture
 604: def _focal_turn_count(stimulus: dict[str, Any]) -> int:
 605:     """Approximate per-stimulus focal-speaker turn count.
 606: 
 607:     The driver alternates speakers (turn 0 = focal, turn 1 = interlocutor, …)
 608:     so over ``expected_turn_count = n`` turns the focal persona speaks
 609:     ``ceil(n / 2)`` times. This approximation is exact for n=1 (MCQ) and
 610:     n=2; for n=3 it matches the driver's interleaving deterministically.
 611:     """
 612:     expected = int(stimulus.get("expected_turn_count", 1))
 613:     return (expected + 1) // 2
 614: 
 615: 
 616: def _stratified_stimulus_slice(  # noqa: C901 — proportional rebalance is inherently branchy
 617:     battery: list[dict[str, Any]],
 618:     *,
 619:     target_focal_per_cycle: int,
 620: ) -> list[dict[str, Any]]:
 621:     """Stratify the battery so the slice's category mix matches the original.
 622: 
 623:     Each category contributes proportionally to its share of the battery's
 624:     total focal-speaker turns; within a category, YAML order is preserved
 625:     (deterministic). When ``target_focal_per_cycle`` exceeds the battery's
 626:     focal-turn capacity the full battery is returned (no oversampling).
 627:     """
 628:     if target_focal_per_cycle <= 0:
 629:         return []
 630:     by_cat: dict[str, list[dict[str, Any]]] = defaultdict(list)
 631:     for stim in battery:
 632:         by_cat[str(stim.get("category", ""))].append(stim)
 633: 
 634:     total_focal = sum(_focal_turn_count(s) for s in battery)
 635:     if total_focal == 0:
 636:         return []
 637:     if target_focal_per_cycle >= total_focal:
 638:         return list(battery)
 639: 
 640:     selected: list[dict[str, Any]] = []
 641:     chosen_focal = 0
 642:     for cat, stims in by_cat.items():
 643:         cat_focal = sum(_focal_turn_count(s) for s in stims)
 644:         # Use ratio rounded to nearest int — sum of ratios may differ from
 645:         # target by a small amount, which we re-balance after the loop.
 646:         share = round(cat_focal / total_focal * target_focal_per_cycle)
 647:         cum = 0
 648:         for stim in stims:
 649:             cf = _focal_turn_count(stim)
 650:             if cum + cf > share:
 651:                 break
 652:             selected.append(stim)
 653:             cum += cf
 654:         chosen_focal += cum
 655:         del cat  # quiet linter; cat was for loop binding only
 656: 
 657:     # Rebalance: if the sum of category shares undershot the target due to
 658:     # rounding, top up by appending the next stimulus from the largest
 659:     # under-represented category until we hit target. Capped at battery
 660:     # length so we cannot oversample.
 661:     if chosen_focal < target_focal_per_cycle:
 662:         remaining: list[dict[str, Any]] = [s for s in battery if s not in selected]
 663:         for stim in remaining:
 664:             if chosen_focal >= target_focal_per_cycle:
 665:                 break
 666:             selected.append(stim)
 667:             chosen_focal += _focal_turn_count(stim)
 668: 
 669:     # Preserve the battery's YAML order (rebalance step may interleave),
 670:     # which keeps cycle-1 / cycle-N pairing identical across test runs.

