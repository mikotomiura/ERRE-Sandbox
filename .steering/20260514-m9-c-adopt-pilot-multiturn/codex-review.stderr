 337: def _build_stimulus_system_prompt(persona: PersonaSpec) -> str:
 338:     """System prompt for the stimulus condition.
 339: 
 340:     Stimulus invocations have no transcript / addressee state; the persona
 341:     block + a stimulus-aware instruction is enough. Order is load-bearing
 342:     (RadixAttention prefix sharing across personas + a single-turn cue).
 343:     """
 344:     common = (
 345:         "You are an autonomous agent in ERRE-Sandbox. A researcher hands you "
 346:         "a curated stimulus from a Toulmin / Theory-of-Mind / RoleEval / "
 347:         "moral-dilemma battery. Stay in character; speak as yourself, not "
 348:         "about yourself."
 349:     )
 350:     persona_block = (
 351:         f"Persona: {persona.display_name} ({persona.era}).\n"
 352:         f"Cognitive habits:\n{_format_persona_habits(persona)}"
 353:     )
 354:     closing = (
 355:         "Respond in a single concise utterance: at most 80 Japanese characters "
 356:         "or 160 Latin characters. Return ONLY the utterance text — no names, "
 357:         "no quotation marks, no stage directions, no JSON, no chain-of-thought."
 358:     )
 359:     return f"{common}\n\n{persona_block}\n\n{closing}"
 360: 
 361: 
 362: def _build_stimulus_user_prompt(
 363:     stimulus: dict[str, Any],
 364:     *,
 365:     cycle_idx: int,
 366:     turn_index: int,
 367:     mcq_options: dict[str, str] | None,
 368: ) -> str:
 369:     """User prompt for a single stimulus turn.
 370: 
 371:     For multi-turn stimuli (``expected_turn_count > 1``) the cue includes the
 372:     turn position so the model knows where in the stimulus arc it is. MCQ
 373:     items get the post-shuffle option block + the deterministic instruction.
 374:     """
 375:     prompt_text = str(stimulus.get("prompt_text", "")).strip()
 376:     category = str(stimulus.get("category", ""))
 377:     body = (
 378:         f"[stimulus_id={stimulus.get('stimulus_id', '?')} category={category} "
 379:         f"cycle={cycle_idx} turn={turn_index}]\n\n{prompt_text}"
 380:     )
 381:     if mcq_options is not None:
 382:         options_block = "\n".join(
 383:             f"({label}) {text}" for label, text in mcq_options.items()
 384:         )
 385:         body = f"{body}\n\nOptions:\n{options_block}\n\n{_MCQ_LANG_HINT}"
 386:     return body
 439: def _make_stimulus_inference_fn(
 440:     *,
 441:     client: OllamaChatClient,
 442:     persona_spec: PersonaSpec,
 443:     sink_state: _SinkState,
 444:     loop: asyncio.AbstractEventLoop,
 445: ) -> Callable[..., str]:
 446:     """Build the synchronous ``inference_fn`` consumed by GoldenBaselineDriver.
 447: 
 448:     The driver expects a sync callable; we hop onto the supplied event loop
 449:     via ``run_coroutine_threadsafe`` because the driver itself runs on the
 450:     main thread (the loop is being driven by ``asyncio.run``). Aborts the
 451:     capture when ``sink_state.fatal_error`` is set (Codex HIGH-3 propagation).
 452:     """
 453:     system_prompt = _build_stimulus_system_prompt(persona_spec)
 454: 
 455:     def inference_fn(
 456:         *,
 457:         persona_id: str,
 458:         stimulus: dict[str, Any],
 459:         cycle_idx: int,
 460:         turn_index: int,
 461:         prior_turns: tuple[DialogTurnMsg, ...],
 462:         mcq_shuffled_options: dict[str, str] | None,
 463:     ) -> str:
 464:         del persona_id, prior_turns  # honoured by the driver but not used here
 465:         if sink_state.fatal_error is not None:
 466:             raise CaptureFatalError(sink_state.fatal_error)
 467:         is_mcq = mcq_shuffled_options is not None
 468:         user_prompt = _build_stimulus_user_prompt(
 469:             stimulus,
 470:             cycle_idx=cycle_idx,
 471:             turn_index=turn_index,
 472:             mcq_options=mcq_shuffled_options,
 473:         )
 474:         messages = [
 475:             ChatMessage(role="system", content=system_prompt),
 476:             ChatMessage(role="user", content=user_prompt),
 477:         ]
 478:         sampling_delta = _MCQ_DETERMINISTIC_SAMPLING if is_mcq else SamplingDelta()
 479:         options: dict[str, Any] = {
 480:             "num_predict": (
 481:                 _STIMULUS_MCQ_NUM_PREDICT if is_mcq else _STIMULUS_NUM_PREDICT
 482:             ),
 483:             "stop": list(_STIMULUS_MCQ_STOP if is_mcq else _STIMULUS_STOP),
 484:         }
 485:         future = asyncio.run_coroutine_threadsafe(
 486:             _retrying_chat(
 487:                 client,
 488:                 messages,
 489:                 sampling_delta=sampling_delta,
 490:                 persona_spec=persona_spec,
 491:                 options=options,
 492:             ),
 493:             loop,
 494:         )
 495:         result = future.result()
 496:         return result if result is not None else ""
 497: 
 498:     return inference_fn

