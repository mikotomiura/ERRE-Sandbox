"C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
from pathlib import Path
import duckdb
for p in sorted(Path('data/eval/golden').glob('kant_stimulus_run*.duckdb')):
    con=duckdb.connect(str(p), read_only=True)
    rows=con.execute(\"\"\"
        SELECT count(*) total,
               sum(CASE WHEN speaker_persona_id='kant' THEN 1 ELSE 0 END) focal,
               sum(CASE WHEN speaker_persona_id <> 'kant' THEN 1 ELSE 0 END) other,
               count(DISTINCT dialog_id) dialogs,
               min(turn_index), max(turn_index)
        FROM raw_dialog.dialog
    \"\"\").fetchone()
    byturn=con.execute(\"SELECT turn_index, count(*) FROM raw_dialog.dialog GROUP BY 1 ORDER BY 1\").fetchall()
    con.close()
    print(p.name, rows, byturn)
print('pilot')
for p in sorted(Path('data/eval/m9-c-adopt-tier-b-pilot').glob('kant_r*_run*_stim.duckdb'))[:10]:
    con=duckdb.connect(str(p), read_only=True)
    rows=con.execute(\"SELECT count(*), sum(CASE WHEN speaker_persona_id='kant' THEN 1 ELSE 0 END), count(DISTINCT dialog_id), min(turn_index), max(turn_index) FROM raw_dialog.dialog\").fetchone()
    con.close()
    print(p.name, rows)
