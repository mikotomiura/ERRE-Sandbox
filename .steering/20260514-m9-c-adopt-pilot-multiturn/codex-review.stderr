 140:     prior_turns: tuple[Any, ...],
 141:     mcq_shuffled_options: dict[str, str] | None,
 142: ) -> str:
 143:     """Deterministic per-cell text — honours the driver's call signature."""
 144:     del prior_turns
 145:     label = "?"
 146:     if mcq_shuffled_options is not None:
 147:         # Pick the first option label so MCQ rows always parse.
 148:         label = next(iter(mcq_shuffled_options))
