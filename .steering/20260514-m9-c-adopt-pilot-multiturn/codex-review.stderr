 357:         """Open → drive turns → close one stimulus dialog using public API."""
 358:         zone = _zone_from_str(stimulus.get("expected_zone"))
 359:         expected_turn_count = int(stimulus.get("expected_turn_count", 1))
 360:         if expected_turn_count < 1:
 361:             raise ValueError(
