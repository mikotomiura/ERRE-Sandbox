 231:             f" (positive = LoRA-on > baseline → WRONG direction for DA-1 axis 1);"
 232:             f" Burrows reduction = {row['burrows_reduction_point']:+.3%}"
 233:             f" (positive = reduction → correct direction)"
 234:         )
