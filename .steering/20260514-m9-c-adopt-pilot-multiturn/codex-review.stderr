 915:     # Populate the zone cache as the driver opens dialogs by hooking the
 916:     # envelope sink. We receive a DialogInitiateMsg per open with its
 917:     # ``zone``; feed it into ``state.last_zone_by_speaker`` keyed on
 918:     # dialog_id (not speaker_id, because both pair members share it).
 919:     initiate_log: dict[str, str] = {}
 920: 
 921:     def _envelope_sink(env: Any) -> None:
 922:         zone = getattr(env, "zone", None)
 923:         dialog_id = getattr(env, "dialog_id", None)
 924:         if zone is not None and dialog_id is None:
