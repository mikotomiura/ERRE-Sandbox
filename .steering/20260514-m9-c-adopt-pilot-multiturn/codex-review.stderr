 succeeded in 796ms:
   1: """External golden-baseline driver for m9-eval-system P2c.
   2: 
   3: This module owns nothing inside :class:`InMemoryDialogScheduler`; it
   4: drives the scheduler exclusively through the public API
   5: (``schedule_initiate`` / ``record_turn`` / ``close_dialog``). When the
   6: 70-stimulus battery × 3-cycle phase is running, the scheduler is held in
   7: ``golden_baseline_mode=True`` so the natural-dialog cooldown / timeout /
   8: zone restrictions do not interfere. The driver flips
   9: ``scheduler.golden_baseline_mode`` back to ``False`` between phases via
  10: :meth:`GoldenBaselineDriver.enable_natural_phase`, so a single scheduler
  11: instance covers both the stimulus phase and the 300-turn natural-dialog
  12: phase of one golden run.
  13: 
  14: Responsibilities:
  15: 
  16: * :func:`derive_seed` — process-stable ``uint64`` per-run seed derived
  17:   via ``hashlib.blake2b`` (ME-5 / Codex MEDIUM-5; Python's salted
  18:   ``hash()`` is not reproducible across processes).
  19: * :func:`shuffled_mcq_order` — per-cell deterministic shuffle of the
  20:   ``A/B/C/D`` MCQ option keys using ``numpy.random.Generator(PCG64)``
  21:   seeded by ``blake2b(seed_root | stimulus_id)`` (ME-7 §1).
  22: * :class:`GoldenBaselineDriver` — orchestrates one persona's full
  23:   battery: opens / drives / closes one dialog per stimulus, alternating
  24:   the speaker on multi-turn stimuli, and records MCQ scoring outcomes
  25:   with the ME-7 scoring protocol (cycle 1 only primary, source_grade
  26:   ``legend`` excluded, ``category_subscore_eligible=False`` excluded).
  27: * :func:`build_seed_manifest` / :func:`write_seed_manifest` —
  28:   reproducible ``golden/seeds.json`` generation, runnable as
  29:   ``python -m erre_sandbox.evidence.golden_baseline``.
  30: 
  31: Refs:
  32:     - ``.steering/20260430-m9-eval-system/design-final.md``
  33:       §"Orchestrator: 既存 scheduler に minimum patch + 外部 golden driver"
  34:     - ``.steering/20260430-m9-eval-system/decisions.md`` ME-5 (RNG seed),
  35:       ME-7 (MCQ schema / scoring protocol)
  36:     - ``golden/stimulus/_schema.yaml`` (single-source-of-truth schema)
  37: """
  38: 
  39: from __future__ import annotations
  40: 
  41: import hashlib
  42: import json
  43: import logging
  44: from dataclasses import dataclass, field
  45: from pathlib import Path
 298: class GoldenBaselineDriver:
 299:     """Drive a golden-baseline run for one persona via the public scheduler API.
 300: 
 301:     The driver is single-persona on purpose — multi-persona runs use
 302:     fresh ``GoldenBaselineDriver`` instances seeded from
 303:     :func:`derive_seed` so their RNG streams stay independent.
 304:     """
 305: 
 306:     scheduler: InMemoryDialogScheduler
 307:     inference_fn: Callable[..., str]
 308:     seed_root: int
 309:     cycle_count: int = DEFAULT_CYCLE_COUNT
 310:     interlocutor_id: str = DEFAULT_INTERLOCUTOR_ID
 311:     _tick_cursor: int = field(default=0, init=False, repr=False)
 312: 
 313:     def __post_init__(self) -> None:
 314:         if not self.scheduler.golden_baseline_mode:
 315:             raise ValueError(
 316:                 "GoldenBaselineDriver requires "
 317:                 "scheduler.golden_baseline_mode=True at construction time"
 318:             )
 319:         if self.cycle_count < 1:
 320:             raise ValueError(f"cycle_count must be >=1, got {self.cycle_count}")
 321: 
 322:     @property
 323:     def tick_cursor(self) -> int:
 324:         """Read-only view of the next tick the driver will allocate."""
 325:         return self._tick_cursor
 326: 
 327:     def enable_natural_phase(self) -> None:
 328:         """Flip the scheduler back to natural-dialog rules between phases."""
 329:         self.scheduler.golden_baseline_mode = False
 330: 
 331:     def run_persona(
 332:         self,
 333:         persona_id: str,
 334:         *,
 335:         stimuli: list[dict[str, Any]] | None = None,
 336:     ) -> list[StimulusOutcome]:
 337:         """Drive ``stimuli`` × ``cycle_count`` for ``persona_id``.
 338: 
 339:         When ``stimuli`` is ``None`` the production battery for the
 340:         given persona is loaded from ``golden/stimulus/<persona>.yaml``.
 341:         Test callers can pass a synthetic list to control battery size
 342:         without touching the production YAML.
 343:         """
 344:         battery = stimuli if stimuli is not None else load_stimulus_battery(persona_id)
 345:         return [
 346:             self.run_stimulus(persona_id, stimulus, cycle_idx)
 347:             for cycle_idx in range(1, self.cycle_count + 1)
 348:             for stimulus in battery
 349:         ]

