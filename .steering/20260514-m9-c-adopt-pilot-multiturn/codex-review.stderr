 succeeded in 794ms:
   1: """DA-1 4-軸 intersection matrix consumer — Phase B 第 4 セッション.
   2: 
   3: Reads the four metric JSON artefacts (baseline + per-rank Vendi semantic,
   4: Big5 ICC, Burrows Δ, and the per-rank single_lora bench output) and renders
   5: a markdown matrix + per-axis PASS/FAIL decision per DA-1 / DA-8 / DA-9.
   6: 
   7: Effect size for axis 1 (Vendi) is computed as Cohen's d between LoRA-on
   8: window means and baseline window means; positive d → LoRA-on > baseline,
   9: which is the **wrong** direction (DA-1 asks for "LoRA-on < no-LoRA").
  10: """
  11: 
  12: from __future__ import annotations
  13: 
  14: import argparse
  15: import json
  16: import math
  17: import sys
  18: from pathlib import Path
  19: from statistics import mean, stdev
  20: 
  21: 
  22: def _load(p: Path) -> dict:
  23:     return json.loads(p.read_text(encoding="utf-8"))
  24: 
  25: 
  26: def _vendi_window_scores(payload: dict) -> list[float]:
  27:     return [float(w["vendi_score"]) for w in payload["per_window"]]
  28: 
  29: 
  30: def _burrows_window_means(payload: dict) -> list[float]:
  31:     return [
  32:         float(w["mean_burrows"])
  33:         for w in payload["per_window"]
  34:         if w["mean_burrows"] is not None
  35:     ]
  36: 
  37: 
  38: def _cohens_d(a: list[float], b: list[float]) -> float:
  39:     """Pooled-SD Cohen's d (a vs b)."""
  40:     if len(a) < 2 or len(b) < 2:
  41:         return float("nan")
  42:     ma, mb = mean(a), mean(b)
  43:     sa, sb = stdev(a), stdev(b)
  44:     na, nb = len(a), len(b)
  45:     pooled_var = ((na - 1) * sa * sa + (nb - 1) * sb * sb) / max(na + nb - 2, 1)
  46:     pooled_sd = math.sqrt(max(pooled_var, 1e-30))
  47:     return (ma - mb) / pooled_sd
  48: 
  49: 
  50: def _icc_summary(payload: dict) -> dict:
  51:     icc = payload["icc"]
  52:     return {
  53:         "point": icc["icc_consistency_average"],
  54:         "lo": icc["icc_consistency_lower_ci"],
  55:         "hi": icc["icc_consistency_upper_ci"],
  56:         "agreement_point": icc["icc_agreement_single"],
  57:         "agreement_lo": icc["icc_agreement_lower_ci"],
  58:         "agreement_hi": icc["icc_agreement_upper_ci"],
  59:     }
  60: 
  61: 
  62: def _bench_throughput(jsonl_path: Path) -> float:
  63:     """Pull output_throughput_tok_s from the *last* JSONL row in a bench file."""
  64:     last = None
  65:     for line in jsonl_path.read_text(encoding="utf-8").splitlines():
  66:         line = line.strip()
  67:         if not line:
  68:             continue
  69:         try:
  70:             last = json.loads(line)
  71:         except json.JSONDecodeError:
  72:             continue
  73:     if last is None:
  74:         return float("nan")
  75:     return float(
  76:         last.get("output_throughput")
  77:         or last.get("output_throughput_token_s")
  78:         or last.get("output_throughput_tok_s")
  79:         or last.get("output_tok_s")
  80:         or last.get("output_token_throughput")
  81:         or 0.0
  82:     )
  83: 
  84: 
  85: def main() -> int:
  86:     p = argparse.ArgumentParser()
  87:     p.add_argument("--steering-dir", type=Path, required=True)
  88:     p.add_argument("--bench-dir", type=Path, required=True)
  89:     p.add_argument("--throughput-threshold", type=float, default=24.25)
  90:     p.add_argument("--ranks", nargs="+", type=int, default=[4, 8, 16])
  91:     p.add_argument("--output", type=Path, required=True)
  92:     args = p.parse_args()
  93: 
  94:     steering = args.steering_dir
  95:     bench = args.bench_dir
  96:     ranks = args.ranks
  97: 
  98:     # Load baselines
  99:     vendi_baseline = _load(steering / "tier-b-baseline-kant-vendi-semantic.json")
 100:     icc_baseline = _load(steering / "tier-b-baseline-kant-icc.json")
 101:     burrows_baseline = _load(steering / "tier-b-baseline-kant-burrows.json")
 102: 
 103:     baseline_vendi_scores = _vendi_window_scores(vendi_baseline)
 104:     baseline_burrows_means = _burrows_window_means(burrows_baseline)
 105: 
 106:     rows: list[dict] = []
 107:     rows.append(
 108:         {
 109:             "label": "no-LoRA baseline",
 110:             "vendi": vendi_baseline["bootstrap"],
 111:             "vendi_scores": baseline_vendi_scores,
 112:             "icc": _icc_summary(icc_baseline),
 113:             "burrows": burrows_baseline["bootstrap"],
 114:             "burrows_means": baseline_burrows_means,
 115:             "throughput": float("nan"),
 116:             "throughput_pass": None,
 117:             "axes": {},
 118:         }
 119:     )
 120: 
 121:     for r in ranks:
 122:         vendi_r = _load(steering / f"tier-b-pilot-kant-r{r}-vendi-semantic.json")
 123:         icc_r = _load(steering / f"tier-b-icc-kant-r{r}.json")
 124:         burrows_r = _load(steering / f"tier-b-pilot-kant-r{r}-burrows.json")
 125:         vendi_scores_r = _vendi_window_scores(vendi_r)
 126:         burrows_means_r = _burrows_window_means(burrows_r)
 127:         throughput = _bench_throughput(bench / f"single_lora-r{r}.jsonl")
 128: 
 129:         # Axis 1: Vendi semantic effect size + direction (LoRA-on < no-LoRA)
 130:         d = _cohens_d(vendi_scores_r, baseline_vendi_scores)
 131:         # DA-1 wants LoRA-on < baseline so we want d < 0; "effect size d's |·|"
 132:         # only counts when direction is correct.
 133:         vendi_point = vendi_r["bootstrap"]["point"]
 134:         vendi_lo = vendi_r["bootstrap"]["lo"]
 135:         baseline_vendi_hi = vendi_baseline["bootstrap"]["hi"]
 136:         direction_pass = vendi_point < vendi_baseline["bootstrap"]["point"]
 137:         ci_lo_clears_zero = (baseline_vendi_hi - vendi_point) > 0  # rough
 138:         axis1_pass = direction_pass and ci_lo_clears_zero
 139: 
 140:         # Axis 2: ICC(C,k) >= 0.6 point + CI lower >= 0.6
 141:         icc_summary = _icc_summary(icc_r)
 142:         axis2_pass = icc_summary["point"] >= 0.6 and icc_summary["lo"] >= 0.6
 143: 
 144:         # Axis 3: Burrows Δ reduction >= 10% point + CI lower > 0
 145:         burrows_point = burrows_r["bootstrap"]["point"]
 146:         baseline_burrows_point = burrows_baseline["bootstrap"]["point"]
 147:         reduction_ratio = (
 148:             baseline_burrows_point - burrows_point
 149:         ) / baseline_burrows_point  # positive = reduction
 150:         burrows_lo = burrows_r["bootstrap"]["lo"]
 151:         burrows_hi = burrows_r["bootstrap"]["hi"]
 152:         # CI lower > 0 on the reduction implies baseline_lo > burrows_hi (no overlap, baseline higher)
 153:         ci_lower_reduction = (
 154:             burrows_baseline["bootstrap"]["lo"] - burrows_hi
 155:         ) / baseline_burrows_point
 156:         axis3_pass = reduction_ratio >= 0.10 and ci_lower_reduction > 0.0
 157: 
 158:         # Axis 4: throughput >= 70% baseline (= 24.25)
 159:         axis4_pass = (
 160:             (throughput >= args.throughput_threshold)
 161:             if throughput == throughput  # not NaN
 162:             else False
 163:         )
 164: 
 165:         axes_pass = sum([axis1_pass, axis2_pass, axis3_pass, axis4_pass])
 166:         rows.append(
 167:             {
 168:                 "label": f"rank={r}",
 169:                 "vendi": vendi_r["bootstrap"],
 170:                 "vendi_scores": vendi_scores_r,
 171:                 "vendi_cohens_d": d,
 172:                 "vendi_axis1_pass": axis1_pass,
 173:                 "icc": icc_summary,
 174:                 "icc_axis2_pass": axis2_pass,
 175:                 "burrows": burrows_r["bootstrap"],
 176:                 "burrows_means": burrows_means_r,
 177:                 "burrows_reduction_point": reduction_ratio,
 178:                 "burrows_axis3_pass": axis3_pass,
 179:                 "throughput": throughput,
 180:                 "throughput_axis4_pass": axis4_pass,
 181:                 "axes_pass_count": axes_pass,
 182:             }
 183:         )
 184: 
 185:     out_payload = {
 186:         "thresholds": {
 187:             "vendi_direction": "LoRA-on < no-LoRA",
 188:             "icc_min_point": 0.6,
 189:             "icc_min_lo": 0.6,
 190:             "burrows_reduction_min": 0.10,
 191:             "throughput_min_tok_s": args.throughput_threshold,
 192:         },
 193:         "rows": rows,
 194:     }
 195:     args.output.parent.mkdir(parents=True, exist_ok=True)
 196:     args.output.write_text(json.dumps(out_payload, indent=2), encoding="utf-8")
 197: 
 198:     # Pretty-print markdown matrix to stdout
 199:     print("# DA-1 4-axis matrix — kant Phase B 第 4 セッション\n")
 200:     print("| rank | Vendi semantic | ICC(C,k) | Burrows Δ | throughput | axes PASS |")
 201:     print("|---|---|---|---|---|---|")
 202:     for row in rows:
 203:         v = row["vendi"]
 204:         i = row["icc"]
 205:         b = row["burrows"]
 206:         if row["label"] == "no-LoRA baseline":
 207:             t = "K-β 34.64 / threshold 24.25"
 208:             axes = "—"
 209:         else:
 210:             tn = row["throughput"]
 211:             t = f"{tn:.2f} ({'PASS' if row['throughput_axis4_pass'] else 'FAIL'})"
 212:             axes = (
 213:                 f"{row['axes_pass_count']}/4"
 214:                 f" (V:{ 'PASS' if row['vendi_axis1_pass'] else 'FAIL'},"
 215:                 f" I:{ 'PASS' if row['icc_axis2_pass'] else 'FAIL'},"
 216:                 f" B:{ 'PASS' if row['burrows_axis3_pass'] else 'FAIL'},"
 217:                 f" T:{ 'PASS' if row['throughput_axis4_pass'] else 'FAIL'})"
 218:             )
 219:         print(
 220:             f"| {row['label']} | "
 221:             f"{v['point']:.3f} [{v['lo']:.3f}, {v['hi']:.3f}] | "
 222:             f"{i['point']:.4f} [{i['lo']:.4f}, {i['hi']:.4f}] | "
 223:             f"{b['point']:.3f} [{b['lo']:.3f}, {b['hi']:.3f}] | "
 224:             f"{t} | {axes} |"
 225:         )
 226: 
 227:     print("\n## Per-rank diagnostic")
 228:     for row in rows[1:]:
