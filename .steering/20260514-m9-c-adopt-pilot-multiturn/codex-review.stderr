 127: # ---------------------------------------------------------------------------
 128: # Responder factories
 129: # ---------------------------------------------------------------------------
 130: 
 131: 
 132: def _build_ollama_responder(
 133:     *,
 134:     host: str,
 135:     model: str,
 136:     think: bool,
 137:     timeout_s: float,
 138:     seed_offset: int,
 139:     temperature: float,
 140: ) -> Callable[[str], int]:
 141:     base = host.rstrip("/")
 142:     # Per-call seed counter so each IPIP item gets a unique seed; at T>0
 143:     # this produces administration-level stochasticity while remaining
 144:     # reproducible across re-runs (deterministic ladder from seed_offset).
 145:     state = {"call_idx": 0}
 146: 
 147:     def responder(prompt: str) -> int:
 148:         call_seed = (seed_offset ^ (state["call_idx"] * 0x85EBCA77)) & 0xFFFFFFFF
 149:         state["call_idx"] += 1
 150:         payload: dict[str, Any] = {
 151:             "model": model,
 152:             "messages": [{"role": "user", "content": prompt}],
 153:             "stream": False,
 154:             "think": think,
 155:             "options": {
 156:                 "temperature": temperature,
 157:                 "num_predict": 8,
 158:                 "seed": int(call_seed),
 159:             },
 160:         }
 161:         body = json.dumps(payload).encode("utf-8")
 162:         req = urllib.request.Request(  # noqa: S310 — fixed host
 163:             f"{base}/api/chat",
 164:             data=body,
 165:             headers={"Content-Type": "application/json"},
 166:             method="POST",
 167:         )
 168:         last_exc: Exception | None = None
 169:         for attempt in range(_DEFAULT_RETRY_MAX):
 170:             try:
 171:                 with urllib.request.urlopen(req, timeout=timeout_s) as resp:  # noqa: S310
 172:                     raw = json.loads(resp.read().decode("utf-8"))
 173:                 text = str(raw.get("message", {}).get("content", "")).strip()
 174:                 return _clamp_likert(_extract_likert(text))
 175:             except (urllib.error.URLError, TimeoutError, OSError, json.JSONDecodeError) as exc:
 176:                 last_exc = exc
 177:                 wait_s = _DEFAULT_RETRY_BACKOFF_S * (2**attempt)
 178:                 logger.warning(
 179:                     "ollama responder attempt=%d/%d failed: %s — sleep %.1fs",
 180:                     attempt + 1,
 181:                     _DEFAULT_RETRY_MAX,
 182:                     exc,
 183:                     wait_s,
 184:                 )
 185:                 time.sleep(wait_s)
 186:         msg = f"ollama responder exhausted retries: {last_exc!r}"
 187:         raise RuntimeError(msg)
 188: 
 189:     return responder
 190: 
 191: 
 192: def _build_sglang_responder(
 193:     *,
 194:     host: str,
 195:     adapter: str,
 196:     timeout_s: float,
 197:     seed_offset: int,
 198:     temperature: float,
 199: ) -> Callable[[str], int]:
 200:     base = host.rstrip("/")
 201:     state = {"call_idx": 0}
 202: 
 203:     def responder(prompt: str) -> int:
 204:         call_seed = (seed_offset ^ (state["call_idx"] * 0x85EBCA77)) & 0xFFFFFFFF
 205:         state["call_idx"] += 1
 206:         payload: dict[str, Any] = {
 207:             "model": adapter,
 208:             "messages": [{"role": "user", "content": prompt}],
 209:             "temperature": temperature,
 210:             "max_tokens": 8,
 211:             "seed": int(call_seed),
 212:             "chat_template_kwargs": {"enable_thinking": False},
 213:         }
 214:         body = json.dumps(payload).encode("utf-8")
 215:         req = urllib.request.Request(  # noqa: S310 — fixed host
 216:             f"{base}/v1/chat/completions",
 217:             data=body,
 218:             headers={"Content-Type": "application/json"},
 219:             method="POST",
 220:         )
 221:         last_exc: Exception | None = None
 222:         for attempt in range(_DEFAULT_RETRY_MAX):
 223:             try:
 224:                 with urllib.request.urlopen(req, timeout=timeout_s) as resp:  # noqa: S310
 225:                     raw = json.loads(resp.read().decode("utf-8"))
 226:                 choices = raw.get("choices") or []
 227:                 if not choices:
 228:                     msg = f"sglang returned no choices: {raw}"
 229:                     raise RuntimeError(msg)
 230:                 text = str(choices[0].get("message", {}).get("content", "")).strip()
 231:                 return _clamp_likert(_extract_likert(text))
 232:             except (urllib.error.URLError, TimeoutError, RuntimeError, OSError, json.JSONDecodeError) as exc:
 233:                 last_exc = exc
 234:                 wait_s = _DEFAULT_RETRY_BACKOFF_S * (2**attempt)
 235:                 logger.warning(
 236:                     "sglang responder attempt=%d/%d failed: %s — sleep %.1fs",
 237:                     attempt + 1,
 238:                     _DEFAULT_RETRY_MAX,
 239:                     exc,
 240:                     wait_s,
 241:                 )
 242:                 time.sleep(wait_s)
 243:         msg = f"sglang responder exhausted retries: {last_exc!r}"
 244:         raise RuntimeError(msg)
 245: 
 246:     return responder
 247: 
 248: 
 249: def _clamp_likert(value: int) -> int:
 250:     return max(DEFAULT_LIKERT_MIN, min(DEFAULT_LIKERT_MAX, value))
 251: 
