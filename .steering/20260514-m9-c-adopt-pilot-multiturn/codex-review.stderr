"C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import yaml
from pathlib import Path
from collections import Counter, defaultdict
p=Path('golden/stimulus/kant.yaml')
data=yaml.safe_load(p.read_text(encoding='utf-8'))
stims=list(data['stimuli'])
def focal(s): return max(1,(int(s.get('expected_turn_count',1))+1)//2)
def total(s): return int(s.get('expected_turn_count',1))
print('n_stim', len(stims))
print('expected_turn_counts', Counter(total(s) for s in stims))
print('full_focal', sum(focal(s) for s in stims), 'full_total', sum(total(s) for s in stims), 'full_inter', sum(total(s)-focal(s) for s in stims))
# simulate proposed _stratified_slice preserving category iteration order in yaml
target=50
by_cat=defaultdict(list)
for s in stims:
    by_cat[str(s.get('category',''))].append(s)
T=sum(focal(s) for s in stims)
selected=[]; chosen=0
for cat, ss in by_cat.items():
    cat_total=sum(focal(s) for s in ss)
    share=round(cat_total/T*target)
    cum=0
    for s in ss:
        cf=focal(s)
        if cum+cf>share:
            break
        selected.append(s); cum+=cf
    chosen += cum
if chosen < target:
    for s in stims:
        if chosen>=target: break
        if s in selected: continue
        selected.append(s); chosen += focal(s)
print('selected_stim', len(selected), 'selected_focal_per_cycle', sum(focal(s) for s in selected), 'selected_total_per_cycle', sum(total(s) for s in selected), 'selected_inter_per_cycle', sum(total(s)-focal(s) for s in selected))
print('selected_counts', Counter(total(s) for s in selected))
print('6 cycles focal', 6*sum(focal(s) for s in selected), 'total', 6*sum(total(s) for s in selected), 'inter', 6*sum(total(s)-focal(s) for s in selected))
print('categories')
for cat, ss in by_cat.items():
    sel=[s for s in selected if s in ss]
    print(cat, 'all n', len(ss), 'all focal', sum(focal(s) for s in ss), 'sel n', len(sel), 'sel focal', sum(focal(s) for s in sel), 'sel total', sum(total(s) for s in sel), 'counts', Counter(total(s) for s in sel))
