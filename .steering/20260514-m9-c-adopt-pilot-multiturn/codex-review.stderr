 107: def _extract_likert(reply: str) -> int:
 108:     """Pull the first 1-5 digit out of an LLM reply.
 109: 
 110:     Defensive against verbose responders that ignore the "reply with only the
 111:     digit" instruction. Falls back to neutral 3 when no digit is found so the
 112:     administration completes; that fallback contributes to the
 113:     ``acquiescence_index`` diagnostic and is therefore detectable.
 114:     """
 115:     stripped = reply.strip()
 116:     # qwen3 may still emit <think> blocks when enable_thinking is misrouted.
 117:     if "</think>" in stripped:
 118:         stripped = stripped.split("</think>", 1)[1].strip()
 119:     if stripped.startswith("<think>"):
 120:         stripped = stripped.removeprefix("<think>").strip()
 121:     match = _LIKERT_RE.search(stripped)
 122:     if match is None:
 123:         return 3
 124:     return int(match.group(0))
