  46: def test_focal_turn_count_handles_odd_and_even() -> None:
  47:     """``ceil(n/2)`` matches the driver's alternating-speaker layout."""
  48:     assert _focal_turn_count({"expected_turn_count": 1}) == 1
  49:     assert _focal_turn_count({"expected_turn_count": 2}) == 1
