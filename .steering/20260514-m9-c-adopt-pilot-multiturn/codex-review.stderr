 394: async def _retrying_chat(
 395:     client: OllamaChatClient,
 396:     messages: list[ChatMessage],
 397:     *,
 398:     sampling_delta: SamplingDelta,
 399:     persona_spec: PersonaSpec,
 400:     options: dict[str, Any],
 401: ) -> str | None:
 402:     """Issue ``chat()`` with bounded retry; return ``None`` on terminal failure.
 403: 
 404:     Retries only on :class:`OllamaUnavailableError` (transient HTTP / parse
 405:     issues). Logical content failures fall through to the caller, which
 406:     handles MCQ-specific scoring on the resulting empty string.
 407:     """
 408:     last_exc: OllamaUnavailableError | None = None
 409:     sampling = compose_sampling(persona_spec.default_sampling, sampling_delta)
 410:     for attempt in range(_INFERENCE_RETRY_MAX_ATTEMPTS):
 411:         try:
 412:             resp = await client.chat(
 413:                 messages,
 414:                 sampling=sampling,
 415:                 options=options,
 416:                 think=False,
 417:             )
 418:         except OllamaUnavailableError as exc:
 419:             last_exc = exc
 420:             wait_s = _INFERENCE_RETRY_BASE_S * (_INFERENCE_RETRY_MULTIPLIER**attempt)
 421:             logger.warning(
 422:                 "ollama chat failed attempt=%d/%d: %s — backing off %.2fs",
 423:                 attempt + 1,
 424:                 _INFERENCE_RETRY_MAX_ATTEMPTS,
 425:                 exc,
 426:                 wait_s,
 427:             )
 428:             await asyncio.sleep(wait_s)
 429:             continue
 430:         return str(resp.content)
 431:     logger.error(
 432:         "ollama chat exhausted %d attempts: %s",
 433:         _INFERENCE_RETRY_MAX_ATTEMPTS,
 434:         last_exc,
 435:     )
 436:     return None
 437: 
