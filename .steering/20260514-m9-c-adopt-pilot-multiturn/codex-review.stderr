 321: # ---------------------------------------------------------------------------
 322: # DuckDB sink + checkpoint
 323: # ---------------------------------------------------------------------------
 324: 
 325: 
 326: def _bootstrap_db(con: duckdb.DuckDBPyConnection) -> None:
 327:     con.execute(_RAW_DIALOG_TABLE_DDL)
 328: 
 329: 
 330: def _read_resume_state(con: duckdb.DuckDBPyConnection) -> tuple[int, str | None, int]:
 331:     rows = con.execute(
 332:         "SELECT last_cycle_idx, last_stimulus_id, completed_turns"
 333:         " FROM pilot_state ORDER BY updated_at DESC LIMIT 1"
 334:     ).fetchall()
 335:     if not rows:
 336:         return 0, None, 0
 337:     return int(rows[0][0]), rows[0][1], int(rows[0][2])
 338: 
 339: 
 340: def _flush_state(
 341:     con: duckdb.DuckDBPyConnection,
 342:     cycle_idx: int,
 343:     stimulus_id: str,
 344:     completed: int,
 345: ) -> None:
 346:     con.execute("DELETE FROM pilot_state")
 347:     con.execute(
 348:         "INSERT INTO pilot_state VALUES (?, ?, ?, ?)",
 349:         (cycle_idx, stimulus_id, completed, datetime.now(UTC)),
 350:     )
 351: 
 352: 
 353: def _insert_focal_turn(
 354:     con: duckdb.DuckDBPyConnection,
 355:     *,
 356:     run_id: str,
 357:     persona_id: str,
 358:     dialog_id: str,
 359:     tick: int,
 360:     utterance: str,
 361:     zone: str,
 362: ) -> None:
 363:     row_id = f"{run_id}:{dialog_id}:0"
 364:     con.execute(
 365:         "INSERT INTO raw_dialog.dialog"
 366:         ' ("id", "run_id", "dialog_id", "tick", "turn_index",'
 367:         ' "speaker_agent_id", "speaker_persona_id",'
 368:         ' "addressee_agent_id", "addressee_persona_id",'
 369:         ' "utterance", "mode", "zone", "reasoning",'
 370:         ' "epoch_phase", "created_at")'
 371:         " VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
 372:         (
 373:             row_id,
 374:             run_id,
 375:             dialog_id,
 376:             tick,
 377:             0,
 378:             _AGENT_ID_FMT.format(persona_id=persona_id),
 379:             persona_id,
 380:             _INTERLOCUTOR_ID,
 381:             _INTERLOCUTOR_ID,
 382:             utterance,
 383:             "",  # mode reserved for ERRE FSM (eval doesn't fire FSM)
 384:             zone,
 385:             "",
 386:             "evaluation",  # DB11 contamination contract — eval-only
 387:             datetime.now(UTC),
 388:         ),
 389:     )
 390: 
 391: 
 392: # ---------------------------------------------------------------------------
 393: # Main loop
 394: # ---------------------------------------------------------------------------
 395: 
 396: 
 397: def _derive_seed(persona: str, rank: int, run_idx: int) -> int:
 398:     key = f"{persona}|r{rank}|run{run_idx}".encode()
 399:     return int.from_bytes(hashlib.blake2b(key, digest_size=8).digest(), "little")
 400: 
 401: 
 402: def run_pilot(args: argparse.Namespace) -> int:
 403:     persona_id = args.persona
 404:     rank = args.rank
 405:     run_idx = args.run_idx
 406:     adapter_name = args.adapter_name or f"{persona_id}_r{rank}_real"
 407: 
 408:     persona_yaml = _load_persona_yaml(args.personas_dir, persona_id)
 409:     system_prompt = _build_system_prompt(persona_yaml)
 410: 
 411:     battery = _load_stimulus_battery(persona_id, args.stimulus_dir)
 412:     target_per_cycle = max(1, args.turn_count // max(1, args.cycle_count))
 413:     sliced = _stratified_slice(battery, target_focal_per_cycle=target_per_cycle)
 414:     if not sliced:
 415:         logger.error("stratified slice produced 0 stimuli for persona=%s", persona_id)
 416:         return 2
 417: 
 418:     seed_root = _derive_seed(persona_id, rank, run_idx)
 419:     run_id = f"{persona_id}_r{rank}_run{run_idx}_pilot"
 420: 
 421:     args.output.parent.mkdir(parents=True, exist_ok=True)
 422:     con = duckdb.connect(str(args.output), read_only=False)
 423:     _bootstrap_db(con)
 424: 
 425:     resume_cycle, resume_stim, completed = _read_resume_state(con)
 426:     if completed > 0:
 427:         logger.info(
 428:             "resuming from cycle=%d last_stim=%s completed=%d",
 429:             resume_cycle,
 430:             resume_stim,
 431:             completed,
 432:         )
 433: 
 434:     if not args.skip_adapter_check:
 435:         _ensure_adapter_loaded(
 436:             host=args.sglang_host,
 437:             adapter_name=adapter_name,
 438:             timeout_s=args.timeout_s,
 439:         )
 440:         logger.info("adapter %s confirmed loaded on sglang", adapter_name)
 441: 
 442:     target_total = args.turn_count
 443:     tick = completed
 444:     started_at = time.monotonic()
 445:     skip_until_resume = completed > 0
 446: 
 447:     for cycle_idx in range(resume_cycle if completed > 0 else 0, args.cycle_count):
 448:         for stim_idx, stimulus in enumerate(sliced):
 449:             if completed >= target_total:
 450:                 break
 451:             stim_id = str(stimulus.get("stimulus_id", f"unknown_{stim_idx}"))
 452:             if skip_until_resume:
 453:                 if cycle_idx == resume_cycle and stim_id == resume_stim:
 454:                     skip_until_resume = False
 455:                     continue
 456:                 if cycle_idx == resume_cycle and stim_id != resume_stim:
 457:                     continue
 458:                 # cycle past resume → resume done
 459:                 skip_until_resume = False
 460:             user_prompt = _build_user_prompt(stimulus, cycle_idx)
 461:             zone = str(stimulus.get("expected_zone", ""))
 462:             dialog_id = f"{run_id}:c{cycle_idx}:{stim_id}"
 463:             seed = (seed_root ^ (cycle_idx << 16) ^ hash(stim_id)) & 0xFFFFFFFF
 464:             try:
 465:                 resp = _sglang_chat(
 466:                     host=args.sglang_host,
 467:                     model_name=adapter_name,
 468:                     system_prompt=system_prompt,
 469:                     user_prompt=user_prompt,
 470:                     temperature=args.temperature,
 471:                     seed=int(seed),
 472:                     timeout_s=args.timeout_s,
 473:                 )
 474:             except RuntimeError:
 475:                 logger.exception(
 476:                     "fatal sglang failure at cycle=%d stim=%s — checkpointing",
 477:                     cycle_idx,
 478:                     stim_id,
 479:                 )
 480:                 _flush_state(con, cycle_idx, stim_id, completed)
 481:                 con.execute("CHECKPOINT")
 482:                 con.close()
 483:                 return 3
 484:             _insert_focal_turn(
 485:                 con,
 486:                 run_id=run_id,
 487:                 persona_id=persona_id,
 488:                 dialog_id=dialog_id,
 489:                 tick=tick,
 490:                 utterance=resp.text,
 491:                 zone=zone,
 492:             )
 493:             completed += 1
 494:             tick += 1
 495:             if completed % _CHECKPOINT_FLUSH_EVERY == 0:
 496:                 _flush_state(con, cycle_idx, stim_id, completed)
 497:                 con.execute("CHECKPOINT")
 498:                 elapsed = time.monotonic() - started_at
 499:                 rate = completed / max(elapsed, 1e-3)
 500:                 eta_s = max(0.0, (target_total - completed) / max(rate, 1e-6))
 501:                 logger.info(
 502:                     "checkpoint persona=%s rank=%d run=%d completed=%d/%d"
 503:                     " rate=%.2f turn/s eta=%.1f min",
 504:                     persona_id,
 505:                     rank,
 506:                     run_idx,
 507:                     completed,
 508:                     target_total,
 509:                     rate,
 510:                     eta_s / 60.0,
 511:                 )
 512:         if completed >= target_total:
 513:             break
 514: 
 515:     _flush_state(con, args.cycle_count, "complete", completed)
 516:     con.execute("CHECKPOINT")
 517:     con.close()
 518:     elapsed = time.monotonic() - started_at
 519:     logger.info(
 520:         "pilot done persona=%s rank=%d run=%d completed=%d elapsed=%.1f min"
 521:         " output=%s",
 522:         persona_id,
 523:         rank,
 524:         run_idx,
 525:         completed,
 526:         elapsed / 60.0,
 527:         args.output,
 528:     )
 529:     return 0
 530: 
 531: 
 532: def _build_arg_parser() -> argparse.ArgumentParser:
 533:     p = argparse.ArgumentParser(
 534:         prog="m9-c-adopt-tier-b-pilot",
 535:         description=(
 536:             "Per-rank Tier B pilot采取 against SGLang with LoRA adapter routing."
 537:             " Outputs raw_dialog with epoch_phase=evaluation; per-25-turn"
 538:             " checkpoint resume."
 539:         ),
 540:     )
 541:     p.add_argument("--persona", required=True, choices=("kant", "nietzsche", "rikyu"))
 542:     p.add_argument("--rank", required=True, type=int, choices=(4, 8, 16, 32))
 543:     p.add_argument("--run-idx", required=True, type=int)
 544:     p.add_argument("--turn-count", type=int, default=_DEFAULT_TURN_COUNT)
 545:     p.add_argument("--cycle-count", type=int, default=_DEFAULT_CYCLE_COUNT)
 546:     p.add_argument("--temperature", type=float, default=0.6)
 547:     p.add_argument("--sglang-host", default=_DEFAULT_SGLANG_HOST)
 548:     p.add_argument("--timeout-s", type=float, default=_DEFAULT_TIMEOUT_S)
 549:     p.add_argument("--adapter-name", default=None)
 550:     p.add_argument("--skip-adapter-check", action="store_true")
 551:     p.add_argument(
 552:         "--stimulus-dir",
 553:         type=Path,
 554:         default=_DEFAULT_STIMULUS_DIR,
 555:     )
 556:     p.add_argument(
 557:         "--personas-dir",
 558:         type=Path,
 559:         default=_DEFAULT_PERSONAS_DIR,
 560:     )
 561:     p.add_argument("--output", required=True, type=Path)
 562:     p.add_argument(
 563:         "--log-level",
 564:         default="info",
 565:         choices=("debug", "info", "warning", "error"),
 566:     )
 567:     return p
 568: 
 569: 
 570: def main(argv: list[str] | None = None) -> int:
 571:     args = _build_arg_parser().parse_args(argv)
 572:     logging.basicConfig(
 573:         level=args.log_level.upper(),
 574:         format="%(asctime)s [%(name)s] %(levelname)s: %(message)s",
 575:         force=True,
 576:     )
 577:     return run_pilot(args)
 578: 
 579: 
 580: if __name__ == "__main__":
 581:     sys.exit(main())

