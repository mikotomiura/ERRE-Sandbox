  54: def test_stratified_slice_preserves_category_proportions() -> None:
  55:     """Slice should keep the same per-category share as the full battery."""
  56:     battery = load_stimulus_battery("kant")
  57:     full_focal = sum(_focal_turn_count(s) for s in battery)
  58:     target = full_focal // 2
  59:     sliced = _stratified_stimulus_slice(battery, target_focal_per_cycle=target)
  60: 
  61:     def by_cat(items: list[dict[str, Any]]) -> dict[str, int]:
  62:         out: dict[str, int] = {}
  63:         for stim in items:
  64:             cat = str(stim.get("category", ""))
  65:             out[cat] = out.get(cat, 0) + _focal_turn_count(stim)
  66:         return out
  67: 
  68:     full_share = by_cat(battery)
  69:     sliced_share = by_cat(sliced)
  70:     # Each category must appear in the slice (proportional ≠ all-or-nothing)
  71:     # which is the Codex HIGH-1 contract — naive YAML-prefix slicing would
  72:     # drop roleeval / moral_dilemma entirely.
  73:     for cat, count in full_share.items():
  74:         assert count > 0
  75:         assert sliced_share.get(cat, 0) > 0, (
  76:             f"category {cat} disappeared from stratified slice"
  77:         )
  78:     sliced_focal = sum(_focal_turn_count(s) for s in sliced)
  79:     # Allow ±15% relative drift from rounded category shares.
  80:     assert abs(sliced_focal - target) <= max(2, target * 15 // 100)
  81: 
  82: 
  83: def test_stratified_slice_returns_full_battery_when_target_exceeds_capacity() -> None:
  84:     battery = load_stimulus_battery("kant")
  85:     full_focal = sum(_focal_turn_count(s) for s in battery)
  86:     sliced = _stratified_stimulus_slice(battery, target_focal_per_cycle=full_focal * 2)
  87:     assert len(sliced) == len(battery)
  88: 
  89: 
  90: def test_stratified_slice_zero_target_returns_empty() -> None:
  91:     sliced = _stratified_stimulus_slice(
  92:         load_stimulus_battery("kant"), target_focal_per_cycle=0
  93:     )
  94:     assert sliced == []
