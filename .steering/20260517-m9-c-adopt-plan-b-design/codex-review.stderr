 784: def _group_aware_stratified_split(
 785:     weighted_examples_by_shard: dict[str, list[dict[str, object]]],
 786:     *,
 787:     eval_split_fraction: float,
 788:     seed: int,
 789:     stratify_by_language: bool = False,
 790: ) -> tuple[set[tuple[str, str]], set[tuple[str, str]]]:
 791:     """Stratified random split of dialog groups (Codex HIGH-A #1 + MEDIUM-2).
 792: 
 793:     Splits ``(source_shard, dialog_id)`` group keys into train and eval
 794:     sets, stratified by ``source_shard_type`` ("natural" / "stimulus") so
 795:     the eval split keeps the natural-vs-stimulus ratio of the corpus.
 796: 
 797:     When ``stratify_by_language=True`` (Plan B, design.md ﾂｧ1.6) the
 798:     stratum key is extended to ``(source_shard_type, language)`` so each
 799:     language slice keeps its train/eval ratio independently. This is the
 800:     safe-by-design eval contamination control for the de-monolog
 801:     re-cast injection 窶・without it, a rare ``de`` class can collapse
 802:     into either train or eval by chance, distorting eval_loss as a
 803:     Plan B-relevant signal.
 804: 
 805:     For multi-row dialogs whose rows disagree on ``language`` (e.g. mixed
 806:     de/en within one dialog), the stratum is determined by the first row
 807:     seen for that group key 窶・deterministic for a given iteration order.
 808:     """
 809:     import numpy as np  # noqa: PLC0415
 810: 
 811:     rng = np.random.default_rng(seed)
 812:     by_stratum: dict[str, list[tuple[str, str]]] = {}
 813:     for shard_basename, examples in weighted_examples_by_shard.items():
 814:         seen: set[tuple[str, str]] = set()
 815:         for ex in examples:
 816:             metadata = ex["weight_metadata"]
 817:             assert isinstance(metadata, dict)
 818:             shard_type_part = str(metadata["source_shard_type"])
 819:             if stratify_by_language:
 820:                 lang_part = str(metadata.get("language", "mixed"))
 821:                 stratum = f"{shard_type_part}|{lang_part}"
 822:             else:
 823:                 stratum = shard_type_part
 824:             group_key = (shard_basename, str(metadata["dialog_id"]))
 825:             if group_key in seen:
 826:                 continue
 827:             seen.add(group_key)
 828:             by_stratum.setdefault(stratum, []).append(group_key)
 829: 
 830:     train_keys: set[tuple[str, str]] = set()
 831:     eval_keys: set[tuple[str, str]] = set()
 832:     for stratum, keys in by_stratum.items():
 833:         keys_arr = np.array(keys, dtype=object)
 834:         if len(keys_arr) == 0:
 835:             continue
 836:         rng.shuffle(keys_arr)
 837:         n_eval = max(1, round(eval_split_fraction * len(keys_arr)))
 838:         # Ensure at least one train key remains
 839:         n_eval = min(n_eval, len(keys_arr) - 1) if len(keys_arr) > 1 else 0
 840:         for i, k in enumerate(keys_arr):
 841:             tup_raw = k.tolist() if hasattr(k, "tolist") else list(k)
 842:             tup: tuple[str, str] = (str(tup_raw[0]), str(tup_raw[1]))
 843:             if i < n_eval:
 844:                 eval_keys.add(tup)
 845:             else:
 846:                 train_keys.add(tup)
 847:         _LOGGER.info(
 848:             "split stratum=%s n_train=%d n_eval=%d",
 849:             stratum,
 850:             len(keys_arr) - n_eval,

