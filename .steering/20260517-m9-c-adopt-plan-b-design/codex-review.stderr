  59:     assert result["thresholds"]["de_en_mass_min"] == 0.60
  60:     assert result["thresholds"]["de_mass_min"] == 0.30
  61:     assert result["achieved"]["n_eff"] == 1800.0
  62:     assert result["achieved"]["de_en_mass"] == pytest.approx(0.65)
  63:     assert result["achieved"]["de_mass"] == pytest.approx(0.35)
  64:     assert result["merge_sha"] == "abc123"
  65:     assert result["weight_audit_path"] == "path/to/weight-audit.json"
  66:     assert result["schema_version"] == 1
