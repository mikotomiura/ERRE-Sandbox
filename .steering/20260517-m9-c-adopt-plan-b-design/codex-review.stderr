.steering/20260517-m9-c-adopt-plan-b-design\d2-encoder-allowlist-plan-b.json:27:      "kernel_note": "Character 5-gram cosine similarity (Burrows-adjacent shallow stylometry)。retrieval-trained でない independent 軸として encoder diversity を確保。"
.steering/20260517-m9-c-adopt-plan-b-design\d2-encoder-allowlist-plan-b.json:33:      "exclusion_reason": "Plan A natural d sign flip (+0.23 vs MPNet/E5 negative)。retrieval-trained encoder の disagreement を ADOPT 不寄与化する (BGE-M3 sign flip 教訓の generalisation)。報告は obligatory。"
.steering/20260517-m9-c-adopt-plan-b-design\d2-encoder-allowlist-plan-b.json:36:  "encoder_agreement_axis": {
.steering/20260517-m9-c-adopt-plan-b-design\d2-encoder-allowlist-plan-b.json:40:    "gate_conditions_per_encoder": [
