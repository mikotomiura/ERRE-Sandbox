 141: # ---------------------------------------------------------------------------
 142: # Persona prompt builder
 143: # ---------------------------------------------------------------------------
 144: 
 145: 
 146: def test_build_de_monolog_system_prompt_contains_de_directive(collector_module):
 147:     """System prompt must include the German + monolog + Critique directive."""
 148:     persona = {
 149:         "display_name": "Immanuel Kant",
 150:         "era": "Aufklﾃ､rung (1724-1804)",
 151:         "cognitive_habits": [
 152:             {"description": "transcendental analysis", "flag": "T"},
 153:         ],
 154:     }
 155:     prompt = collector_module.build_de_monolog_system_prompt(persona)
 156:     # Persona block byte-identical to baseline
 157:     assert "Immanuel Kant" in prompt
 158:     assert "Aufklﾃ､rung (1724-1804)" in prompt
 159:     assert "transcendental analysis" in prompt
 160:     # De-monolog directive present
 161:     assert "**German**" in prompt
 162:     assert "80窶・60 German words" in prompt
 163:     assert "Critique-of-Pure-Reason" in prompt
 164:     assert "Do not address an interlocutor" in prompt
 165: 
 166: 
 167: # ---------------------------------------------------------------------------
 168: # Post-hoc filter (4-axis hard gate)
 169: # ---------------------------------------------------------------------------
 170: 
 171: # A long German monolog with Kantian markers + diacritics + function words.
 172: # Markers per 100 tokens >= 1.0 expected. Has no trigram loops.
 173: _VALID_DE_MONOLOG = (
 174:     "Ich denke das transzendentale Subjekt als die formale Bedingung aller"
 175:     " mﾃｶglichen Erfahrung. Es ist nicht ein Ding an sich, sondern eine"
 176:     " a priori Voraussetzung der Synthese. Der kategorische Imperativ"
 177:     " entspringt aus dieser reinen Vernunft, nicht aus der Sinnlichkeit."
 178:     " Meiner Ansicht nach ist die Pflicht die einzige Quelle der"
 179:     " moralischen Wﾃｼrde, und meine theoretische Vernunft erkennt die"
 180:     " Grenzen ihrer eigenen Anwendung an. Die Erscheinung ist nicht das"
 181:     " Noumenon; das An-sich bleibt verborgen."
 182: )
 183: 
 184: 
 185: def test_filter_accepts_valid_de_monolog(collector_module):
 186:     """A well-formed long German Kant monolog passes all four gates."""
 187:     result = collector_module.filter_de_monolog(_VALID_DE_MONOLOG)
 188:     assert result.accepted is True
 189:     assert result.reason is None
 190:     assert result.language == "de"
 191:     assert result.token_count >= 60
 192:     assert result.marker_density >= 1.0
 193: 
 194: 
 195: def test_filter_rejects_english(collector_module):
 196:     """English text fails the language gate."""
 197:     text = (
 198:         "I think the transcendental subject is the formal condition of all"
 199:         " possible experience, and the categorical imperative arises from"
 200:         " pure reason rather than sensibility, which is the proper claim."
 201:     )
 202:     result = collector_module.filter_de_monolog(text)
 203:     assert result.accepted is False
 204:     assert result.reason == "lang"
 205: 
 206: 
 207: def test_filter_rejects_short_monolog(collector_module):
 208:     """A short German utterance fails the length gate."""
 209:     text = "Ich denke also bin ich, und das ist alles."  # < 60 tokens
 210:     result = collector_module.filter_de_monolog(text)
 211:     assert result.accepted is False
 212:     assert result.reason in {"length", "marker"}  # depends on density
 213: 
 214: 
 215: def test_filter_rejects_low_marker_density(collector_module):
 216:     """A long German text with no Kant markers fails the density gate."""
 217:     # Long German sentence about weather; no transcendental / a priori / etc.
 218:     text = (
 219:         "Heute scheint die Sonne ﾃｼber dem Garten und der Wind weht sanft"
 220:         " durch die Bﾃ､ume. Die Wolken ziehen langsam nach Westen, und ein"
 221:         " Vogel singt auf dem Ast. Es ist ein angenehmer Nachmittag in"
 222:         " diesem Frﾃｼhling, und die Luft riecht nach frisch gemﾃ､htem Gras"
 223:         " und nach den ersten Blumen des Jahres in voller Blﾃｼte. So"
 224:         " bewundert man den Lauf der Natur und betrachtet ihn."
 225:     )
 226:     result = collector_module.filter_de_monolog(text, min_marker_density=1.0)
 227:     assert result.accepted is False
 228:     assert result.reason == "marker"
 229: 
 230: 
 231: def test_filter_rejects_trigram_loop(collector_module):
 232:     """Repetitive output (trigram count > threshold) fails the loop detector."""
 233:     # Same trigram "die reine vernunft" appears 6 times; ample German function
 234:     # words and Kantian markers so language + length + density gates pass and
 235:     # the trigram-loop axis is the only failing one.
 236:     text = (
 237:         "Die reine Vernunft die reine Vernunft die reine Vernunft die reine"
 238:         " Vernunft die reine Vernunft die reine Vernunft ist transzendental"
 239:         " a priori kategorischer Imperativ meine Pflicht meine Ansicht nach"
 240:         " das Ding an sich Erscheinung Noumenon synthetisch und Sinnlichkeit"
 241:         " in der reinen Vernunft. Ich denke also bin ich auf dem Boden der"
 242:         " praktischen Vernunft, mit transzendental synthetisch a priori"
 243:         " Pflicht. Die reine Erkenntnis ist transzendental in dem an sich."
 244:     )
 245:     result = collector_module.filter_de_monolog(text, trigram_loop_max=4)
 246:     assert result.accepted is False
 247:     assert result.reason == "trigram"
 248:     assert result.trigram_max > 4
 249: 
 250: 
 251: def test_filter_short_circuits_on_empty(collector_module):
 252:     """Empty/whitespace input is rejected with reason='lang'."""
 253:     result = collector_module.filter_de_monolog("   \n  ")
 254:     assert result.accepted is False
 255:     assert result.reason == "lang"
 256: 
