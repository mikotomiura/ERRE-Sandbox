1237:     )
1238: 
1239:     if dry_run:
1240:         _LOGGER.info(
1241:             "train_kant_lora dry-run (weighted): gate cleared with %d examples,"
1242:             " %d synthetic monologs, %d eval rows; GPU stack not imported",
1243:             split.realised_examples,
1244:             split.synthetic_monolog_n,
1245:             len(split.eval_examples),
1246:         )
1247:         return summary
1248: 
1249:     _execute_training_run_weighted(
1250:         split=split,
1660:         remove_unused_columns=False,  # keep sample_weight column
1661:         **eval_kwargs,
1662:     )
1663: 
1664:     trainer = WeightedTrainer(
1665:         model=model,
1666:         args=training_args,
1667:         train_dataset=tokenized_train,
1668:         eval_dataset=tokenized_eval,
1669:         data_collator=_weighted_collator,
1670:     )
1671: 
1672:     if torch.cuda.is_available():
1673:         torch.cuda.reset_peak_memory_stats()
1674: 
1675:     train_result = trainer.train()
1676:     peak_vram = (
1677:         int(torch.cuda.max_memory_allocated()) if torch.cuda.is_available() else 0
1678:     )
1679:     train_loss = (
1680:         float(train_result.training_loss)
1681:         if train_result is not None and hasattr(train_result, "training_loss")
1682:         else None
1683:     )
1684: 
1685:     eval_loss: float | None = None
1686:     if tokenized_eval is not None:
1687:         try:
1688:             metrics = trainer.evaluate()
1689:         except (RuntimeError, ValueError) as exc:
1690:             _LOGGER.warning("final evaluate() failed: %s", exc)
1691:             metrics = {}
1692:         eval_loss = float(metrics["eval_loss"]) if "eval_loss" in metrics else None
1693: 
1694:     trainer.model.save_pretrained(str(output_dir_path))
1695:     tokenizer.save_pretrained(str(output_dir_path))
1696:     return peak_vram, train_loss, eval_loss
1697: 
1698: 
1699: def _execute_training_run_weighted(
1700:     *,
1701:     split: WeightedSplitResult,
1702:     output_dir_path: Path,
1703:     summary: TrainRunSummary,
1704:     base_model: str,
1705:     lora_rank: int,
1706:     quantization: Quantization,
1707:     batch_size: int,
1708:     gradient_accumulation_steps: int,
1709:     max_seq_length: int,
1710:     max_steps: int,
1711:     learning_rate: float,
1712:     save_steps: int,
1713:     target_modules: Sequence[str],
1714:     seed: int,
1715: ) -> None:
1716:     """Run the full GPU-side weighted pipeline and update ``summary`` in place."""
1717:     tokenizer, model = _load_quantised_model(base_model, quantization)
1718:     model = _apply_lora(
1719:         model,
1720:         lora_rank=lora_rank,
1721:         quantization=quantization,
1722:         target_modules=target_modules,
1723:     )
1724: 
1725:     peak_vram, train_loss, eval_loss = _run_trainer_weighted(
1726:         model=model,
1727:         tokenizer=tokenizer,
1728:         train_examples=split.train_examples,
1729:         eval_examples=split.eval_examples,
1730:         output_dir_path=output_dir_path,
1731:         quantization=quantization,
1732:         batch_size=batch_size,
1733:         gradient_accumulation_steps=gradient_accumulation_steps,
1734:         max_seq_length=max_seq_length,
1735:         max_steps=max_steps,
1736:         learning_rate=learning_rate,
1737:         save_steps=save_steps,
1738:         seed=seed,
1739:     )
1740: 
1741:     summary.training_executed = True
1742:     summary.peak_vram_bytes = peak_vram
1743:     summary.train_loss = train_loss
1744:     summary.eval_loss = eval_loss
1745: 
1746:     metadata_path = output_dir_path / "train_metadata.json"
1747:     metadata_path.write_text(
1748:         json.dumps(summary.to_dict(), indent=2, sort_keys=True) + "\n",
1749:         encoding="utf-8",
1750:     )
1751: 
1752:     _LOGGER.info(
1753:         "train_kant_lora (weighted) completed: persona=%s rank=%d quant=%s"
1754:         " realised=%d synthetic_n=%d peak_vram=%.2fGB train_loss=%s"
1755:         " eval_loss=%s output=%s",
1756:         summary.persona_id,
1757:         lora_rank,
1758:         quantization,
1759:         summary.realised_examples,
1760:         summary.synthetic_monolog_n,
1880:         dest="min_examples",
1881:         type=int,
1882:         default=DEFAULT_MIN_EXAMPLES,
1883:         help=f"CS-3 gate threshold (default: {DEFAULT_MIN_EXAMPLES})",
1884:     )
1885:     parser.add_argument(
1886:         "--seed",
1887:         dest="seed",
1888:         type=int,
1889:         default=42,
1890:         help="Reproducibility seed",
1891:     )
1892:     parser.add_argument(
1893:         "--dry-run",
1894:         dest="dry_run",
1895:         action="store_true",
1896:         help=(
1897:             "Run the gate only, then exit. No GPU stack import, no files"
1898:             " written to output_dir. Useful for B-1/B-2 trigger verification."
1899:             " When combined with --weighted, the pre-training audit is still"
1900:             " emitted to output_dir/weight-audit.json so the fallback trigger"
1901:             " can be evaluated before the 3-5h training kickoff."
1902:         ),
1903:     )
1904:     parser.add_argument(
1905:         "--weighted",
1906:         dest="weighted",
1907:         action="store_true",
1908:         help=(
1909:             "Enable the DA-14 retrain v2 signal-driven path: per-example"
1910:             " sample weights, group-aware 90/10 stratified split, monolog"
1911:             " re-cast from training-side natural shards, and a pre-training"
1912:             " audit. Falls back via exit code 6 (N_eff < 1000) or 7"
1913:             " (top-5%% weight share >= 50%%) -- escalate to Candidate C."
1914:         ),
1915:     )
1916:     parser.add_argument(
1917:         "--no-real-tokenizer-for-weights",
1918:         dest="no_real_tokenizer_for_weights",
1919:         action="store_true",
1920:         help=(
1921:             "Use the whitespace ﾃ・1.3 token-count proxy instead of Qwen3-8B"
1922:             " for weight metadata. Faster and deterministic for tests, but"
1923:             " production runs should NOT pass this (Codex MEDIUM-1 caveat)."
1924:         ),
1925:     )
1926:     parser.add_argument(
1927:         "-v",
1928:         "--verbose",
1929:         dest="verbose",
1930:         action="store_true",
1931:         help="Enable INFO-level logging on stderr",
1932:     )
1933:     return parser
1934: 
1935: 
1936: def _resolve_paths(
1937:     duckdb_glob: str | None,
1938:     db_path: list[Path] | None,
1939: ) -> list[Path]:
1940:     if db_path:
1941:         return sorted(db_path)
1942:     if duckdb_glob is None:  # pragma: no cover 窶・argparse exclusive group prevents this
1943:         raise FileNotFoundError(
1944:             "train_kant_lora: neither --duckdb-glob nor --db-path supplied",
1945:         )
1946:     # ``Path.glob`` would require splitting the pattern from its anchor
1947:     # which conflates ``data/eval/golden/kant_*.duckdb`` (anchored, common
1948:     # case here) with ``**/kant_*.duckdb`` (unanchored); ``_glob.glob``
1949:     # is the unambiguous tool for the CLI surface.
1950:     matches = sorted(Path(p) for p in _glob.glob(duckdb_glob, recursive=True))  # noqa: PTH207
1951:     if not matches:
1952:         raise FileNotFoundError(
1953:             f"train_kant_lora: --duckdb-glob {duckdb_glob!r} matched no files",
1954:         )
1955:     return matches
1956: 
1957: 
1958: def main(argv: Sequence[str] | None = None) -> int:  # noqa: PLR0911 窶・distinct exit-code paths
1959:     """Argparse-driven CLI entry point. Returns a POSIX exit code.
1960: 
1961:     The default exit codes follow ``decisions.md`` CS-3 / DA-14 窶・each
1962:     gate error has a distinct rc so wrapping shell scripts can branch:
1963: 
1964:     * 0 窶・success (training run completed or dry-run gate cleared)
1965:     * 2 窶・:class:`EvaluationContaminationError`
1966:     * 3 窶・:class:`BlockerNotResolvedError`
1967:     * 4 窶・:class:`InsufficientTrainingDataError`
1968:     * 5 窶・other ``ValueError`` / ``FileNotFoundError`` (operator error)
1969:     * 6 窶・:class:`InsufficientEffectiveSampleSizeError` (DA-14 fallback)
1970:     * 7 窶・:class:`WeightConcentrationError` (DA-14 fallback)
1971:     * 1 窶・unexpected exception (re-raised to surface stack trace)
1972:     """
1973:     parser = _build_arg_parser()
1974:     args = parser.parse_args(argv)
1975: 
1976:     logging.basicConfig(
1977:         level=logging.INFO if args.verbose else logging.WARNING,
1978:         format="%(asctime)s %(levelname)s %(name)s %(message)s",
1979:         stream=sys.stderr,
1980:     )
1981: 
1982:     try:
1983:         db_paths = _resolve_paths(args.duckdb_glob, args.db_path)
1984:         summary = train_kant_lora(
1985:             db_paths,
1986:             args.output_dir,
1987:             base_model=args.base_model,
1988:             persona_id=args.persona,
1989:             lora_rank=args.rank,
1990:             quantization=args.quantization,
1991:             batch_size=args.batch_size,
1992:             gradient_accumulation_steps=args.gradient_accumulation,
1993:             max_seq_length=args.max_seq_length,
1994:             max_steps=args.max_steps,
1995:             learning_rate=args.learning_rate,
1996:             save_steps=args.save_steps,
1997:             min_examples=args.min_examples,
1998:             seed=args.seed,
1999:             dry_run=args.dry_run,
2000:             weighted=args.weighted,
2001:             use_real_tokenizer_for_weights=not args.no_real_tokenizer_for_weights,
2002:         )
2003:     except EvaluationContaminationError as exc:
2004:         _LOGGER.error("contamination: %s", exc)  # noqa: TRY400  # rc mapping
2005:         return 2
2006:     except BlockerNotResolvedError as exc:
2007:         _LOGGER.error("blocker not resolved: %s", exc)  # noqa: TRY400  # rc mapping
2008:         return 3
2009:     except InsufficientTrainingDataError as exc:
2010:         _LOGGER.error("insufficient data: %s", exc)  # noqa: TRY400  # rc mapping
2011:         return 4
2012:     except InsufficientEffectiveSampleSizeError as exc:
2013:         _LOGGER.error("audit N_eff fallback: %s", exc)  # noqa: TRY400
2014:         return 6
2015:     except WeightConcentrationError as exc:
2016:         _LOGGER.error("audit top-5%% fallback: %s", exc)  # noqa: TRY400
2017:         return 7
2018:     except (ValueError, FileNotFoundError) as exc:
2019:         _LOGGER.error("operator error: %s", exc)  # noqa: TRY400  # rc mapping
2020:         return 5

