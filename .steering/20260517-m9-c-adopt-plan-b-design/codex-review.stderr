 100:     re.compile(p, re.IGNORECASE) for p in GERMAN_FIRST_PERSON_MARKERS
 101: ]
 102: KANTIAN_PATTERNS: Final[list[re.Pattern[str]]] = [
 103:     re.compile(p, re.IGNORECASE) for p in KANTIAN_PHILOSOPHY_MARKERS
 104: ]
