 685:     p = argparse.ArgumentParser(
 686:         prog="m9-c-adopt-de-focused-monolog-collector",
 687:         description=(
 688:             "Plan B (Candidate C hybrid retrain) driver: collect de-focused"
 689:             " single-turn monolog examples from SGLang base model with"
