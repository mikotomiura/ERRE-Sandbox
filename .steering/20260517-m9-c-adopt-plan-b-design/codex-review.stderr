 691:             " >=1.0 / no trigram loop)."
 692:         ),
 693:     )
 694:     p.add_argument("--persona", required=True, choices=("kant",))
 695:     p.add_argument("--run-idx", type=int, default=0)
 696:     p.add_argument("--target-net", type=int, default=_DEFAULT_TARGET_NET)
 697:     p.add_argument("--max-attempts", type=int, default=_DEFAULT_MAX_ATTEMPTS)
 698:     p.add_argument("--temperature", type=float, default=_DEFAULT_TEMPERATURE)
 699:     p.add_argument(
 700:         "--frequency-penalty", type=float, default=_DEFAULT_FREQ_PENALTY
 701:     )
 702:     p.add_argument(
 703:         "--presence-penalty", type=float, default=_DEFAULT_PRESENCE_PENALTY
 704:     )
 705:     p.add_argument("--max-tokens", type=int, default=_DEFAULT_MAX_TOKENS)
 706:     p.add_argument(
