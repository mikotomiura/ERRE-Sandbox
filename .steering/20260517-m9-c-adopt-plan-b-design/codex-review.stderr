 succeeded in 275ms:
   1: """Unit tests for ``stratify_by_language`` on ``_group_aware_stratified_split``.
   2: 
   3: The split helper lives in :mod:`erre_sandbox.training.train_kant_lora` (see
   4: ``.steering/20260517-m9-c-adopt-plan-b-design/decisions.md`` DI-5 for why the
   5: public-facing wording calls this ``dataset.py extension``). When the new
   6: ``stratify_by_language`` kw-only flag is on, each ``(source_shard_type,
   7: language)`` cell receives its own 90/10 random split, which is the
   8: contamination control for the Plan B de-monolog re-cast (design.md ﾂｧ1.6).
   9: """
  10: 
  11: from __future__ import annotations
  12: 
  13: import pytest
  14: 
  15: from erre_sandbox.training.train_kant_lora import _group_aware_stratified_split
  16: 
  17: 
  18: def _make_example(
  19:     *,
  20:     shard: str,
  21:     dialog_id: str,
  22:     language: str,
  23:     shard_type: str,
  24: ) -> dict[str, object]:
  25:     return {
  26:         "text": f"placeholder-{shard}-{dialog_id}",
  27:         "weight_metadata": {
  28:             "language": language,
  29:             "token_count": 80,
  30:             "has_addressee": False,
  31:             "marker_density_per_100_tokens": 1.2,
  32:             "source_shard": shard,
  33:             "source_shard_type": shard_type,
  34:             "dialog_id": dialog_id,
  35:             "turn_index": 0,
  36:         },
  37:     }
  38: 
  39: 
  40: def _build_balanced_corpus() -> dict[str, list[dict[str, object]]]:
  41:     """20 dialogs across (natural|stimulus) ﾃ・(de|en|ja|mixed) = 8 cells, 2-3 each.
  42: 
  43:     The cell sizes are intentionally small so that with default
  44:     ``eval_split_fraction=0.10`` each cell gets exactly 1 eval and 1-2
  45:     train keys, making the stratification effect observable.
  46:     """
  47:     examples_by_shard: dict[str, list[dict[str, object]]] = {}
  48:     cells = [
  49:         ("natural", "de", 3),
  50:         ("natural", "en", 3),
  51:         ("natural", "ja", 3),
  52:         ("natural", "mixed", 2),
  53:         ("stimulus", "de", 3),
  54:         ("stimulus", "en", 3),
  55:         ("stimulus", "ja", 3),
  56:         ("stimulus", "mixed", 2),
  57:     ]
  58:     counter = 0
  59:     for shard_type, lang, n in cells:
  60:         for _ in range(n):
  61:             counter += 1
  62:             shard = f"kant_{shard_type}_run0.duckdb"
  63:             dialog_id = f"{shard_type}_{lang}_d{counter}"
  64:             ex = _make_example(
  65:                 shard=shard, dialog_id=dialog_id, language=lang, shard_type=shard_type
  66:             )
  67:             examples_by_shard.setdefault(shard, []).append(ex)
  68:     return examples_by_shard
  69: 
  70: 
  71: def test_default_behavior_is_byte_identical_when_flag_off() -> None:
  72:     """``stratify_by_language=False`` (default) preserves existing behavior."""
  73:     corpus = _build_balanced_corpus()
  74:     train_a, eval_a = _group_aware_stratified_split(
  75:         corpus, eval_split_fraction=0.10, seed=42
  76:     )
  77:     train_b, eval_b = _group_aware_stratified_split(
  78:         corpus, eval_split_fraction=0.10, seed=42, stratify_by_language=False
  79:     )
  80:     assert train_a == train_b
  81:     assert eval_a == eval_b
  82: 
  83: 
  84: def test_stratify_by_language_separates_each_language_cell() -> None:
  85:     """With the flag on, every (shard_type, language) cell sees its own split."""
  86:     corpus = _build_balanced_corpus()
  87:     train_keys, eval_keys = _group_aware_stratified_split(
  88:         corpus, eval_split_fraction=0.10, seed=42, stratify_by_language=True
  89:     )
  90:     # Each cell has 2-3 keys; eval_split_fraction=0.10 竊・round(0.1*n) = 0 for
  91:     # n<=4, but the function enforces "at least 1 eval if n > 1" via
  92:     # ``max(1, round(...))`` AND ``min(n_eval, n-1)``. So 2-key cells get
  93:     # 1 eval, 3-key cells get 1 eval. Total eval count = 8 cells ﾃ・1 = 8.
  94:     assert len(eval_keys) == 8
  95:     # No overlap between train and eval
  96:     assert train_keys.isdisjoint(eval_keys)
  97: 
  98: 
  99: def test_stratify_by_language_round_trip_metadata() -> None:
 100:     """Eval keys span every (shard_type, language) stratum that has >=2 keys."""
 101:     corpus = _build_balanced_corpus()
 102:     _, eval_keys = _group_aware_stratified_split(
 103:         corpus, eval_split_fraction=0.10, seed=42, stratify_by_language=True
 104:     )
 105:     # Build a quick lookup from group_key 竊・(shard_type, language)
 106:     key_to_stratum: dict[tuple[str, str], tuple[str, str]] = {}
 107:     for shard, exs in corpus.items():
 108:         for ex in exs:
 109:             meta = ex["weight_metadata"]
 110:             assert isinstance(meta, dict)
 111:             key = (shard, str(meta["dialog_id"]))
 112:             key_to_stratum[key] = (
 113:                 str(meta["source_shard_type"]),
 114:                 str(meta["language"]),
 115:             )
 116:     eval_strata = {key_to_stratum[k] for k in eval_keys}
 117:     # All 8 cells (natural|stimulus ﾃ・de|en|ja|mixed) should appear in eval.
 118:     assert eval_strata == {
 119:         ("natural", "de"),
 120:         ("natural", "en"),
 121:         ("natural", "ja"),
 122:         ("natural", "mixed"),
 123:         ("stimulus", "de"),
 124:         ("stimulus", "en"),
 125:         ("stimulus", "ja"),
 126:         ("stimulus", "mixed"),
 127:     }
 128: 
 129: 
 130: def test_deterministic_for_fixed_seed() -> None:
 131:     """Same seed + same flag produce identical splits across invocations."""
 132:     corpus = _build_balanced_corpus()
 133:     train_1, eval_1 = _group_aware_stratified_split(
 134:         corpus, eval_split_fraction=0.10, seed=42, stratify_by_language=True
 135:     )
 136:     train_2, eval_2 = _group_aware_stratified_split(
 137:         corpus, eval_split_fraction=0.10, seed=42, stratify_by_language=True
 138:     )
 139:     assert train_1 == train_2
 140:     assert eval_1 == eval_2
 141: 
 142: 
 143: def test_seed_sensitivity_distinguishes_strata() -> None:
 144:     """Different seeds yield different splits while preserving stratum counts."""
 145:     corpus = _build_balanced_corpus()
 146:     _, eval_42 = _group_aware_stratified_split(
 147:         corpus, eval_split_fraction=0.10, seed=42, stratify_by_language=True
 148:     )
 149:     _, eval_7 = _group_aware_stratified_split(
 150:         corpus, eval_split_fraction=0.10, seed=7, stratify_by_language=True
 151:     )
 152:     # Per-stratum eval counts are preserved (8 strata ﾃ・1 eval = 8)
 153:     assert len(eval_42) == 8
 154:     assert len(eval_7) == 8
 155:     # ...but the actual eval keys differ on at least some stratum
 156:     assert eval_42 != eval_7
 157: 
 158: 
 159: @pytest.mark.parametrize("shard_type", ["natural", "stimulus"])
 160: def test_unknown_language_falls_to_mixed_bucket(shard_type: str) -> None:
 161:     """Rows missing ``language`` fall back to ``"mixed"`` (default bucket)."""
 162:     examples_by_shard: dict[str, list[dict[str, object]]] = {}
 163:     shard = f"kant_{shard_type}_run0.duckdb"
 164:     for i in range(4):
 165:         ex = _make_example(
 166:             shard=shard,
 167:             dialog_id=f"d{i}",
 168:             language="mixed",
 169:             shard_type=shard_type,
 170:         )
 171:         examples_by_shard.setdefault(shard, []).append(ex)
 172:     train_keys, eval_keys = _group_aware_stratified_split(
 173:         examples_by_shard, eval_split_fraction=0.10, seed=42, stratify_by_language=True
 174:     )
 175:     assert len(train_keys) + len(eval_keys) == 4
 176:     assert train_keys.isdisjoint(eval_keys)

