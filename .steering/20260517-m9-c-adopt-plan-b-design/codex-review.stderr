 succeeded in 330ms:
   1: """Signal-driven per-example weighting for m9-c-adopt retrain v2 (DA-14 / DR-1).
   2: 
   3: This module is the **training-time** half of the retrain v2 spec
   4: (`.steering/20260514-m9-c-adopt-retrain-v2-design/design-final.md` ﾂｧ3.2/ﾂｧ3.3).
   5: It consumes a pre-computed per-example metadata dict (language / token_count /
   6: has_addressee / marker_density_per_100_tokens 窶・derived in
   7: :mod:`erre_sandbox.training.example_features`) and produces:
   8: 
   9: * per-example raw weights via :func:`compute_example_weight` (Codex HIGH-C
  10:   verbatim formula, clamped to ``[0.1, 3.0]``);
  11: * per-train-split normalised weights via :func:`normalise_weights_to_mean_one`
  12:   so effective LR is not silently shifted by the heuristic coefficient choice
  13:   (Codex HIGH-C #2);
  14: * a pre-training audit JSON via :func:`emit_weight_audit` that surfaces
  15:   per-language weighted mass, top-5% concentration, and N_eff 窶・the three
  16:   signals that drive the Candidate C fallback trigger (Codex HIGH-A #2).
  17: 
  18: Coefficient transparency (Codex HIGH-C #3): the 0.35 / 0.20 / 0.15 / 0.30
  19: coefficients are **heuristic** (sum-to-1 for interpretability), NOT
  20: empirically optimal. The closest prior art is static importance weighting /
  21: curriculum learning (Bengio 2009); focal loss is a loose analogy only because
  22: focal loss is model-confidence-dependent and dynamic. DAP / preference
  23: personalization is a different objective entirely.
  24: 
  25: No torch / transformers imports 窶・the gate-only path in
  26: :func:`erre_sandbox.training.train_kant_lora.train_kant_lora` and the
  27: pre-training audit step must remain installable without the ``[training]``
  28: extras.
  29: """
  30: 
  31: from __future__ import annotations
  32: 
  33: import json
  34: import statistics
  35: from typing import TYPE_CHECKING, Any, Final, cast
  36: 
  37: if TYPE_CHECKING:
  38:     from collections.abc import Sequence
  39:     from pathlib import Path
  40: 
  41: 
  42: _CE_IGNORE_INDEX: Final[int] = -100
  43: """HuggingFace causal-LM ignored-position sentinel; used in cross_entropy."""
  44: 
  45: _LEN_BUCKET_SHORT_MAX: Final[int] = 30
  46: _LEN_BUCKET_MID_MAX: Final[int] = 60
  47: _LEN_BUCKET_LONG_MAX: Final[int] = 120
  48: """Bucket upper bounds (exclusive) for the audit length histogram."""
  49: 
  50: 
  51: # ---------------------------------------------------------------------------
  52: # Constants (Codex HIGH-C verbatim spec)
  53: # ---------------------------------------------------------------------------
  54: 
  55: WEIGHT_CLAMP_MIN: Final[float] = 0.1
  56: """Lower bound on the raw per-example weight (Codex HIGH-C).
  57: 
  58: Structural defence against pathological zero-weight examples; the formula's
  59: practical minimum is roughly ``0.34`` for ja/short/dialog/zero-marker rows, so
  60: this clamp is rarely hit but guards against future coefficient retuning that
  61: could push raw values below the floor.
  62: """
  63: 
  64: WEIGHT_CLAMP_MAX: Final[float] = 3.0
  65: """Upper bound on the raw per-example weight (Codex HIGH-C).
  66: 
  67: Caps gradient variance: at ``rank=8`` with ``batch=1, grad_accum=8`` the
  68: weighted-sum reduction means a single example's contribution to the gradient
  69: scales linearly in its weight, so an uncapped raw of e.g. 7.5 (from a very
  70: high marker_density) would dominate the batch. The 3.0 cap together with
  71: mean=1.0 normalisation keeps the effective per-example ratio at ~10x rather
  72: than the formula's nominal ~30x (Codex HIGH-C LOW-2 reflection).
  73: """
  74: 
  75: _LANG_FACTORS: Final[dict[str, float]] = {
  76:     "de": 1.4,
  77:     "en": 1.0,
  78:     "mixed": 0.5,
  79:     "ja": 0.2,
  80: }
  81: """Per-language multiplicative factor in the raw-weight formula.
  82: 
  83: German is rewarded most aggressively (1.4x) because the Step 1 corpus
  84: analysis showed only 15.9% German share 窶・well below the Kant base rate ~16%
  85: that produces persona-discriminative signal. Mixed text gets 0.5x because the
  86: language classifier flags it when neither side dominates, signalling a
  87: diluted training example. Japanese is heavily down-weighted (0.2x) because
  88: the corpus is 56.7% ja-heavy and the trainer was previously dominated by
  89: non-discriminative ja conversation patterns.
  90: """
  91: 
  92: _LENGTH_THRESHOLDS: Final[tuple[tuple[int, float], ...]] = (
  93:     (30, 0.3),
  94:     (60, 0.8),
  95:     (120, 1.5),
  96: )
  97: """``(strict-upper-token-bound, factor)`` ladder for the length multiplier.
  98: 
  99: Rows with token_count >= the highest bound (120) get the saturated factor
 100: (2.0). Step 1 corpus analysis showed 69.0% of rows are <30 tokens 窶・the
 101: 0.3 multiplier on that majority is the primary lever for emphasising
 102: long-form Kant rhetoric.
 103: """
 104: _LENGTH_FACTOR_SATURATED: Final[float] = 2.0
 105: 
 106: _MONOLOG_BONUS: Final[float] = 1.5
 107: _DIALOG_BONUS: Final[float] = 1.0
 108: """Monolog (no addressee) is boosted because Step 1 found 0% monolog ratio.
 109: 
 110: Synthetic monolog re-cast in :func:`_collect_from_shards_weighted` brings
 111: this to ~5-7% of the train split; the bonus magnifies the per-example
 112: contribution so the trainer sees the long-form / self-addressed style as a
 113: distinct mode rather than a sampling outlier.
 114: """
 115: 
 116: _MARKER_FACTOR_FLOOR: Final[float] = 0.2
 117: _MARKER_DENSITY_DIVISOR: Final[float] = 2.0
 118: """``marker_factor = max(marker_density / 2.0, 0.2)`` 窶・see design-final ﾂｧ3.2.
 119: 
 120: The literature anchor (Cambridge Edition translator-aligned passages) is
 121: ~2.0 markers per 100 tokens, so dividing by 2.0 normalises the factor to
 122: ~1.0 at anchor density. The 0.2 floor prevents zero-marker rows from
 123: collapsing to weight 0 (the corpus median marker density is 0, so without
 124: the floor ~half the rows would contribute nothing).
 125: """
 126: 
 127: _COEFF_LANG: Final[float] = 0.35
 128: _COEFF_LENGTH: Final[float] = 0.20
 129: _COEFF_MONOLOG: Final[float] = 0.15
 130: _COEFF_MARKER: Final[float] = 0.30
 131: """Linear-combination coefficients (sum = 1.0).
 132: 
 133: Heuristic, NOT empirical (Codex HIGH-C #3). Language gets the largest share
 134: because the ja-heavy gap (C1 from corpus analysis) is the empirically
 135: largest of the four. Marker density second, length third, monolog bonus
 136: lowest because monolog re-cast is a synthetic injection rather than a
 137: property of the realised corpus.
 138: """
 139: 
 140: 
 141: # ---------------------------------------------------------------------------
 142: # compute_example_weight
 143: # ---------------------------------------------------------------------------
 144: 
 145: 
 146: def compute_example_weight(example_metadata: dict[str, object]) -> float:
 147:     """Compute the clamped raw weight for one training example (HIGH-C verbatim).
 148: 
 149:     Args:
 150:         example_metadata: Per-row metadata dict with keys
 151: 
 152:             * ``language`` (``"de"``/``"en"``/``"mixed"``/``"ja"``)
 153:             * ``token_count`` (int)
 154:             * ``has_addressee`` (bool)
 155:             * ``marker_density_per_100_tokens`` (float)
 156: 
 157:             Extra keys are ignored. Missing or mis-typed keys raise
 158:             ``KeyError`` / ``TypeError`` 窶・callers must materialise the
 159:             metadata before invoking this function (the
 160:             :func:`erre_sandbox.training.example_features.extract_example_metadata`
 161:             helper does this end-to-end).
 162: 
 163:     Returns:
 164:         A float in ``[WEIGHT_CLAMP_MIN, WEIGHT_CLAMP_MAX]``. The practical
 165:         minimum across the Step 1 corpus is roughly 0.34 (ja / short /
 166:         dialog / zero-marker); the practical maximum saturates at 3.0 for
 167:         de / 120+ tokens / monolog / marker_density >= ~10.
 168: 
 169:     Notes:
 170:         The returned weight is raw 窶・it has *not* yet been normalised to
 171:         mean=1.0. Pass the full per-train-split list through
 172:         :func:`normalise_weights_to_mean_one` before feeding to
 173:         :class:`WeightedTrainer`, otherwise the effective learning rate
 174:         will drift relative to the K-ﾎｲ rank=8 baseline (Codex HIGH-C #2).
 175:     """
 176:     lang = example_metadata["language"]
 177:     tokens = int(cast("int", example_metadata["token_count"]))
 178:     has_addressee = bool(example_metadata["has_addressee"])
 179:     marker_density = float(
 180:         cast("float", example_metadata["marker_density_per_100_tokens"])
 181:     )
 182: 
 183:     lang_factor = _LANG_FACTORS[str(lang)]
 184:     length_factor = _LENGTH_FACTOR_SATURATED
 185:     for upper_bound, factor in _LENGTH_THRESHOLDS:
 186:         if tokens < upper_bound:
 187:             length_factor = factor
 188:             break
 189:     monolog_bonus = _DIALOG_BONUS if has_addressee else _MONOLOG_BONUS
 190:     marker_factor = max(marker_density / _MARKER_DENSITY_DIVISOR, _MARKER_FACTOR_FLOOR)
 191: 
 192:     raw = (
 193:         lang_factor * _COEFF_LANG
 194:         + length_factor * _COEFF_LENGTH
 195:         + monolog_bonus * _COEFF_MONOLOG
 196:         + marker_factor * _COEFF_MARKER
 197:     )
 198:     return float(min(max(raw, WEIGHT_CLAMP_MIN), WEIGHT_CLAMP_MAX))
 199: 
 200: 
 201: # ---------------------------------------------------------------------------
 202: # normalise_weights_to_mean_one
 203: # ---------------------------------------------------------------------------
 204: 
 205: 
 206: def normalise_weights_to_mean_one(raw: Sequence[float]) -> list[float]:
 207:     """Rescale ``raw`` so the mean is exactly 1.0 (Codex HIGH-C #2).
 208: 
 209:     Without normalisation the hand-set coefficients (0.35/0.20/0.15/0.30)
 210:     silently shift the effective learning rate because the corpus-wide
 211:     mean of unnormalised weights is ~0.85 (estimated from Step 1 finding).
 212:     With normalisation the trainer's effective LR matches the K-ﾎｲ baseline
 213:     exactly except for the per-example variance the weights introduce.
 214: 
 215:     Args:
 216:         raw: The per-example raw weights as returned by
 217:             :func:`compute_example_weight`. Must be non-empty and contain
 218:             at least one positive value (an all-zero list raises
 219:             ``ZeroDivisionError`` 窶・that condition indicates a metadata
 220:             extraction bug, not a recoverable runtime state).
 221: 
 222:     Returns:
 223:         A list of floats with ``sum(out) / len(out) == 1.0`` to numerical
 224:         precision. Pairwise ratios are preserved exactly.
 225:     """
 226:     if not raw:
 227:         raise ValueError("normalise_weights_to_mean_one: raw list is empty")
 228:     mean = sum(raw) / len(raw)
 229:     if mean <= 0.0:
 230:         raise ZeroDivisionError(
 231:             "normalise_weights_to_mean_one: mean of raw weights is non-positive"
 232:             f" ({mean!r}); compute_example_weight should never emit 0/negative"
 233:             " 窶・investigate the upstream metadata extraction.",
 234:         )
 235:     return [w / mean for w in raw]
 236: 
 237: 
 238: # ---------------------------------------------------------------------------
 239: # emit_weight_audit
 240: # ---------------------------------------------------------------------------
 241: 
 242: _BUCKET_LANGS: Final[tuple[str, ...]] = ("de", "en", "ja", "mixed")
 243: _BUCKET_LENGTHS: Final[tuple[str, ...]] = ("<30", "30-59", "60-119", "120+")
 244: 
 245: 
 246: def _length_bucket(token_count: int) -> str:
 247:     if token_count < _LEN_BUCKET_SHORT_MAX:
 248:         return "<30"
 249:     if token_count < _LEN_BUCKET_MID_MAX:
 250:         return "30-59"
 251:     if token_count < _LEN_BUCKET_LONG_MAX:
 252:         return "60-119"
 253:     return "120+"
 254: 
 255: 
 256: def _marker_quartile_label(density: float, breakpoints: list[float]) -> str:
 257:     """Return ``"q1"``/``"q2"``/``"q3"``/``"q4"`` for a marker-density value."""
 258:     if not breakpoints:
 259:         return "q1"
 260:     if density <= breakpoints[0]:

