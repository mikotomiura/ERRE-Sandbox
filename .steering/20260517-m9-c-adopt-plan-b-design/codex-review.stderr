 succeeded in 312ms:
   1: r"""Plan B (Candidate C hybrid retrain) achieved-corpus-stats gate.
   2: 
   3: Reads the existing ``weight-audit.json`` emitted by
   4: :func:`erre_sandbox.training.weighting.emit_weight_audit` and applies the
   5: 4-axis hard gate defined in
   6: ``.steering/20260517-m9-c-adopt-plan-b-design/design.md`` ﾂｧ1.3:
   7: 
   8: * ``n_eff >= 1500`` (existing DA-14 target, promoted to hard gate)
   9: * ``top_5_pct_weight_share <= 0.35`` (existing DA-14 target)
  10: * ``per_language_weighted_mass["de"] + ["en"] >= 0.60`` (new Plan B
  11:   hard gate; rationale ``decisions.md`` DI-3)
  12: * ``per_language_weighted_mass["de"] >= 0.30`` (new Plan B hard gate to
  13:   prevent en free-rider; minority opinion from design-v2 ﾂｧ8)
  14: 
  15: The script emits ``plan-b-corpus-gate.json`` next to ``weight-audit.json``
  16: (or at ``--output`` if supplied) and exits with code 0 on pass / 8 on
  17: fail. Exit code 8 maps to :class:`PlanBCorpusGateError` once that
  18: exception lands in ``erre_sandbox.training.exceptions`` (next-session
  19: work) 窶・for now this script is the single source of truth for the gate
  20: verdict and the train_kant_lora ``--plan-b-gate`` flag will invoke this
  21: module-level :func:`audit_corpus` function.
  22: 
  23: Refs:
  24: 
  25: * ``.steering/20260517-m9-c-adopt-plan-b-design/design.md`` ﾂｧ1.3
  26: * ``.steering/20260517-m9-c-adopt-plan-b-design/decisions.md`` DI-3, DI-7
  27: * ``src/erre_sandbox/training/weighting.py`` :func:`emit_weight_audit`
  28: 
  29: Usage::
  30: 
  31:     python scripts/m9-c-adopt/audit_plan_b_corpus_stats.py \\
  32:         --weight-audit data/lora/m9-c-adopt-v2/kant_r8_v3/weight-audit.json \\
  33:         --merge-sha "$(git rev-parse HEAD)" \\
  34:         --output data/lora/m9-c-adopt-v2/kant_r8_v3/plan-b-corpus-gate.json
  35: """
  36: 
  37: from __future__ import annotations
  38: 
  39: import argparse
  40: import json
  41: import logging
  42: import sys
  43: from datetime import UTC, datetime
  44: from pathlib import Path
  45: from typing import Any, Final
  46: 
  47: logger = logging.getLogger(__name__)
  48: 
  49: 
  50: # ---------------------------------------------------------------------------
  51: # Thresholds (preregistered, design.md ﾂｧ1.3)
  52: # ---------------------------------------------------------------------------
  53: 
  54: N_EFF_MIN: Final[float] = 1500.0
  55: TOP_5_PCT_MAX: Final[float] = 0.35
  56: DE_EN_MASS_MIN: Final[float] = 0.60
  57: DE_MASS_MIN: Final[float] = 0.30
  58: GATE_FAIL_EXIT_CODE: Final[int] = 8
  59: GATE_SCHEMA_VERSION: Final[int] = 1
  60: 
  61: 
  62: def audit_corpus(
  63:     weight_audit: dict[str, Any],
  64:     *,
  65:     weight_audit_path: str,
  66:     merge_sha: str,
  67:     n_eff_min: float = N_EFF_MIN,
  68:     top_5_pct_max: float = TOP_5_PCT_MAX,
  69:     de_en_mass_min: float = DE_EN_MASS_MIN,
  70:     de_mass_min: float = DE_MASS_MIN,
  71: ) -> dict[str, Any]:
  72:     """Apply the 4-axis Plan B gate to a parsed weight-audit dict.
  73: 
  74:     Pure function 窶・caller is responsible for IO. Returns a result dict
  75:     matching the schema in ``design.md`` ﾂｧ1.3, with ``plan_b_gate`` set
  76:     to ``"pass"`` or ``"fail"`` and ``failed_axes`` listing every axis
  77:     that breached its threshold.
  78:     """
  79:     n_eff = float(weight_audit.get("n_eff", 0.0))
  80:     top_5 = float(weight_audit.get("top_5_pct_weight_share", 1.0))
  81:     lang_mass_obj = weight_audit.get("per_language_weighted_mass", {})
  82:     if not isinstance(lang_mass_obj, dict):
  83:         lang_mass_obj = {}
  84:     de_mass = float(lang_mass_obj.get("de", 0.0))
  85:     en_mass = float(lang_mass_obj.get("en", 0.0))
  86:     de_en_mass = de_mass + en_mass
  87: 
  88:     failed_axes: list[str] = []
  89:     if n_eff < n_eff_min:
  90:         failed_axes.append("n_eff")
  91:     if top_5 > top_5_pct_max:
  92:         failed_axes.append("top_5_pct")
  93:     if de_en_mass < de_en_mass_min:
  94:         failed_axes.append("de_en_mass")
  95:     if de_mass < de_mass_min:
  96:         failed_axes.append("de_mass")
  97: 
  98:     return {
  99:         "schema_version": GATE_SCHEMA_VERSION,
 100:         "plan_b_gate": "pass" if not failed_axes else "fail",
 101:         "thresholds": {
 102:             "n_eff_min": n_eff_min,
 103:             "top_5_pct_max": top_5_pct_max,
 104:             "de_en_mass_min": de_en_mass_min,
 105:             "de_mass_min": de_mass_min,
 106:         },
 107:         "achieved": {
 108:             "n_eff": n_eff,
 109:             "top_5_pct_weight_share": top_5,
 110:             "de_en_mass": de_en_mass,
 111:             "de_mass": de_mass,
 112:             "en_mass": en_mass,
 113:         },
 114:         "failed_axes": failed_axes,
 115:         "weight_audit_path": weight_audit_path,
 116:         "merge_sha": merge_sha,
 117:         "captured_at_utc": datetime.now(UTC).isoformat(),
 118:     }
 119: 
 120: 
 121: def _build_arg_parser() -> argparse.ArgumentParser:
 122:     p = argparse.ArgumentParser(
 123:         prog="m9-c-adopt-audit-plan-b-corpus-stats",
 124:         description=(
 125:             "Apply the Plan B 4-axis achieved-corpus-stats hard gate to an"
 126:             " existing weight-audit.json. Exits 0 on pass / 8 on fail."
 127:         ),
 128:     )
 129:     p.add_argument(
 130:         "--weight-audit",
 131:         required=True,
 132:         type=Path,
 133:         help="Path to weight-audit.json emitted by train_kant_lora.",
 134:     )
 135:     p.add_argument(
 136:         "--merge-sha",
 137:         required=True,
 138:         help=(
 139:             "Git SHA of the PR merging the Plan B design + driver"
 140:             " (provenance pin for the gate verdict)."
 141:         ),
 142:     )
 143:     p.add_argument(
 144:         "--output",
 145:         type=Path,
 146:         default=None,
 147:         help=(
 148:             "Output path for plan-b-corpus-gate.json. Defaults to the"
 149:             " parent dir of --weight-audit."
 150:         ),
 151:     )
 152:     p.add_argument(
 153:         "--n-eff-min", type=float, default=N_EFF_MIN, help="Override N_eff floor."
 154:     )
 155:     p.add_argument(
 156:         "--top-5-pct-max",
 157:         type=float,
 158:         default=TOP_5_PCT_MAX,
 159:         help="Override top-5%% weight share ceiling.",
 160:     )
 161:     p.add_argument(
 162:         "--de-en-mass-min",
 163:         type=float,
 164:         default=DE_EN_MASS_MIN,
 165:         help="Override de+en weighted mass floor.",
 166:     )
 167:     p.add_argument(
 168:         "--de-mass-min",
 169:         type=float,
 170:         default=DE_MASS_MIN,
 171:         help="Override de-alone weighted mass floor.",
 172:     )
 173:     p.add_argument(
 174:         "--log-level",
 175:         default="info",
 176:         choices=("debug", "info", "warning", "error"),
 177:     )
 178:     return p
 179: 
 180: 
 181: def main(argv: list[str] | None = None) -> int:
 182:     args = _build_arg_parser().parse_args(argv)
 183:     logging.basicConfig(
 184:         level=args.log_level.upper(),
 185:         format="%(asctime)s [%(name)s] %(levelname)s: %(message)s",
 186:         force=True,
 187:     )
 188:     weight_audit_path: Path = args.weight_audit
 189:     if not weight_audit_path.exists():
 190:         logger.error("weight-audit not found: %s", weight_audit_path)
 191:         return 2
 192:     weight_audit = json.loads(weight_audit_path.read_text(encoding="utf-8"))
 193: 
 194:     output_path: Path = (
 195:         args.output
 196:         if args.output is not None
 197:         else weight_audit_path.parent / "plan-b-corpus-gate.json"
 198:     )
 199: 
 200:     result = audit_corpus(
 201:         weight_audit,
 202:         weight_audit_path=str(weight_audit_path),
 203:         merge_sha=args.merge_sha,
 204:         n_eff_min=args.n_eff_min,
 205:         top_5_pct_max=args.top_5_pct_max,
 206:         de_en_mass_min=args.de_en_mass_min,
 207:         de_mass_min=args.de_mass_min,
 208:     )
 209: 
 210:     output_path.parent.mkdir(parents=True, exist_ok=True)
 211:     output_path.write_text(
 212:         json.dumps(result, indent=2, sort_keys=True) + "\n",
 213:         encoding="utf-8",
 214:     )
 215: 
 216:     achieved = result["achieved"]
 217:     thresholds = result["thresholds"]
 218:     logger.info(
 219:         "plan-b-corpus-gate: %s (n_eff=%.1f/%.0f top_5%%=%.3f/%.3f"
 220:         " de+en=%.3f/%.2f de=%.3f/%.2f)",
 221:         result["plan_b_gate"].upper(),
 222:         achieved["n_eff"],
 223:         thresholds["n_eff_min"],
 224:         achieved["top_5_pct_weight_share"],
 225:         thresholds["top_5_pct_max"],
 226:         achieved["de_en_mass"],
 227:         thresholds["de_en_mass_min"],
 228:         achieved["de_mass"],
 229:         thresholds["de_mass_min"],
 230:     )
 231:     logger.info("plan-b-corpus-gate output: %s", output_path)
 232: 
 233:     if result["failed_axes"]:
 234:         logger.error(
 235:             "plan-b-corpus-gate FAIL on axes: %s",
 236:             ", ".join(result["failed_axes"]),
 237:         )
 238:         return GATE_FAIL_EXIT_CODE
 239:     return 0
