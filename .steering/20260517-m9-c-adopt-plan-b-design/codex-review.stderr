 519: def run_collection(args: argparse.Namespace) -> int:  # noqa: PLR0915
 520:     persona_id = args.persona
 521:     run_idx = args.run_idx
 522: 
 523:     persona_yaml = _load_persona_yaml(args.personas_dir, persona_id)
 524:     system_prompt = build_de_monolog_system_prompt(persona_yaml)
 525: 
 526:     battery = _load_stimulus_battery(persona_id, args.stimulus_dir)
 527:     de_stimuli = select_de_focused_stimuli(battery)
 528:     if not de_stimuli:
 529:         logger.error("no de-focused stimuli found for persona=%s", persona_id)
 530:         return 2
 531:     logger.info("de-focused stimulus subset: %d / %d", len(de_stimuli), len(battery))
 532: 
 533:     seed_root = _derive_seed(persona_id, run_idx)
 534:     run_id = f"{persona_id}_de_monolog_run{run_idx}"
 535: 
 536:     args.output.parent.mkdir(parents=True, exist_ok=True)
 537:     con = duckdb.connect(str(args.output), read_only=False)
 538:     _bootstrap_db(con)
 539: 
 540:     _resume_stim, resume_attempt, completed_net, total_attempts, rejected = (
 541:         _read_resume_state(con)
 542:     )
 543:     if completed_net > 0 and not args.dry_run:
 544:         logger.info(
 545:             "resuming: completed_net=%d total_attempts=%d rejected=%d",
 546:             completed_net,
 547:             total_attempts,
 548:             rejected,
 549:         )
 550: 
 551:     target_net = args.target_net
 552:     max_attempts = args.max_attempts
 553:     started_at = time.monotonic()
 554: 
 555:     logger.info(
 556:         "collection start persona=%s run=%d target_net=%d max_attempts=%d"
 557:         " de_stim=%d host=%s",
 558:         persona_id,
 559:         run_idx,
 560:         target_net,
 561:         max_attempts,
 562:         len(de_stimuli),
 563:         args.sglang_host,
 564:     )
 565: 
 566:     reject_reasons: dict[str, int] = defaultdict(int)
 567:     attempt_idx = resume_attempt
 568: 
 569:     while completed_net < target_net and total_attempts < max_attempts:
 570:         stim_pos = attempt_idx % len(de_stimuli)
 571:         stimulus = de_stimuli[stim_pos]
 572:         stim_id = str(stimulus.get("stimulus_id", f"unknown_{stim_pos}"))
 573:         zone = str(stimulus.get("expected_zone", ""))
 574:         seed = (seed_root ^ (attempt_idx << 4)) & 0xFFFFFFFF
 575:         user_prompt = _build_user_prompt(stimulus, attempt_idx)
 576: 
 577:         try:
 578:             resp = _sglang_chat(
 579:                 host=args.sglang_host,
 580:                 model_name=_NO_LORA_MODEL,
 581:                 system_prompt=system_prompt,
 582:                 user_prompt=user_prompt,
 583:                 temperature=args.temperature,
 584:                 frequency_penalty=args.frequency_penalty,
 585:                 presence_penalty=args.presence_penalty,
 586:                 max_tokens=args.max_tokens,
 587:                 seed=int(seed),
 588:                 timeout_s=args.timeout_s,
 589:             )
 590:         except RuntimeError:
 591:             logger.exception(
 592:                 "fatal sglang failure at attempt=%d stim=%s 窶・checkpointing",
 593:                 attempt_idx,
 594:                 stim_id,
 595:             )
 596:             _flush_state(
 597:                 con, stim_id, attempt_idx, completed_net, total_attempts, rejected
 598:             )
 599:             con.execute("CHECKPOINT")
 600:             con.close()
 601:             return 3
 602: 
 603:         total_attempts += 1
 604:         filter_result = filter_de_monolog(
 605:             resp.text,
 606:             min_token_count=args.min_token_count,
 607:             min_marker_density=args.min_marker_density,
 608:             trigram_loop_max=args.trigram_loop_max,
 609:         )
 610: 
 611:         if filter_result.accepted:
 612:             dialog_id = f"de_mono_{stim_id}_a{attempt_idx}"
 613:             tick = completed_net
 614:             _insert_monolog_row(
 615:                 con,
 616:                 run_id=run_id,
 617:                 persona_id=persona_id,
 618:                 dialog_id=dialog_id,
 619:                 tick=tick,
 620:                 utterance=resp.text,
 621:                 zone=zone,
 622:             )
 623:             completed_net += 1
 624:         else:
 625:             rejected += 1
 626:             reason = filter_result.reason or "unknown"
 627:             reject_reasons[reason] += 1
 628: 
 629:         attempt_idx += 1
 630: 
 631:         if total_attempts % _CHECKPOINT_FLUSH_EVERY == 0:
 632:             _flush_state(
 633:                 con, stim_id, attempt_idx, completed_net, total_attempts, rejected
 634:             )
 635:             con.execute("CHECKPOINT")
 636:             elapsed = time.monotonic() - started_at
 637:             rate = completed_net / max(elapsed, 1e-3)
 638:             eta_s = max(0.0, (target_net - completed_net) / max(rate, 1e-6))
 639:             acceptance = completed_net / max(total_attempts, 1)
 640:             logger.info(
 641:                 "checkpoint completed_net=%d/%d attempts=%d rejected=%d"
 642:                 " acceptance=%.1f%% rate=%.2f net/s eta=%.1f min",
 643:                 completed_net,
 644:                 target_net,
 645:                 total_attempts,
 646:                 rejected,
 647:                 acceptance * 100.0,
 648:                 rate,
 649:                 eta_s / 60.0,
 650:             )
 651: 
 652:     _flush_state(con, "complete", attempt_idx, completed_net, total_attempts, rejected)
 653:     con.execute("CHECKPOINT")
 654:     con.close()
 655: 
 656:     elapsed = time.monotonic() - started_at
 657:     acceptance = completed_net / max(total_attempts, 1)
 658:     logger.info(
 659:         "collection done completed_net=%d target=%d attempts=%d rejected=%d"
 660:         " acceptance=%.1f%% elapsed=%.1f min output=%s",
 661:         completed_net,
 662:         target_net,
 663:         total_attempts,
 664:         rejected,
 665:         acceptance * 100.0,
 666:         elapsed / 60.0,
 667:         args.output,
 668:     )
 669:     for reason, count in sorted(reject_reasons.items()):
 670:         logger.info("  reject reason %s: %d", reason, count)
 671: 
 672:     if completed_net < target_net:
 673:         logger.error(
 674:             "target_net=%d not reached after max_attempts=%d (completed=%d)",
 675:             target_net,
 676:             max_attempts,
 677:             completed_net,
 678:         )
 679:         return 2
 680: 
 681:     return 0
