 258: def test_filter_thresholds_are_configurable(collector_module):
 259:     """Thresholds can be loosened/tightened per call."""
 260:     # 3 German function words (ich, das, ist) + Kantian marker
 261:     # ("transzendentale" matches \\btranszendental\\w*\\b) 竊・classify_language="de"
 262:     text = "Ich denke das transzendentale Subjekt ist die reine Vernunft."
 263:     # Default rejects (length: only ~10 tokens, < 60)
 264:     assert collector_module.filter_de_monolog(text).accepted is False
 265:     # Lower thresholds 窶・should now pass
 266:     result = collector_module.filter_de_monolog(
 267:         text, min_token_count=4, min_marker_density=0.5, trigram_loop_max=10
 268:     )
 269:     assert result.accepted is True
