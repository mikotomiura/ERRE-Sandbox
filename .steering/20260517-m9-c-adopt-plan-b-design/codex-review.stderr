 240: # ---------------------------------------------------------------------------
 241: # SGLang HTTP client (mirrors tier_b_pilot._sglang_chat with extra penalties)
 242: # ---------------------------------------------------------------------------
 243: 
 244: 
 245: @dataclasses.dataclass(frozen=True)
 246: class SGLangChatResponse:
 247:     text: str
 248:     finish_reason: str | None
 249:     raw: dict[str, Any]
 250: 
 251: 
 252: def _sglang_chat(
 253:     *,
 254:     host: str,
 255:     model_name: str,
 256:     system_prompt: str,
 257:     user_prompt: str,
 258:     temperature: float,
 259:     frequency_penalty: float,
 260:     presence_penalty: float,
 261:     max_tokens: int,
 262:     seed: int,
 263:     timeout_s: float,
 264: ) -> SGLangChatResponse:
 265:     """One blocking POST to SGLang ``/v1/chat/completions``."""
 266:     payload = {
 267:         "model": model_name,
 268:         "messages": [
 269:             {"role": "system", "content": system_prompt},
 270:             {"role": "user", "content": user_prompt},
 271:         ],
 272:         "max_tokens": max_tokens,
 273:         "temperature": temperature,
 274:         "frequency_penalty": frequency_penalty,
 275:         "presence_penalty": presence_penalty,
 276:         "seed": seed,
 277:         "chat_template_kwargs": {"enable_thinking": False},
 278:     }
 279:     body = json.dumps(payload).encode("utf-8")
 280:     req = urllib.request.Request(  # noqa: S310 窶・fixed scheme via host arg
 281:         f"{host.rstrip('/')}/v1/chat/completions",
 282:         data=body,
 283:         headers={"Content-Type": "application/json"},
 284:         method="POST",
 285:     )
 286:     last_exc: Exception | None = None
 287:     for attempt in range(_INFERENCE_RETRY_MAX):
 288:         try:
 289:             with urllib.request.urlopen(req, timeout=timeout_s) as resp:  # noqa: S310
 290:                 raw = json.loads(resp.read().decode("utf-8"))
 291:             choices = raw.get("choices") or []
 292:             if not choices:
 293:                 msg = f"sglang returned no choices: {raw}"
 294:                 raise RuntimeError(msg)
 295:             choice = choices[0]
 296:             text = str(choice.get("message", {}).get("content", "")).strip()
 297:             if "</think>" in text:
 298:                 text = text.split("</think>", 1)[1].strip()
 299:             if text.startswith("<think>"):
 300:                 text = text.removeprefix("<think>").strip()
 301:             finish = choice.get("finish_reason")
 302:             return SGLangChatResponse(text=text, finish_reason=finish, raw=raw)
 303:         except (urllib.error.URLError, TimeoutError, RuntimeError, OSError) as exc:
 304:             last_exc = exc
 305:             wait_s = _INFERENCE_RETRY_BACKOFF_S * (2**attempt)
 306:             logger.warning(
 307:                 "sglang chat failed attempt=%d/%d: %s 窶・backing off %.1fs",
 308:                 attempt + 1,
 309:                 _INFERENCE_RETRY_MAX,
 310:                 exc,
 311:                 wait_s,
 312:             )
 313:             time.sleep(wait_s)
 314:     msg = f"sglang chat exhausted {_INFERENCE_RETRY_MAX} attempts: {last_exc!r}"
 315:     raise RuntimeError(msg)
 316: 
 317: 
 318: # ---------------------------------------------------------------------------
 319: # Post-hoc filter (hard gate, design.md ﾂｧ1.1)
 320: # ---------------------------------------------------------------------------
 321: 
 322: 
 323: @dataclasses.dataclass(frozen=True)
 324: class FilterResult:
 325:     accepted: bool
 326:     reason: str | None  # "lang" | "length" | "marker" | "trigram" | None
 327:     language: str
 328:     token_count: int
 329:     marker_density: float
 330:     trigram_max: int
 331: 
 332: 
 333: _WORD_RE: Final = re.compile(r"[\wﾃ､ﾃｶﾃｼﾃ淌・姪彎+", re.UNICODE)
 334: 
 335: 
 336: def _max_trigram_count(text: str) -> int:
 337:     """Return the maximum frequency of any token trigram in ``text``."""
 338:     tokens = [t.lower() for t in _WORD_RE.findall(text)]
 339:     if len(tokens) < 3:  # noqa: PLR2004
 340:         return 0
 341:     counts: dict[tuple[str, str, str], int] = defaultdict(int)
 342:     for i in range(len(tokens) - 2):
 343:         counts[(tokens[i], tokens[i + 1], tokens[i + 2])] += 1
 344:     return max(counts.values()) if counts else 0
 345: 
 346: 
 347: def filter_de_monolog(
 348:     text: str,
 349:     *,
 350:     min_token_count: int = _DEFAULT_MIN_TOKEN_COUNT,
 351:     min_marker_density: float = _DEFAULT_MIN_MARKER_DENSITY,
 352:     trigram_loop_max: int = _DEFAULT_TRIGRAM_LOOP_MAX,
 353: ) -> FilterResult:
 354:     """Apply the 4-axis post-hoc hard gate to a single utterance.
 355: 
 356:     Order of checks: language 竊・length 竊・marker_density 竊・trigram_loop.
 357:     Short-circuits on first failure for diagnostic clarity.
 358:     """
 359:     if not text or not text.strip():
 360:         return FilterResult(
 361:             accepted=False,
 362:             reason="lang",
 363:             language="mixed",
 364:             token_count=0,
 365:             marker_density=0.0,
 366:             trigram_max=0,
 367:         )
 368:     language = classify_language(text)
 369:     if language != "de":
 370:         return FilterResult(
 371:             accepted=False,
 372:             reason="lang",
 373:             language=language,
 374:             token_count=0,
 375:             marker_density=0.0,
 376:             trigram_max=0,
 377:         )
 378:     tokens = estimate_token_count(text, use_real_tokenizer=False)
 379:     if tokens < min_token_count:
 380:         return FilterResult(
 381:             accepted=False,
 382:             reason="length",
 383:             language=language,
 384:             token_count=tokens,
 385:             marker_density=0.0,
 386:             trigram_max=0,
 387:         )
 388:     marker_count = count_markers(text, GERMAN_PATTERNS) + count_markers(
 389:         text, KANTIAN_PATTERNS
 390:     )
 391:     density = (marker_count / tokens) * 100.0 if tokens > 0 else 0.0
 392:     if density < min_marker_density:
 393:         return FilterResult(
 394:             accepted=False,
 395:             reason="marker",
 396:             language=language,
 397:             token_count=tokens,
 398:             marker_density=density,
 399:             trigram_max=0,
 400:         )
 401:     trigram_max = _max_trigram_count(text)
 402:     if trigram_max > trigram_loop_max:
 403:         return FilterResult(
 404:             accepted=False,
 405:             reason="trigram",
 406:             language=language,
 407:             token_count=tokens,
 408:             marker_density=density,
 409:             trigram_max=trigram_max,
 410:         )
 411:     return FilterResult(
 412:         accepted=True,
 413:         reason=None,
 414:         language=language,
 415:         token_count=tokens,
 416:         marker_density=density,
 417:         trigram_max=trigram_max,
 418:     )
 419: 
 420: 
 421: # ---------------------------------------------------------------------------
 422: # DuckDB sink + checkpoint
 423: # ---------------------------------------------------------------------------
 424: 
 425: 
 426: def _bootstrap_db(con: duckdb.DuckDBPyConnection) -> None:
 427:     con.execute(_RAW_DIALOG_TABLE_DDL)
 428: 
 429: 
 430: def _read_resume_state(
 431:     con: duckdb.DuckDBPyConnection,
 432: ) -> tuple[str | None, int, int, int, int]:
 433:     rows = con.execute(
 434:         "SELECT last_stim_id, last_attempt_idx, completed_net, total_attempts,"
 435:         " rejected FROM pilot_state ORDER BY updated_at DESC LIMIT 1"
 436:     ).fetchall()
 437:     if not rows:
 438:         return None, 0, 0, 0, 0
 439:     return (
 440:         rows[0][0],
 441:         int(rows[0][1]),
 442:         int(rows[0][2]),
 443:         int(rows[0][3]),
 444:         int(rows[0][4]),
 445:     )
 446: 
 447: 
 448: def _flush_state(
 449:     con: duckdb.DuckDBPyConnection,
 450:     last_stim: str,
 451:     attempt_idx: int,
 452:     completed_net: int,
 453:     total_attempts: int,
 454:     rejected: int,
 455: ) -> None:
 456:     con.execute("DELETE FROM pilot_state")
 457:     con.execute(
 458:         "INSERT INTO pilot_state VALUES (?, ?, ?, ?, ?, ?)",
 459:         (
 460:             last_stim,
 461:             attempt_idx,
 462:             completed_net,
 463:             total_attempts,
 464:             rejected,
 465:             datetime.now(UTC),
 466:         ),
 467:     )
 468: 
 469: 
 470: def _insert_monolog_row(
 471:     con: duckdb.DuckDBPyConnection,
 472:     *,
 473:     run_id: str,
 474:     persona_id: str,
 475:     dialog_id: str,
 476:     tick: int,
 477:     utterance: str,
 478:     zone: str,
 479: ) -> None:
 480:     row_id = f"{run_id}:{dialog_id}"
 481:     con.execute(
 482:         "INSERT INTO raw_dialog.dialog"
 483:         ' ("id", "run_id", "dialog_id", "tick", "turn_index",'
 484:         ' "speaker_agent_id", "speaker_persona_id",'
 485:         ' "addressee_agent_id", "addressee_persona_id",'
 486:         ' "utterance", "mode", "zone", "reasoning",'
 487:         ' "epoch_phase", "created_at")'
 488:         " VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
 489:         (
 490:             row_id,
 491:             run_id,
 492:             dialog_id,
 493:             tick,
 494:             0,  # turn_index always 0 (single-turn monolog)
 495:             _AGENT_ID_FMT.format(persona_id=persona_id),
 496:             persona_id,
 497:             None,  # addressee_agent_id NULL (monolog)
 498:             None,  # addressee_persona_id NULL (monolog)
 499:             utterance,
 500:             "",  # mode reserved for ERRE FSM
 501:             zone,
