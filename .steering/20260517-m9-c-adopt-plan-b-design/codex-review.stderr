 514: def _derive_seed(persona: str, run_idx: int) -> int:
 515:     key = f"{persona}|de_monolog|run{run_idx}".encode()
 516:     return int.from_bytes(hashlib.blake2b(key, digest_size=8).digest(), "little")
 517: 
