 144: # ---------------------------------------------------------------------------
 145: # Stimulus loading + subset (de prompt + study/peripatos zone)
 146: # ---------------------------------------------------------------------------
 147: 
 148: 
 149: def _load_stimulus_battery(persona_id: str, root: Path) -> list[dict[str, Any]]:
 150:     path = root / f"{persona_id}.yaml"
 151:     parsed = yaml.safe_load(path.read_text(encoding="utf-8"))
 152:     if not isinstance(parsed, dict) or not isinstance(parsed.get("stimuli"), list):
 153:         msg = f"{path}: malformed stimulus YAML"
 154:         raise TypeError(msg)
 155:     return list(parsed["stimuli"])
 156: 
 157: 
 158: def _is_de_prompt(prompt_text: str) -> bool:
 159:     """Heuristic: prompt_text classified as ``de`` or ``mixed`` with strong de hits.
 160: 
 161:     Reuses :func:`classify_language` for consistency with the post-hoc
 162:     filter applied to model outputs. Allow ``mixed`` so e.g. bilingual
 163:     stims with heavy German function-word density still slip through.
 164:     """
 165:     lang = classify_language(prompt_text)
 166:     return lang in {"de", "mixed"}
 167: 
 168: 
 169: def select_de_focused_stimuli(battery: list[dict[str, Any]]) -> list[dict[str, Any]]:
 170:     """Filter battery to de-prompt stimuli in study / peripatos zones.
 171: 
 172:     Excludes ``moral_dilemma`` / ``tom_chashitsu`` / ``roleeval`` categories
 173:     (design.md R-4: persona drift mitigation 窶・de-monolog directive plus
 174:     out-of-domain stimuli would force artificial German output unrelated
 175:     to Critique-of-Pure-Reason register).
 176:     """
 177:     selected: list[dict[str, Any]] = []
 178:     for stim in battery:
 179:         category = str(stim.get("category", ""))
 180:         zone = str(stim.get("expected_zone", ""))
 181:         prompt_text = str(stim.get("prompt_text", ""))
 182:         if category in _EXCLUDED_CATEGORIES:
 183:             continue
 184:         if zone not in _TARGET_ZONES:
 185:             continue
 186:         if not _is_de_prompt(prompt_text):
 187:             continue
 188:         selected.append(stim)
 189:     return selected
 190: 
 191: 
 192: # ---------------------------------------------------------------------------
 193: # Persona prompt 窶・fork of tier_b_pilot._build_system_prompt for de monolog
 194: # ---------------------------------------------------------------------------
 195: 
 196: 
 197: def _load_persona_yaml(personas_dir: Path, persona_id: str) -> dict[str, Any]:
 198:     path = personas_dir / f"{persona_id}.yaml"
 199:     return yaml.safe_load(path.read_text(encoding="utf-8")) or {}
 200: 
 201: 
 202: def build_de_monolog_system_prompt(persona: dict[str, Any]) -> str:
 203:     """Persona system prompt with the de-monolog directive appended.
 204: 
 205:     Mirrors ``tier_b_pilot._build_system_prompt`` so the persona block
 206:     (display name, era, cognitive habits) is identical, then appends the
 207:     de-monolog directive. Keeping the persona block byte-identical to the
 208:     baseline collector preserves the apples-to-apples comparison axis with
 209:     DA-14 baseline / Plan A rescore.
 210:     """
 211:     display = persona.get("display_name", persona.get("persona_id", "agent"))
 212:     era = persona.get("era", "")
 213:     habits_seq: list[Any] = persona.get("cognitive_habits") or []
 214:     habit_lines: list[str] = []
 215:     for habit in list(habits_seq)[:3]:
 216:         if isinstance(habit, dict):
 217:             desc = habit.get("description", "")
 218:             flag = habit.get("flag", "")
 219:             habit_lines.append(f"- {desc} [{flag}]")
 220:     habits_block = "\n".join(habit_lines) if habit_lines else "(no habits recorded)"
 221:     common = (
 222:         "You are an autonomous agent in ERRE-Sandbox. A researcher hands you "
 223:         "a curated stimulus from a Toulmin / Theory-of-Mind / RoleEval / "
 224:         "moral-dilemma battery. Stay in character; speak as yourself, not "
 225:         "about yourself."
 226:     )
 227:     persona_block = f"Persona: {display} ({era}).\nCognitive habits:\n{habits_block}"
 228:     return f"{common}\n\n{persona_block}\n{_DE_MONOLOG_DIRECTIVE}"
 229: 
 230: 
 231: def _build_user_prompt(stimulus: dict[str, Any], attempt_idx: int) -> str:
 232:     prompt_text = str(stimulus.get("prompt_text", "")).strip()
 233:     category = str(stimulus.get("category", ""))
 234:     return (
 235:         f"[stimulus_id={stimulus.get('stimulus_id', '?')} "
 236:         f"category={category} attempt={attempt_idx}]\n\n{prompt_text}"
 237:     )
