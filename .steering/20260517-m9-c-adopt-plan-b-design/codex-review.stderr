  50: def test_audit_corpus_passes_when_all_thresholds_met(audit_module):
  51:     result = audit_module.audit_corpus(
  52:         _good_audit(),
  53:         weight_audit_path="path/to/weight-audit.json",
  54:         merge_sha="abc123",
