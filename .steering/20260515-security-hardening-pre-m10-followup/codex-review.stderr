    37	    # store for Tier 0 ``raw_dialog`` + ``metrics`` schemas; Parquet export
    38	    # is a downstream artefact. Kept in core (not eval extras) so the
    39	    # ``contracts.eval_paths`` schema-guard contract is always exercised by
    40	    # CI; heavy ML deps (sentence-transformers, scipy, ollama, empath, arch)
    41	    # remain isolated under ``optional-dependencies.eval``.
    42	    "duckdb>=1.1,<2",
    43	]
    44	
