   194	
   195	    def test_fan_out_drops_oldest_and_enqueues_warning_when_full(self) -> None:
   196	        reg = Registry()
   197	        q: asyncio.Queue[ControlEnvelope] = asyncio.Queue(maxsize=2)
   198	        reg.add("s1", q)
   199	        first = WorldTickMsg(tick=1, active_agents=1)
   200	        second = WorldTickMsg(tick=2, active_agents=1)
   201	        third = WorldTickMsg(tick=3, active_agents=1)
   202	        reg.fan_out(first)
   203	        reg.fan_out(second)
   204	        # Queue is full; next fan_out should drop `first`, add warning, add third.
   205	        reg.fan_out(third)
   206	        drained: list[ControlEnvelope] = []
   207	        while not q.empty():
   208	            drained.append(q.get_nowait())
   209	        kinds = [e.kind for e in drained]
   210	        assert "error" in kinds
   211	        assert drained[-1] is third
   212	        errors = [e for e in drained if isinstance(e, ErrorMsg)]
   213	        assert errors[0].code == "backlog_overflow"
