   252	    """
   253	    _ = persona  # future hook: persona-specific spawn biases
   254	    agent_id = f"a_{spec.persona_id}_001"
   255	    erre_name = ZONE_TO_DEFAULT_ERRE_MODE.get(
   256	        spec.initial_zone,
   257	        ERREModeName.DEEP_WORK,
   258	    )
   259	    return AgentState(
   260	        agent_id=agent_id,

