   920	def _main() -> None:
   921	    import uvicorn  # noqa: PLC0415 — only needed when run as __main__
   922	
   923	    parser = argparse.ArgumentParser(description=__doc__)
   924	    parser.add_argument("--host", default="0.0.0.0")  # noqa: S104 — LAN only
   925	    parser.add_argument("--port", type=int, default=8000)
   926	    args = parser.parse_args()
   927	    uvicorn.run(
   928	        "erre_sandbox.integration.gateway:make_app",
   929	        factory=True,
   930	        host=args.host,
   931	        port=args.port,
   932	    )
   933	
