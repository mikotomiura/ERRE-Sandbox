   507	    ) -> None:
   508	        """Default ``WSAuthConfig()`` accepts unauthenticated peers.
   509	
   510	        Mirrors the Mac↔G-GEAR LAN workflow contract — bumping to the new
   511	        gateway must not require token provisioning on existing setups.
   512	        """
   513	        with (
   514	            _make_authed_client(mock_runtime, WSAuthConfig()) as client,
   515	            client.websocket_connect("/ws/observe") as ws,
