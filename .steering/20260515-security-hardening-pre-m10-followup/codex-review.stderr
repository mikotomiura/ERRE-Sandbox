 succeeded in 0ms:
     1	# WebSocketClient — T16 godot-ws-client (T19 live: client handshake added)
     2	#
     3	# Thin WebSocket client. Responsibilities:
     4	#   1. Maintain a connection to the G-GEAR gateway at ``ws_url``
     5	#   2. Send the required client ``HandshakeMsg`` as the first frame so the T14
     6	#      gateway transitions AWAITING_HANDSHAKE → ACTIVE before ``HANDSHAKE_TIMEOUT_S``
     7	#   3. Auto-reconnect every ``RECONNECT_DELAY`` seconds on disconnect
     8	#   4. Parse each incoming UTF-8 JSON frame into a Dictionary
     9	#   5. Emit ``envelope_received`` / ``connection_status_changed``
    10	#
    11	# This script intentionally knows nothing about ControlEnvelope kinds or
    12	# downstream dispatch. ``EnvelopeRouter.gd`` handles kind-based routing,
    13	# keeping this client focused on transport concerns only. Fixture replay
    14	# lives in the developer-only ``scripts/dev/FixturePlayer.gd`` so no test
    15	# code leaks into the production path.
    16	class_name WebSocketClient
    17	extends Node
    18	
    19	## WebSocket URL for the G-GEAR gateway (LAN address, no auth per architecture §6).
    20	##
    21	## Default resolves ``g-gear.local`` via mDNS or /etc/hosts. If that fails on the
    22	## host OS, override this export in the Inspector (MainScene ▸ WebSocketClient)
    23	## with the LAN IP the gateway is bound to, e.g. ``ws://192.168.3.85:8000/ws/observe``.
    24	@export var ws_url: String = "ws://g-gear.local:8000/ws/observe"
    25	## Schema version this client advertises in its client HandshakeMsg. Must match the
    26	## gateway's :data:`erre_sandbox.schemas.SCHEMA_VERSION` or the gateway closes with
    27	## ``ErrorMsg code="schema_mismatch"``.
    28	const CLIENT_SCHEMA_VERSION: String = "0.10.0-m7h"
    29	## Reconnect delay in seconds. Set to 2.0s to satisfy MVP M2 acceptance criterion
    30	## "WS 切断で 3 秒以内自動再接続" (MASTER-PLAN §4.4). See godot-gdscript patterns.md §1.
    31	const RECONNECT_DELAY: float = 2.0
    32	## Upper bound for a single incoming WebSocket frame. Anything larger is dropped
    33	## with a warning — defends the headless Godot process against a misbehaving
    34	## gateway that emits oversize JSON (see security review HIGH #1 for context).
    35	const MAX_FRAME_BYTES: int = 1_048_576
    36	
    37	var _ws: WebSocketPeer = WebSocketPeer.new()
    38	var _connected: bool = false
    39	var _handshake_sent: bool = false
    40	var _should_reconnect: bool = false
    41	var _reconnect_timer: float = 0.0
    42	
    43	signal envelope_received(envelope: Dictionary)
    44	signal connection_status_changed(connected: bool)
    45	
    46	
    47	func _ready() -> void:
    48		_connect_to_server()
    49	
    50	
    51	func _connect_to_server() -> void:
    52		_should_reconnect = false
    53		_handshake_sent = false
    54		print("[WS] connecting to %s" % ws_url)
    55		var err := _ws.connect_to_url(ws_url)
    56		if err != OK:
    57			push_warning(
    58				"[WS] connect_to_url failed (%s); retry in %ss"
    59				% [error_string(err), RECONNECT_DELAY]
    60			)
    61			_schedule_reconnect()
    62	
    63	
    64	## Build the client HandshakeMsg JSON the T14 gateway expects as the first frame
    65	## (must arrive within ``HANDSHAKE_TIMEOUT_S = 5.0`` or the session is closed).
    66	func _send_client_handshake() -> void:
    67		var payload := {
    68			"kind": "handshake",
    69			"schema_version": CLIENT_SCHEMA_VERSION,
    70			"tick": 0,
    71			"sent_at": Time.get_datetime_string_from_system(true) + "Z",
    72			"peer": "godot",
    73			"capabilities": [],
    74		}
    75		var err := _ws.send_text(JSON.stringify(payload))
    76		if err != OK:
    77			push_warning("[WS] client handshake send failed: %s" % error_string(err))
    78		else:
    79			_handshake_sent = true
    80			print("[WS] client HandshakeMsg sent")
    81	
    82	
    83	func _schedule_reconnect() -> void:
    84		_should_reconnect = true
    85		_reconnect_timer = RECONNECT_DELAY
    86	
    87	
    88	func _process(delta: float) -> void:
    89		if _should_reconnect:
    90			_reconnect_timer -= delta
    91			if _reconnect_timer <= 0.0:
    92				_connect_to_server()
    93			return
    94	
    95		_ws.poll()
    96		var state := _ws.get_ready_state()
    97		match state:
    98			WebSocketPeer.STATE_OPEN:
    99				if not _connected:
   100					_connected = true
   101					print("[WS] connected to %s" % ws_url)
   102					connection_status_changed.emit(true)
   103				if not _handshake_sent:
   104					_send_client_handshake()
   105				_consume_packets()
   106			WebSocketPeer.STATE_CLOSING:
   107				pass
   108			WebSocketPeer.STATE_CLOSED:
   109				if _connected:
   110					_connected = false
   111					var code := _ws.get_close_code()
   112					var reason := _ws.get_close_reason()
   113					print("[WS] disconnected: code=%d reason=%s" % [code, reason])
   114					connection_status_changed.emit(false)
   115				_schedule_reconnect()
   116	
