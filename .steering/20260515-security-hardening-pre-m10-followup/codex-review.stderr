   867	# =============================================================================
   868	# App factory and lifespan
   869	# =============================================================================
   870	
   871	
   872	@asynccontextmanager
   873	async def _lifespan(app: FastAPI) -> AsyncIterator[None]:
   874	    runtime: _RuntimeLike = app.state.runtime
   875	    registry: Registry = app.state.registry
   876	    task = asyncio.create_task(_broadcaster(runtime, registry), name="broadcaster")
   877	    try:
   878	        yield
   879	    finally:
   880	        task.cancel()
   881	        with contextlib.suppress(asyncio.CancelledError, Exception):
   882	            await task
