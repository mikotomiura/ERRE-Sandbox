   106	class TestWorldRuntimeEnvelopeQueue:
   107	    """SH-5: bounded main queue + coalescing heartbeat queue."""
   108	
   109	    def test_envelope_queue_overflow_emits_warning_and_drops_oldest(
   110	        self, world_harness: RuntimeHarness
   111	    ) -> None:
   112	        runtime = world_harness.runtime
   113	        for i in range(1024):
   114	            runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   115	        runtime.inject_envelope(WorldTickMsg(tick=9999, active_agents=0))
   116	        drained = runtime.drain_envelopes()
   117	        ticks = [e.tick for e in drained if isinstance(e, WorldTickMsg)]
   118	        assert 9999 in ticks
   119	        errors = [e for e in drained if isinstance(e, ErrorMsg)]
   120	        assert len(errors) >= 1
   121	        assert errors[0].code == "runtime_backlog_overflow"
   122	        assert "drops=" in errors[0].detail
   123	        # The very first envelope (tick=0) was dropped to make room.
   124	        assert 0 not in ticks
   125	
   126	    async def test_heartbeat_queue_coalesces_to_latest(
   127	        self, world_harness: RuntimeHarness
   128	    ) -> None:
   129	        runtime = world_harness.runtime
   130	        await runtime._on_heartbeat_tick()
   131	        await runtime._on_heartbeat_tick()
   132	        await runtime._on_heartbeat_tick()
   133	        drained = runtime.drain_envelopes()
   134	        heartbeats = [e for e in drained if isinstance(e, WorldTickMsg)]
   135	        assert len(heartbeats) == 1
   136	
   137	    async def test_recv_envelope_returns_main_and_preserves_heartbeat(
   138	        self, world_harness: RuntimeHarness
   139	    ) -> None:
   140	        """SH-5 Codex 13th HIGH-1: heartbeat must not be silent-dropped when
   141	        both queues are ready at the moment of ``recv_envelope``."""
   142	        runtime = world_harness.runtime
   143	        await runtime._on_heartbeat_tick()
   144	        runtime.inject_envelope(WorldTickMsg(tick=42, active_agents=0))
   145	        first = await runtime.recv_envelope()
   146	        # Main is prioritised: the directly-injected envelope must come
   147	        # back first.
   148	        assert isinstance(first, WorldTickMsg)
   149	        assert first.tick == 42
   150	        # The heartbeat that raced alongside must remain observable on the
   151	        # heartbeat queue.
   152	        drained = runtime.drain_envelopes()
   153	        heartbeats = [e for e in drained if isinstance(e, WorldTickMsg)]
   154	        assert len(heartbeats) == 1
   155	
   156	    # ------------------------------------------------------------------
   157	    # Codex 13th MEDIUM coverage gaps (security-hardening-pre-m10-followup)
   158	    # ------------------------------------------------------------------
   159	    # The four cases below close the boundary / monotonic / cancel /
   160	    # observability gaps the Codex 13th review flagged after PR #170.
   161	    # ``maxsize`` is 1024 in production; the test exercises that exact value
   162	    # rather than a re-bound smaller queue so any regression in the
   163	    # ``qsize() > maxsize - 2`` drain loop surfaces under the live config.
   164	
   165	    def test_envelope_queue_at_maxsize_minus_one_does_not_overflow(
   166	        self, world_harness: RuntimeHarness
   167	    ) -> None:
   168	        """1023 inserts (maxsize=1024 → ``maxsize-1``): no overflow path."""
   169	        runtime = world_harness.runtime
   170	        for i in range(runtime._envelopes.maxsize - 1):
   171	            runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   172	        assert runtime._envelope_overflow_count == 0
   173	        # No warning was enqueued because the queue never hit ``full()``.
   174	        drained = runtime.drain_envelopes()
   175	        assert all(isinstance(env, WorldTickMsg) for env in drained)
   176	
   177	    def test_envelope_queue_at_exact_maxsize_does_not_overflow(
   178	        self, world_harness: RuntimeHarness
   179	    ) -> None:
   180	        """1024 inserts (exact maxsize): boundary stays under overflow."""
   181	        runtime = world_harness.runtime
   182	        for i in range(runtime._envelopes.maxsize):
   183	            runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   184	        # The Nth insert sees the queue not-yet-full pre-put, so it lands
   185	        # without invoking the drop-oldest path.
   186	        assert runtime._envelope_overflow_count == 0
   187	
   188	    def test_envelope_queue_at_maxsize_plus_one_triggers_overflow_once(
   189	        self, world_harness: RuntimeHarness
   190	    ) -> None:
   191	        """1025th insert: overflow path fires exactly once and warning lands."""
   192	        runtime = world_harness.runtime
   193	        for i in range(runtime._envelopes.maxsize):
   194	            runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   195	        assert runtime._envelope_overflow_count == 0
   196	        runtime.inject_envelope(WorldTickMsg(tick=9999, active_agents=0))
   197	        assert runtime._envelope_overflow_count >= 1
   198	        drained = runtime.drain_envelopes()
   199	        errors = [e for e in drained if isinstance(e, ErrorMsg)]
   200	        assert errors
   201	        assert errors[0].code == "runtime_backlog_overflow"
   202	
   203	    def test_repeated_overflow_increments_count_monotonically(
   204	        self, world_harness: RuntimeHarness
   205	    ) -> None:
   206	        """``_envelope_overflow_count`` is monotonically non-decreasing
   207	        across distinct overflow bursts so an SRE timeseries can derive
   208	        rate-of-overflow without rebasing."""
   209	        runtime = world_harness.runtime
   210	        # First burst: drain to room=0, then inject one extra.
   211	        for i in range(runtime._envelopes.maxsize + 1):
   212	            runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   213	        first_burst = runtime._envelope_overflow_count
   214	        assert first_burst >= 1
   215	        # Inject another N+2 envelopes; the queue is full from burst 1, so
   216	        # subsequent inserts continue draining oldest and the counter must
   217	        # keep climbing.
   218	        for i in range(runtime._envelopes.maxsize + 2):
   219	            runtime.inject_envelope(
   220	                WorldTickMsg(tick=10_000 + i, active_agents=0),
   221	            )
   222	        second_burst = runtime._envelope_overflow_count
   223	        assert second_burst > first_burst
   224	
   225	    def test_consume_result_path_uses_drop_oldest_helper(
   226	        self, world_harness: RuntimeHarness
   227	    ) -> None:
   228	        """Both ingress paths funnel through ``_enqueue_with_drop_oldest``.
   229	
   230	        ``inject_envelope`` and ``_consume_result`` share the helper so the
   231	        SH-5 overflow accounting (and SH-FOLLOWUP / Codex 13th MEDIUM
   232	        ``logger.warning`` emission) applies uniformly. Test this by
   233	        priming the queue via ``inject_envelope`` to overflow, then calling
   234	        the helper directly (the same call ``_consume_result`` makes per
   235	        :meth:`WorldRuntime._consume_result.envelopes` loop). The shared
   236	        counter must reflect both calls without rebase.
   237	        """
   238	        runtime = world_harness.runtime
   239	        for i in range(runtime._envelopes.maxsize + 1):
   240	            runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   241	        baseline = runtime._envelope_overflow_count
   242	        # Direct helper invocation models the ``_consume_result`` exit path.
   243	        runtime._enqueue_with_drop_oldest(
   244	            WorldTickMsg(tick=42_000, active_agents=0),
   245	        )
   246	        assert runtime._envelope_overflow_count > baseline
   247	
   248	    def test_overflow_emits_logger_warning_for_sre_observability(
   249	        self,
   250	        world_harness: RuntimeHarness,
   251	        caplog: pytest.LogCaptureFixture,
   252	    ) -> None:
   253	        """Codex 13th MEDIUM: in-band ``ErrorMsg`` is paired with an
   254	        out-of-band ``logger.warning`` so the journal-only SRE pipeline
   255	        catches overflow even when the ErrorMsg consumer is the slow one.
   256	        """
   257	        runtime = world_harness.runtime
   258	        with caplog.at_level(logging.WARNING, logger="erre_sandbox.world.tick"):
   259	            for i in range(runtime._envelopes.maxsize + 1):
   260	                runtime.inject_envelope(WorldTickMsg(tick=i, active_agents=0))
   261	        overflow_records = [
   262	            r
   263	            for r in caplog.records
   264	            if r.levelno == logging.WARNING and "backlog overflow" in r.message
   265	        ]
   266	        assert overflow_records, (
   267	            "expected at least one logger.warning('runtime backlog overflow ...')"
   268	        )
   269	
   270	    async def test_recv_envelope_cancel_releases_resources_cleanly(
   271	        self, world_harness: RuntimeHarness
   272	    ) -> None:
   273	        """A cancelled ``recv_envelope`` must not leave a pending getter
   274	        warning in the loop close path and must not poison either queue."""
   275	        runtime = world_harness.runtime
   276	        task = asyncio.create_task(runtime.recv_envelope())
   277	        # Yield long enough for ``recv_envelope`` to spawn its two
   278	        # internal getters and block on ``asyncio.wait``.
   279	        await asyncio.sleep(0)
   280	        task.cancel()
   281	        with contextlib.suppress(asyncio.CancelledError):
   282	            await task
   283	        # Both queues are still empty — no orphan items left behind by the
   284	        # cancellation race.
   285	        assert runtime._envelopes.qsize() == 0
   286	        assert runtime._heartbeat_envelopes.qsize() == 0

