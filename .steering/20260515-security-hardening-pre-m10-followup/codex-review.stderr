    46	ui = [
    47	    "streamlit>=1.39,<2",
    48	]
    49	# m9-eval-system Tier A/B/C heavy ML deps (Codex MEDIUM-4: keep core
    50	# dependencies lightweight, isolate eval-only stack behind an extras
    51	# group). Install with ``uv sync --extra eval`` on the Mac when running
    52	# tier-a real-model tests; CI default keeps the resolution slim.
    53	eval = [
    54	    "scipy>=1.13,<2",                # bootstrap resample / stats helpers (P5)
    55	    "sentence-transformers>=3,<4",   # MPNet (novelty) + transformers pipeline (NLI)
