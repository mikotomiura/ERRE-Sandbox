   494	class TestWebSocketAuth:
   495	    """SH-2 — Origin / token / session cap connection-time gates.
   496	
   497	    All three gates default to disabled (see :class:`WSAuthConfig`). Each
   498	    test below opts into exactly one gate so the failure mode is isolated.
   499	    """
   500	
   501	    # Shared literal so the S106 noqa only needs to live in one place.
   502	    _TOKEN = "hunter2-shared"  # noqa: S105 — test fixture token literal
