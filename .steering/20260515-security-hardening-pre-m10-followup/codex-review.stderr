   479	def _make_authed_client(
   480	    mock_runtime: MockRuntime,
   481	    auth_config: WSAuthConfig,
   482	) -> TestClient:
   483	    """Build a TestClient whose make_app() was wired with ``auth_config``.
   484	
   485	    Each call returns a fresh TestClient so concurrent tests cannot leak
   486	    registry state between cases. The caller is responsible for using the
   487	    returned client as a context manager so the FastAPI lifespan starts
   488	    the broadcaster task.
   489	    """
   490	    app = make_app(runtime=mock_runtime, auth_config=auth_config)
   491	    return TestClient(app)
