   176	def _envelope_target_agents(env: ControlEnvelope) -> frozenset[str] | None:
   177	    """Extract the set of ``agent_id`` values an envelope is scoped to.
   178	
   179	    Added by ``m4-gateway-multi-agent-stream`` to drive per-session
   180	    subscription filtering. Returns ``None`` when the envelope is global
   181	    (must reach every subscriber regardless of filter).
   182	
   183	    Routing rules:
   184	
   185	    * ``agent_update`` / ``speech`` / ``move`` / ``animation`` — the single
   186	      ``agent_id`` field the envelope carries.
   187	    * ``dialog_initiate`` — both the initiator and target.
   188	    * ``dialog_turn`` — both the speaker and addressee.
   189	    * ``handshake`` / ``world_tick`` / ``error`` / ``dialog_close`` —
   190	      global: handshake is server-originated, world_tick and error are
   191	      session-wide utilities, dialog_close is metadata-only (no
   192	      participant fields on the wire type) so every subscriber needs it
   193	      for UI cleanup.
   194	    """
   195	    if isinstance(env, AgentUpdateMsg):
   196	        return frozenset({env.agent_state.agent_id})
   197	    if isinstance(env, (SpeechMsg, MoveMsg, AnimationMsg)):
   198	        return frozenset({env.agent_id})
   199	    if isinstance(env, DialogInitiateMsg):
   200	        return frozenset({env.initiator_agent_id, env.target_agent_id})
   201	    if isinstance(env, DialogTurnMsg):
   202	        return frozenset({env.speaker_id, env.addressee_id})
   203	    return None
