   139	  policy-grep-gate:
   140	    # SH-1 CI layer (security-hardening-pre-m10-followup): static backstop for
   141	    # the Codex pre_tool_use_policy hook. The hook catches shell-bypass writes
   142	    # at IDE time; this job re-runs the same rules on git diff so a PR cannot
   143	    # reach merge without surfacing a violation. See
   144	    # ``.steering/20260513-security-hardening-pre-m10/decisions.md`` SH-1 and
   145	    # ``.steering/20260515-security-hardening-pre-m10-followup/decisions.md``
   146	    # SH-FOLLOWUP-2 (T201 backstop via ruff re-run, not grep).
   147	    name: policy grep gate (SH-1 backstop)
   148	    runs-on: ubuntu-latest
   149	    timeout-minutes: 5
   150	    steps:
   151	      - uses: actions/checkout@v4
   152	        with:
   153	          # fetch-depth=0 so the ``.steering`` completeness step below can
   154	          # diff against ``origin/main`` even on a fresh PR runner.
   155	          fetch-depth: 0
   156	      - name: Banned imports in src/erre_sandbox/
   157	        run: |
   158	          set -euo pipefail
   159	          if grep -rnE '^[[:space:]]*(import[[:space:]]+(openai|anthropic)|from[[:space:]]+(openai|anthropic))[[:space:]]' \
   160	              src/erre_sandbox/; then
   161	            echo "::error::SH-1: cloud LLM API imports (openai/anthropic) are forbidden inside src/erre_sandbox/"
   162	            exit 1
   163	          fi
   164	          if grep -rnE '^[[:space:]]*(import[[:space:]]+bpy|from[[:space:]]+bpy)' src/erre_sandbox/; then
   165	            echo "::error::SH-1: bpy imports are forbidden inside src/erre_sandbox/ — Blender/GPL stays isolated under erre-sandbox-blender/"
   166	            exit 1
   167	          fi
   168	          echo "[policy-grep-gate] banned-import scan PASS"
   169	      - name: Install uv
   170	        uses: astral-sh/setup-uv@v5
   171	        with:
   172	          enable-cache: true
   173	          python-version-file: .python-version
   174	      - name: Sync dependencies
   175	        run: uv sync --frozen --all-groups
   176	      - name: ruff T201 backstop (SH-FOLLOWUP-2)
   177	        # Re-run ruff with the print rule explicitly selected so the gate
   178	        # fires regardless of whether the main lint job's rule-set drifts.
   179	        # The exemption ``src/erre_sandbox/cli/** = ["T201"]`` in
   180	        # pyproject.toml is honoured automatically, as are inline
   181	        # ``# noqa: T201`` directives — preserving the empirical CI-green
   182	        # baseline (e.g. ``training/train_kant_lora.py:2009``).
   183	        run: uv run ruff check --select T201 src/erre_sandbox
   184	      - name: .steering completeness for impl changes
   185	        run: |
   186	          set -euo pipefail
   187	          base_ref="origin/main"
   188	          if ! git rev-parse --verify --quiet "$base_ref" >/dev/null; then
   189	            # Local push to main / detached HEAD: no diff baseline available;
   190	            # skip the gate (the eval-egress-grep-gate / banned-import step
   191	            # remain in force).
   192	            echo "[policy-grep-gate] skipped: $base_ref not available"
   193	            exit 0
   194	          fi
   195	          changed=$(git diff --name-only "$base_ref"...HEAD -- 'src/erre_sandbox/**/*.py' 2>/dev/null || true)
   196	          if [ -z "$changed" ]; then
   197	            echo "[policy-grep-gate] no src/erre_sandbox/ Python changes; .steering completeness check skipped"
   198	            exit 0
   199	          fi
   200	          # Pick the latest .steering/YYYYMMDD-*/ directory (lexical sort on
   201	          # the date prefix). The CLAUDE.md rule is one directory per task;
   202	          # this check fails loudly only when zero complete task directories
   203	          # exist while impl changes are present.
   204	          recent=$(find .steering -maxdepth 1 -type d -name '[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]-*' 2>/dev/null \
   205	              | sort -r | head -1)
   206	          if [ -z "$recent" ]; then
   207	            echo "::error::SH-1: impl changes in src/erre_sandbox/ require a .steering/YYYYMMDD-task/ directory (none found)"
   208	            exit 1
   209	          fi
   210	          missing=()
   211	          for f in requirement.md design.md tasklist.md; do
   212	            if [ ! -f "$recent/$f" ]; then
   213	              missing+=("$f")
   214	            fi
   215	          done
   216	          if [ ${#missing[@]} -gt 0 ]; then
   217	            echo "::error::SH-1: $recent/ is missing required file(s): ${missing[*]}"
   218	            exit 1
   219	          fi
   220	          echo "[policy-grep-gate] .steering completeness PASS ($recent)"

