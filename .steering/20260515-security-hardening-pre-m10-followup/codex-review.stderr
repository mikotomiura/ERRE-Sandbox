   399	    def test_recv_loop_handles_clean_websocket_disconnect(
   400	        self,
   401	        client: TestClient,
   402	        caplog: pytest.LogCaptureFixture,
   403	    ) -> None:
   404	        """A clean peer-side close (Godot exit, MacBook reconnect) must log at
   405	        DEBUG, not ERROR (live-fix D2).
   406	
   407	        Before the fix, ``WebSocketDisconnect`` propagated out of
   408	        ``_recv_loop`` into the surrounding ``TaskGroup`` as an
   409	        ``ExceptionGroup``; the outer ``except Exception`` then surfaced it
   410	        via ``logger.exception("session %s crashed", ...)`` at ERROR level.
   411	        Live-fix D2 catches the exception inside ``_recv_loop`` and demotes
   412	        it to DEBUG.
   413	        """
   414	        import logging
   415	
   416	        with (
   417	            caplog.at_level(logging.DEBUG, logger="erre_sandbox.integration.gateway"),
   418	            client.websocket_connect("/ws/observe") as ws,
   419	        ):
   420	            _ = _recv_envelope(ws)
   421	            _promote_to_active(ws)
   422	            # Closing the TestClient WS context cleanly disconnects.
   423	
   424	        # Allow the server task to finish logging.
   425	        for _ in range(50):
   426	            if any("peer disconnected" in r.message for r in caplog.records):
   427	                break
   428	            client.portal.call(asyncio.sleep, 0.01)
   429	
   430	        # No "session X crashed" ERROR.
   431	        crashed = [
   432	            r
   433	            for r in caplog.records
   434	            if r.levelno >= logging.ERROR and "crashed" in r.message
   435	        ]
   436	        assert crashed == [], (
   437	            f"clean peer close produced ERROR-level crash log: {crashed}"
   438	        )
   439	
   440	        # The DEBUG-level breadcrumb is present.
   441	        debug_msgs = [
   442	            r
   443	            for r in caplog.records
   444	            if r.levelno == logging.DEBUG and "peer disconnected" in r.message
   445	        ]
   446	        assert debug_msgs, (
   447	            "expected a DEBUG 'peer disconnected' log from recv_loop on clean close"
   448	        )
