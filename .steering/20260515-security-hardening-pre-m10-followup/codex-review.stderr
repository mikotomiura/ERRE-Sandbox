    55	def latest_task(root: Path, *, days: int = 8) -> Path | None:
    56	    steering = root / ".steering"
    57	    if not steering.is_dir():
    58	        return None
    59	    cutoff = dt.datetime.now().timestamp() - (days * 24 * 60 * 60)
    60	    candidates = []
    61	    for item in steering.iterdir():
    62	        if not item.is_dir() or not TASK_RE.match(item.name):
    63	            continue
    64	        try:
    65	            modified = item.stat().st_mtime
    66	        except OSError:
    67	            continue
    68	        if modified >= cutoff:
    69	            candidates.append((modified, item))
    70	    if not candidates:
    71	        return None
    72	    candidates.sort(reverse=True)
    73	    return candidates[0][1]
    74	
    75	
    76	def task_status(task: Path | None) -> dict[str, Any]:
    77	    if task is None:
    78	        return {"task": None, "missing": ["requirement.md", "design.md", "tasklist.md"], "template": False}
    79	    missing = [name for name in ("requirement.md", "design.md", "tasklist.md") if not (task / name).is_file()]
    80	    template = False
    81	    design = task / "design.md"
    82	    if design.is_file():
    83	        try:
    84	            text = design.read_text(encoding="utf-8", errors="replace")
    85	        except OSError:
    86	            text = ""
    87	        template = any(marker in text for marker in DESIGN_TEMPLATE_MARKERS)
    88	    return {"task": task, "missing": missing, "template": template}
