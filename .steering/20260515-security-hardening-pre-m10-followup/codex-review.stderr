    43	def repo_root(payload: dict[str, Any] | None = None) -> Path:
    44	    cwd_value = (payload or {}).get("cwd")
    45	    cwd = Path(cwd_value).expanduser() if isinstance(cwd_value, str) and cwd_value else Path.cwd()
    46	    try:
    47	        result = run(["git", "rev-parse", "--show-toplevel"], cwd=cwd)
    48	    except (OSError, subprocess.SubprocessError):
    49	        return cwd
    50	    if result.returncode == 0 and result.stdout.strip():
    51	        return Path(result.stdout.strip())
