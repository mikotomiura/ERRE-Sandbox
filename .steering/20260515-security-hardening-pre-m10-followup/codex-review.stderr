    31	def run(args: list[str], *, cwd: Path | None = None, timeout: int = 5) -> subprocess.CompletedProcess[str]:
    32	    return subprocess.run(
    33	        args,
    34	        cwd=str(cwd) if cwd else None,
    35	        text=True,
    36	        stdout=subprocess.PIPE,
