   251	def _promote_to_active(ws: Any) -> None:
   252	    """Send the client handshake and consume the M7γ on-connect WorldLayoutMsg.
   253	
   254	    The gateway pushes a single ``world_layout`` envelope between handshake
   255	    validation and registry insertion, so any test that wants to assert
   256	    further runtime-driven envelopes must drain it first. Tests that
   257	    explicitly verify the layout shape should NOT use this helper —
   258	    see ``test_world_layout_msg.py``.
   259	    """
   260	    ws.send_text(_client_hs())
   261	    layout = _recv_envelope(ws)
   262	    assert isinstance(layout, WorldLayoutMsg), (
   263	        f"expected WorldLayoutMsg between handshake and ACTIVE, got {layout!r}"
   264	    )
