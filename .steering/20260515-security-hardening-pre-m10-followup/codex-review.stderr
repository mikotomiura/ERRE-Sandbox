   333	                {
   334	                    "kind": "handshake",
   335	                    "schema_version": "0.0.0-bogus",
   336	                    "tick": 0,
   337	                    "peer": "godot",
   338	                    "capabilities": [],
   339	                    "sent_at": "2026-04-19T00:00:00Z",
   340	                }
   341	            )
   342	            ws.send_text(bad_hs)
   343	            err = _recv_envelope(ws)
   344	            assert isinstance(err, ErrorMsg)
   345	            assert err.code == "schema_mismatch"
   346	            with pytest.raises(WebSocketDisconnect):
   347	                ws.receive_text()
   348	
   349	    def test_first_frame_must_be_handshake(
   350	        self,
   351	        client: TestClient,
   352	    ) -> None:
   353	        with client.websocket_connect("/ws/observe") as ws:
   354	            _ = _recv_envelope(ws)
   355	            # Send a WorldTickMsg first — that's not a handshake.
   356	            ws.send_text(WorldTickMsg(tick=0, active_agents=0).model_dump_json())
   357	            err = _recv_envelope(ws)
   358	            assert isinstance(err, ErrorMsg)
   359	            assert err.code == "invalid_envelope"
   360	            with pytest.raises(WebSocketDisconnect):

