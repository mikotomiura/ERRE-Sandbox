    60	# m9-c-spike — SGLang multi-LoRA serving (CS-1, decisions.md). Pinned to
    61	# the PyPI 2026-04-08 release; G-GEAR install + ``--enable-lora`` smoke
    62	# is verified in Phase K-α (.steering/20260508-m9-c-spike/k-alpha-handoff-prompt.md).
    63	# Kept off the default install — CI runs the SGLang adapter unit tests
    64	# via ``httpx.MockTransport`` so the heavy CUDA wheel stays optional.
    65	inference = [
    66	    "sglang==0.5.10.post1",
    67	]
    68	# m9-c-spike — Bounded Kant LoRA training stack (CS-3..CS-6, decisions.md).
    69	# Phase β (real Kant training) only fires after blockers B-1
    70	# (m9-individual-layer-schema-add) and B-2 (M9-eval P3 採取) clear; the
    71	# adapter scaffold + 4-種 hard-fail gate ship in this PR but consume
