   211	class Registry:
   212	    """Thin per-app lookup of session_id → outbound queue.
   213	
   214	    Not a state machine: the session's state lives in the stack frame of
   215	    :func:`ws_observe`. The registry exists only so that
   216	    :func:`_broadcaster` can find every active outbound queue and
   217	    ``/health`` can report ``active_sessions``.
   218	
   219	    Per-session agent subscription (added by
   220	    ``m4-gateway-multi-agent-stream``) is carried alongside the queue.
   221	    A ``None`` subscription means the session receives every envelope
   222	    (the M2 broadcast default); a frozenset restricts delivery to
   223	    envelopes whose ``_envelope_target_agents`` intersects the set.
   224	    Global envelopes (``world_tick`` / ``error`` / ``dialog_close`` /
   225	    server handshake) bypass the filter unconditionally.
   226	    """
   227	
   228	    def __init__(
   229	        self,
   230	        *,
   231	        max_sessions: int = protocol.MAX_ACTIVE_SESSIONS,
   232	    ) -> None:
   233	        self._queues: dict[str, asyncio.Queue[ControlEnvelope]] = {}
   234	        self._subscriptions: dict[str, frozenset[str] | None] = {}
   235	        self._max_sessions = max_sessions
   236	
   237	    def __len__(self) -> int:
   238	        return len(self._queues)
   239	
   240	    def reserve_slot(
   241	        self,
   242	        session_id: str,
   243	        queue: asyncio.Queue[ControlEnvelope],
   244	        *,
   245	        subscribed_agents: frozenset[str] | None = None,
   246	    ) -> None:
   247	        """Insert a session under the configured cap (SH-2).
   248	
   249	        Raises :class:`erre_sandbox.integration.protocol.SessionCapExceededError`
   250	        when ``len(self) >= max_sessions``. The check is synchronous and
   251	        atomic relative to other registry callers on the same event loop
   252	        (Python's asyncio is single-threaded; there is no concurrent reserve
   253	        between the ``len(...) >= cap`` test and the assignment below).
   254	        """
   255	        if len(self._queues) >= self._max_sessions:
   256	            raise protocol.SessionCapExceededError(
   257	                current=len(self._queues),
   258	                cap=self._max_sessions,
   259	            )
   260	        self._queues[session_id] = queue
   261	        self._subscriptions[session_id] = subscribed_agents
   262	
   263	    def release_slot(self, session_id: str) -> None:
   264	        """Remove a session and free its slot (SH-2)."""
   265	        self.remove(session_id)
   266	
   267	    def add(
   268	        self,
   269	        session_id: str,
   270	        queue: asyncio.Queue[ControlEnvelope],
   271	        *,
   272	        subscribed_agents: frozenset[str] | None = None,
   273	    ) -> None:
