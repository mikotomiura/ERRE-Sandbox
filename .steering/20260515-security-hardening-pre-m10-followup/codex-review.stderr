   185	# 切り替える時のセーフティネットとして残している。
   186	"tests/**" = ["S101", "PLR2004", "D", "ANN", "SLF001", "S311", "TC003", "ERA001", "PLC0415"]
   187	"**/__init__.py" = ["F401", "D104"]
   188	# CLI subcommands intentionally print to stdout/stderr and use argparse
   189	# Namespace at runtime rather than as a TYPE_CHECKING-only import.
   190	"src/erre_sandbox/cli/**" = ["T201", "TC003"]
   191	
   192	[tool.ruff.lint.pydocstyle]
   193	convention = "google"
   194	
   195	[tool.ruff.lint.isort]
   196	known-first-party = ["erre_sandbox"]
   197	
   198	[tool.ruff.format]
   199	quote-style = "double"
   200	indent-style = "space"
   201	docstring-code-format = true
   202	
   203	# =============================================================================
   204	# mypy — src は strict、tests は寛容
   205	# =============================================================================
   206	[tool.mypy]
   207	python_version = "3.11"
   208	strict = true
   209	warn_unused_ignores = true
   210	warn_return_any = false  # T05 完了後に true に昇格 (decisions.md 参照)
   211	plugins = ["pydantic.mypy"]
   212	exclude = ["^\\.venv/", "^build/", "^dist/", "^tools/"]
   213	
