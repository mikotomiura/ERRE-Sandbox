   112	        )
   113	        assert _parse_envelope(raw) is None
   114	
   115	    def test_oversize_multibyte_frame_rejected(self) -> None:
   116	        # F6 regression (codex review 2026-04-28): ``len(raw)`` counts
   117	        # codepoints, not UTF-8 bytes. A payload with chars ≤ limit but
   118	        # encoded bytes > limit must still be rejected so the
   119	        # _MAX_RAW_FRAME_BYTES name actually constrains bytes.
   120	        from erre_sandbox.integration.gateway import _MAX_RAW_FRAME_BYTES
   121	
   122	        char_count = (_MAX_RAW_FRAME_BYTES // 3) + 100
   123	        utterance = "あ" * char_count
   124	        raw = json.dumps(
   125	            {
   126	                "kind": "speech",
   127	                "tick": 0,
   128	                "agent_id": "a",
   129	                "utterance": utterance,
   130	                "zone": "peripatos",
   131	            },
   132	            ensure_ascii=False,
   133	        )
   134	        assert len(raw) <= _MAX_RAW_FRAME_BYTES
   135	        assert len(raw.encode("utf-8")) > _MAX_RAW_FRAME_BYTES
   136	        assert _parse_envelope(raw) is None
   137	
   138	    def test_frame_exactly_at_byte_limit_is_accepted(self) -> None:
   139	        # F6 boundary: a frame whose UTF-8 encoded size equals the limit
   140	        # (not exceeds) must still parse. Guards against off-by-one regression
   141	        # where the byte check turns into ``>=`` instead of ``>``.
   142	        from erre_sandbox.integration.gateway import _MAX_RAW_FRAME_BYTES
   143	
   144	        # Build the JSON envelope first, then pad ``utterance`` so the encoded
   145	        # frame is exactly at the limit.
   146	        scaffold = json.dumps(
   147	            {
   148	                "kind": "speech",
   149	                "tick": 0,
   150	                "agent_id": "a",
   151	                "utterance": "",
   152	                "zone": "peripatos",
   153	            }
   154	        )
   155	        # Each ASCII char added to utterance adds exactly 1 byte to the JSON.
   156	        padding = _MAX_RAW_FRAME_BYTES - len(scaffold.encode("utf-8"))
   157	        raw = json.dumps(
   158	            {
   159	                "kind": "speech",
   160	                "tick": 0,
   161	                "agent_id": "a",
   162	                "utterance": "x" * padding,
   163	                "zone": "peripatos",
   164	            }
   165	        )
   166	        assert len(raw.encode("utf-8")) == _MAX_RAW_FRAME_BYTES
   167	        env = _parse_envelope(raw)
   168	        assert env is not None
   169	        assert isinstance(env, SpeechMsg)
