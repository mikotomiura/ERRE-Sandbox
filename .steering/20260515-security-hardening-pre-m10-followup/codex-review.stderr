    90	    # .steering/20260430-m9-eval-system/design-final.md
    91	    # §"DuckDB 単 file + named schema + 4 層 contract".
    92	    name: eval egress grep gate (no `metrics.` in training paths)
    93	    runs-on: ubuntu-latest
    94	    timeout-minutes: 2
    95	    steps:
    96	      - uses: actions/checkout@v4
    97	      - name: Forbid `metrics.` in training-egress modules
    98	        # Allow-list of paths that read raw_dialog for the LoRA
    99	        # training pipeline. New training egress paths MUST be added
   100	        # here AND covered by the sentinel CI test.
   101	        run: |
   102	          set -euo pipefail
   103	          paths=(
   104	            src/erre_sandbox/cli/export_log.py
   105	            src/erre_sandbox/evidence/eval_store.py
   106	          )
   107	          missing=()
   108	          for p in "${paths[@]}"; do
   109	            if [ ! -f "$p" ]; then missing+=("$p"); fi
   110	          done
   111	          if [ ${#missing[@]} -gt 0 ]; then
   112	            echo "::error::training-egress allow-list points at missing path(s): ${missing[*]}"
   113	            exit 1
   114	          fi
   115	          # Look for any reference to the metrics schema. The
   116	          # ``METRICS_SCHEMA`` constant import is permitted (it's how
   117	          # eval_store guards the boundary), but a literal ``metrics.``
   118	          # qualifier inside a training-egress module is not.
   119	          if grep -nE '"metrics\.|'\''metrics\.' "${paths[@]}"; then
   120	            echo "::error::training-egress module references the metrics schema literally — that is a contract violation (see contracts/eval_paths.py)"
   121	            exit 1
   122	          fi
   123	          # B-1 (m9-individual-layer-schema-add): training-egress
   124	          # modules must not contain a literal that sets
   125	          # ``individual_layer_enabled`` truthy. Codex MEDIUM-1: this
   126	          # grep is a *weak backstop only* — it cannot catch
   127	          # ``setattr``, ``dict.update``, alias assignment, kwargs
   128	          # splats, or comprehensions. The behavioural sentinel test
   129	          # (``tests/test_training/test_train_kant_lora.py::test_assert_phase_beta_ready_blocks_individual_layer_true_via_real_relation``)
   130	          # plus the construction-time aggregate assert in
   131	          # ``_DuckDBRawTrainingRelation.__init__`` are the primary
   132	          # guards. This grep ships as low-cost early warning only.
   133	          if grep -nE 'individual_layer_enabled[[:space:]]*[:=][[:space:]]*(True\b|"true"|1\b)' "${paths[@]}"; then
   134	            echo "::error::training-egress module sets individual_layer_enabled truthy — DB11 / B-1 contract violation"
   135	            exit 1
   136	          fi
