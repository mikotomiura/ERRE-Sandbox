    65	        world_harness.runtime.transition_to_q_and_a()
    66	        after = world_harness.runtime.run_lifecycle
    67	        assert before is not after
    68	        # The old snapshot still carries the pre-transition phase; observers
    69	        # that captured it before the swap retain a stable reading.
    70	        assert before.epoch_phase is EpochPhase.AUTONOMOUS
