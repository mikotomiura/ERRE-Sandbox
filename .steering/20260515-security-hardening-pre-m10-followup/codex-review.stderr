   268	def _maybe_persist_belief(
   269	    *,
   270	    runtime: WorldRuntime,
   271	    memory: MemoryStore,
   272	    agent_id: str,
   273	    other_agent_id: str,
   274	    persona: PersonaSpec,
   275	    addressee_persona: PersonaSpec,
   276	    turn: DialogTurnMsg,
   277	) -> None:
   278	    """Bridge bond mutation → SemanticMemoryRecord upsert when belief gates pass.
   279	
   280	    Pure check delegated to ``cognition.belief.maybe_promote_belief``. The
   281	    sync upsert call lives here (not in tick.py) so the architecture rule
   282	    that ``world/`` does not import ``memory/`` is preserved. Failures
   283	    are logged at warning level — the relational sink is fire-and-forget
   284	    and the cognition cycle must not stall on a semantic-table write.
   285	    """
   286	    rt = runtime._agents.get(agent_id)  # noqa: SLF001 — sink-internal access
   287	    if rt is None:
   288	        return
   289	    bond = next(
   290	        (b for b in rt.state.relationships if b.other_agent_id == other_agent_id),
   291	        None,
   292	    )
   293	    if bond is None:
   294	        return
   295	    record = maybe_promote_belief(
   296	        bond,
   297	        agent_id=agent_id,
   298	        persona=persona,
   299	        addressee_persona=addressee_persona,
   300	    )
   301	    if record is None:
   302	        return
   303	    # M7ζ: stamp ``RelationshipBond.latest_belief_kind`` so the next
   304	    # AgentUpdateMsg snapshot carries the typed classification — the
   305	    # Godot ReasoningPanel reads it from the bond directly. record.belief_kind
   306	    # is non-None at this point because maybe_promote_belief always populates
   307	    # it on a successful promotion (see cognition/belief.py:202).
   308	    if record.belief_kind is not None:
   309	        runtime.apply_belief_promotion(
   310	            agent_id=agent_id,
   311	            other_agent_id=other_agent_id,
   312	            belief_kind=record.belief_kind,
   313	        )
   314	    try:
   315	        memory._upsert_semantic_sync(record)  # noqa: SLF001 — sink-internal sync hook
   316	    except sqlite3.DatabaseError as exc:
   317	        # ``DatabaseError`` is the parent of ``OperationalError`` (lock
   318	        # contention, missing table) plus ``IntegrityError`` (CHECK / UNIQUE
   319	        # violations from a future schema tightening) and the rest of the
   320	        # sqlite3 family. The relational sink is fire-and-forget; any DB
   321	        # error here must be logged and swallowed so the cognition cycle
   322	        # does not stall on a semantic-table write (R4 M3).
   323	        logger.warning(
   324	            "[bootstrap] belief upsert failed for agent=%s other=%s tick=%d: %s",
   325	            agent_id,
   326	            other_agent_id,
   327	            turn.tick,
   328	            exc,
   329	        )
   330	
   331	
   332	def _make_relational_sink(
   333	    *,
   334	    runtime: WorldRuntime,
   335	    memory: MemoryStore,
   336	    persona_registry: dict[str, PersonaSpec],
   337	) -> Callable[[DialogTurnMsg], None]:
   338	    """Build the M7γ per-turn relational-hook sink.
   339	
   340	    Returned callable runs synchronously from
   341	    :class:`InMemoryDialogScheduler.record_turn`: it inserts a
   342	    :class:`MemoryEntry` of kind ``RELATIONAL`` for the speaker and applies
   343	    a :func:`compute_affinity_delta` adjustment to *both* sides'
   344	    :class:`RelationshipBond.affinity` so the dialog turn shows up
   345	    symmetrically in agent state.
   346	
   347	    Sink failures are swallowed inside ``record_turn`` (see
   348	    ``integration/dialog.py:197``); we log warnings here so operators can
   349	    still see them in the journal, but never raise.
   350	    """
   351	
   352	    def _persist_relational_event(turn: DialogTurnMsg) -> None:
   353	        speaker_persona_id = runtime.agent_persona_id(turn.speaker_id)
   354	        speaker_persona = (
   355	            persona_registry.get(speaker_persona_id)
   356	            if speaker_persona_id is not None
   357	            else None
   358	        )
   359	        if speaker_persona is None:
   360	            logger.warning(
   361	                "[bootstrap] relational sink skipped: unresolved speaker "
   362	                "persona for dialog_id=%s speaker=%s",
   363	                turn.dialog_id,
   364	                turn.speaker_id,
   365	            )
   366	            return
   367	        addressee_persona_id = runtime.agent_persona_id(turn.addressee_id)
   368	        addressee_persona = (
   369	            persona_registry.get(addressee_persona_id)
   370	            if addressee_persona_id is not None
   371	            else None
   372	        )
   373	        # M7δ: each side computes its own delta from its own ``prev``
   374	        # (RelationshipBond.affinity at this instant) and from the
   375	        # respective perspective. The semi-formula is asymmetric in
   376	        # ``persona`` (decay/weight follow the perspective-holder's traits)
   377	        # so we cannot share a single delta across sides as M7γ did.
   378	        speaker_prev = runtime.get_bond_affinity(turn.speaker_id, turn.addressee_id)
   379	        delta_speaker = compute_affinity_delta(
   380	            turn,
   381	            recent_transcript=(),
   382	            persona=speaker_persona,
   383	            prev=speaker_prev,
   384	            addressee_persona=addressee_persona,
   385	        )
   386	        if addressee_persona is not None:
   387	            addressee_prev = runtime.get_bond_affinity(
   388	                turn.addressee_id,
   389	                turn.speaker_id,
   390	            )
   391	            delta_addressee = compute_affinity_delta(
   392	                turn,
   393	                recent_transcript=(),
   394	                persona=addressee_persona,
   395	                prev=addressee_prev,
   396	                addressee_persona=speaker_persona,
   397	            )
   398	        else:
   399	            # Defensive: addressee persona unresolved → fall back to the
   400	            # speaker-side delta to keep the bidirectional contract.
   401	            delta_addressee = delta_speaker
   402	        relational_entry = MemoryEntry(
   403	            id=str(uuid.uuid4()),
   404	            agent_id=turn.speaker_id,
   405	            kind=MemoryKind.RELATIONAL,
   406	            content=f"Spoke to {turn.addressee_id}: {turn.utterance}",
   407	            importance=0.5,
   408	            tags=[
   409	                f"dialog:{turn.dialog_id}",
   410	                f"addressee:{turn.addressee_id}",
   411	                f"turn_index:{turn.turn_index}",
   412	            ],
   413	        )
   414	        try:
   415	            memory._add_sync(relational_entry, None)  # noqa: SLF001 — internal sync hook
   416	        except sqlite3.DatabaseError as exc:
   417	            # See ``_maybe_persist_belief`` for the rationale on the
   418	            # ``DatabaseError`` (vs ``OperationalError``) catch (R4 M3).
   419	            logger.warning(
   420	                "[bootstrap] relational memory INSERT failed for "
   421	                "dialog_id=%s tick=%d: %s",
   422	                turn.dialog_id,
   423	                turn.tick,
   424	                exc,
   425	            )
   426	            return
   427	        # Bidirectional bond mutation: each side feels the dialog turn
   428	        # through its own perspective-derived delta. ``zone`` is the
   429	        # speaker's current zone; in γ dialogues require co-location so
   430	        # both participants share the same zone for ``last_interaction_zone``
   431	        # bookkeeping. The accessor returns ``None`` if the agent is
   432	        # transiently unregistered, which propagates harmlessly.
   433	        interaction_zone = runtime.get_agent_zone(turn.speaker_id)
   434	        runtime.apply_affinity_delta(
   435	            agent_id=turn.speaker_id,
   436	            other_agent_id=turn.addressee_id,
   437	            delta=delta_speaker,
   438	            tick=turn.tick,
   439	            zone=interaction_zone,
   440	        )
   441	        runtime.apply_affinity_delta(
   442	            agent_id=turn.addressee_id,
   443	            other_agent_id=turn.speaker_id,
   444	            delta=delta_addressee,
   445	            tick=turn.tick,
   446	            zone=interaction_zone,
   447	        )
   448	        # M7δ: belief promotion bridge (CSDG 2-layer memory). Each side's
   449	        # post-mutation bond may now satisfy the |affinity| × N gates and
   450	        # graduate to a typed SemanticMemoryRecord. Pure-function check
   451	        # in ``cognition.belief`` keeps the layer boundary intact; the
   452	        # sync upsert is owned here so the relational sink stays a single
   453	        # synchronous unit.
   454	        if addressee_persona is not None:
   455	            _maybe_persist_belief(
   456	                runtime=runtime,
   457	                memory=memory,
   458	                agent_id=turn.speaker_id,
   459	                other_agent_id=turn.addressee_id,
   460	                persona=speaker_persona,
   461	                addressee_persona=addressee_persona,
   462	                turn=turn,
   463	            )
   464	            _maybe_persist_belief(
   465	                runtime=runtime,
   466	                memory=memory,
   467	                agent_id=turn.addressee_id,
   468	                other_agent_id=turn.speaker_id,
   469	                persona=addressee_persona,
   470	                addressee_persona=speaker_persona,
   471	                turn=turn,
   472	            )
   473	
   474	    return _persist_relational_event
   475	
   476	
   477	async def bootstrap(cfg: BootConfig) -> None:  # noqa: PLR0915, C901 — composition root inherently long + branchy
   478	    """Construct the full stack and supervise runtime + uvicorn.
   479	
   480	    Resource lifecycle is structured via :class:`AsyncExitStack` so any
   481	    exception during construction (or later during ``TaskGroup``) still
   482	    invokes every ``close`` in LIFO order. OS signals (SIGINT / SIGTERM) are
   483	    caught explicitly; without this the ``uvicorn.Server`` default handler
   484	    intercepts Ctrl-C but the ``WorldRuntime`` task keeps running, which is
   485	    the class of silent failure that T19 spent hours debugging.
   486	    """
   487	    logging.basicConfig(
   488	        level=cfg.log_level.upper(),
   489	        format="%(asctime)s [%(name)s] %(levelname)s: %(message)s",
   490	        # force=True なので、既に handler が登録済 (e.g. pytest caplog) でも
   491	        # bootstrap 呼び出しで root ロガー設定を上書きする。
   492	        force=True,
   493	    )
   494	
   495	    async with AsyncExitStack() as stack:
   496	        memory = MemoryStore(db_path=cfg.db_path)
   497	        # Ensure the sqlite schema exists before any cognition tick runs. Without this
   498	        # the first `Retriever.retrieve(...)` call raises
   499	        # `sqlite3.OperationalError: no such table: episodic_memory`. `create_schema`
   500	        # uses `CREATE TABLE IF NOT EXISTS`, so it is safe to call on every startup.
   501	        memory.create_schema()
   502	        stack.push_async_callback(memory.close)
   503	
   504	        embedding = EmbeddingClient(model=cfg.embed_model, endpoint=cfg.ollama_url)
   505	        stack.push_async_callback(embedding.close)
   506	
   507	        inference = OllamaChatClient(model=cfg.chat_model, endpoint=cfg.ollama_url)
   508	        stack.push_async_callback(inference.close)
   509	
   510	        if cfg.check_ollama:
   511	            logger.info(
   512	                "[bootstrap] health_check %s (model=%s)",
   513	                cfg.ollama_url,
   514	                cfg.chat_model,
   515	            )
   516	            await inference.health_check()
   517	
   518	        retriever = Retriever(memory, embedding)
   519	
   520	        # M8 baseline-quality-metric: persist every ``bias.fired`` firing
   521	        # into sqlite ``bias_events`` so the post-hoc ``baseline-metrics``
   522	        # CLI can compute the bias_fired_rate metric offline. The closure
   523	        # references ``runtime`` by name — Python resolves it lazily at
   524	        # call time, and by that time the ``runtime = WorldRuntime(...)``
   525	        # assignment below has run, so the lookup succeeds. Sink exceptions
   526	        # are caught inside ``_bias_target_zone`` (decisions D5).
   527	        def _persist_bias_event(event: BiasFiredEvent) -> None:
   528	            persona_id = runtime.agent_persona_id(event.agent_id)
   529	            if persona_id is None:
   530	                logger.warning(
   531	                    "[bootstrap] bias_event sink skipped: unresolved persona "
   532	                    "for agent=%s tick=%d",
   533	                    event.agent_id,
   534	                    event.tick,
   535	                )
   536	                return
   537	            memory.add_bias_event_sync(
   538	                tick=event.tick,
   539	                agent_id=event.agent_id,
   540	                persona_id=persona_id,
   541	                from_zone=event.from_zone,
   542	                to_zone=event.to_zone,
   543	                bias_p=event.bias_p,
   544	            )
   545	
   546	        # M7δ R3 M3: persona resolver maps ``speaker_id`` (e.g.
   547	        # ``a_nietzsche_001``) → ``display_name`` (``Friedrich Nietzsche``)
   548	        # so the reflection LLM sees historical names in the "recent peer
   549	        # utterances" block instead of internal agent ids. Built once here
   550	        # and shared across all agents through the Reflector singleton.
   551	        def _resolve_persona_display_name(agent_id: str) -> str | None:
   552	            persona_id = runtime.agent_persona_id(agent_id)
   553	            if persona_id is None:
   554	                return None
   555	            spec = persona_registry.get(persona_id)
   556	            return spec.display_name if spec is not None else None
   557	
   558	        # ``WorldRuntime`` and ``CognitionCycle`` both reference each
   559	        # other indirectly: the cycle's reflector is built with a
   560	        # persona-resolver closure that needs the runtime; the runtime
   561	        # construction below takes the cycle. Build the reflector first
   562	        # with a forward-declaration trampoline so the resolver captures
   563	        # ``runtime`` after assignment.
   564	        reflector = Reflector(
   565	            store=memory,
   566	            embedding=embedding,
   567	            llm=inference,
   568	            persona_resolver=_resolve_persona_display_name,
   569	        )
   570	        cycle = CognitionCycle(
   571	            retriever=retriever,
   572	            store=memory,
   573	            embedding=embedding,
   574	            llm=inference,
   575	            erre_policy=DefaultERREModePolicy(),
   576	            bias_sink=_persist_bias_event,
   577	            reflector=reflector,
   578	        )
   579	        runtime = WorldRuntime(cycle=cycle)
   580	
   581	        # M8 L6-D1: per-turn sink persists every recorded dialog turn into
   582	        # sqlite ``dialog_turns`` for later LoRA-training export. The closure
   583	        # resolves ``agent_id → persona_id`` via ``runtime.agent_persona_id``
   584	        # so the wire schema stays untouched (decisions D2). Sink failures
   585	        # are caught inside ``InMemoryDialogScheduler.record_turn`` so a
   586	        # transient sqlite glitch cannot tear down the live loop.
   587	        def _persist_dialog_turn(turn: DialogTurnMsg) -> None:
   588	            speaker_pid = runtime.agent_persona_id(turn.speaker_id)
   589	            addressee_pid = runtime.agent_persona_id(turn.addressee_id)
   590	            if speaker_pid is None or addressee_pid is None:
   591	                logger.warning(
   592	                    "[bootstrap] dialog_turn sink skipped: unresolved persona for "
   593	                    "dialog_id=%s speaker=%s(%s) addressee=%s(%s)",
   594	                    turn.dialog_id,
   595	                    turn.speaker_id,
   596	                    speaker_pid,
   597	                    turn.addressee_id,
   598	                    addressee_pid,
   599	                )
   600	                return
   601	            # M7ε: stamp the live run-lifecycle epoch onto every persisted
   602	            # turn so ``scaling_metrics.aggregate()`` can drop ``Q_AND_A``
   603	            # turns from relational-saturation metrics (M8 D5 / ADR D3).
   604	            # Reading ``runtime.run_lifecycle`` at sink time makes the
   605	            # value automatically follow ``transition_to_q_and_a()`` when
   606	            # the m9-LoRA Q&A driver lands.
   607	            memory.add_dialog_turn_sync(
   608	                turn,
   609	                speaker_persona_id=speaker_pid,
   610	                addressee_persona_id=addressee_pid,
   611	                epoch_phase=runtime.run_lifecycle.epoch_phase,
   612	            )
   613	
   614	        # M7γ Commit 2: relational hook chain. After the M8 dialog-turn
   615	        # persistence, append a per-turn relational-memory INSERT and a
   616	        # bidirectional :class:`RelationshipBond` affinity update.
   617	        persona_registry = _load_persona_registry(cfg)
   618	        _persist_relational_event = _make_relational_sink(
   619	            runtime=runtime,
   620	            memory=memory,

 succeeded in 0ms:
   280	        well under ``max_sessions`` so this alias's cap enforcement does not
   281	        regress them.
   282	        """
   283	        self.reserve_slot(session_id, queue, subscribed_agents=subscribed_agents)
   284	
   285	    def remove(self, session_id: str) -> None:
   286	        self._queues.pop(session_id, None)
   287	        self._subscriptions.pop(session_id, None)
   288	
   289	    def fan_out(self, env: ControlEnvelope) -> None:
   290	        """Push ``env`` to every registered queue whose subscription matches.
   291	
   292	        If a queue is full we drop the **oldest** item, push a single
   293	        :class:`ErrorMsg` ``backlog_overflow`` warning, then push ``env``.
   294	        This preserves the "latest-wins" behaviour described in the
   295	        integration-contract while keeping memory bounded.
   296	
   297	        Subscription filtering: a session whose ``subscribed_agents`` is
   298	        ``None`` receives every envelope. A non-None subscription receives
   299	        an envelope only when ``_envelope_target_agents(env)`` is ``None``
   300	        (global) or intersects the subscription.
   301	        """
   302	        targets = _envelope_target_agents(env)
   303	        for session_id, queue in list(self._queues.items()):
   304	            subscription = self._subscriptions.get(session_id)
   305	            if (
   306	                subscription is not None
   307	                and targets is not None
   308	                and subscription.isdisjoint(targets)
   309	            ):
   310	                # Session is subscribed to a specific agent set and this
   311	                # envelope is scoped to a disjoint agent set — skip.
   312	                continue
   313	            # Guard against an unbounded (maxsize=0) queue: ``queue.full()``
   314	            # returns False in that case, but the qsize() > maxsize - 2 loop
   315	            # below would drain every queued item if we ever reached it.
   316	            if queue.maxsize > 0 and queue.full():
   317	                # We need room for two items (warning + env), so drop enough
   318	                # oldest entries to bring the queue size to maxsize - 2.
   319	                while queue.qsize() > max(queue.maxsize - 2, 0):
   320	                    try:
   321	                        queue.get_nowait()
   322	                    except asyncio.QueueEmpty:  # pragma: no cover — defensive
   323	                        break
   324	                warning = _make_error(
   325	                    code="backlog_overflow",
   326	                    detail=(
   327	                        f"session {session_id} queue full (maxsize="
   328	                        f"{queue.maxsize}); dropped oldest"
   329	                    ),
   330	                )
   331	                try:
   332	                    queue.put_nowait(warning)
   333	                except asyncio.QueueFull:
   334	                    # maxsize < 2: warning cannot fit, env takes priority.
   335	                    logger.debug(
   336	                        "session %s dropped backlog_overflow warning",
   337	                        session_id,
   338	                    )
   339	            try:
   340	                queue.put_nowait(env)
   341	            except asyncio.QueueFull:  # pragma: no cover — we just made room
   342	                logger.warning("session %s dropped envelope", session_id)
   343	
   344	    def debug_snapshot(self) -> list[dict[str, int]]:
   345	        """Observation of current queue depths — used by ``/health`` and logs."""
   346	        return [
   347	            {
   348	                "session_id_suffix_hash": abs(hash(sid)) % 10_000,
   349	                "queue_depth": q.qsize(),
   350	            }
   351	            for sid, q in self._queues.items()
   352	        ]
   353	
