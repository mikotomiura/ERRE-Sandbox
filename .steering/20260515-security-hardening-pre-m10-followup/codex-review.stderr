   242	def _recv_envelope(ws: Any) -> ControlEnvelope:
   243	    """Helper: TestClient.websocket_connect yields a WS proxy whose receive_text
   244	    returns a string; parse it into a ControlEnvelope via the module adapter."""
   245	    raw = ws.receive_text()
   246	    env = _parse_envelope(raw)
   247	    assert env is not None, f"server frame did not parse: {raw!r}"
   248	    return env
