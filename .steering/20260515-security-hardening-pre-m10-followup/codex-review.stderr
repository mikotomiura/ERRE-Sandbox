     1	"""FSM tests for ``WorldRuntime`` run-level epoch transitions (M8, L6-D3).
     2	
     3	Covers the allowed transition path ``autonomous → q_and_a → evaluation`` and
     4	the disallowed paths (direct skip, reverse, re-transition). Construction
     5	reuses the ``world_harness`` fixture so the runtime is in its default post-
     6	``__init__`` state (``EpochPhase.AUTONOMOUS``) without running any tick.
     7	
     8	The trailing ``TestWorldRuntimeEnvelopeQueue`` class covers the SH-5 hardening
     9	of the runtime envelope queue (2-queue split with bounded main +
    10	coalescing heartbeat).
    11	"""
    12	
    13	from __future__ import annotations
    14	
    15	import asyncio
    16	import contextlib
    17	import logging
    18	from typing import TYPE_CHECKING
    19	
    20	import pytest
    21	
    22	from erre_sandbox.schemas import (
    23	    EpochPhase,
    24	    ErrorMsg,
    25	    RunLifecycleState,
    26	    WorldTickMsg,
    27	)
    28	
    29	if TYPE_CHECKING:
    30	    from .conftest import RuntimeHarness
    31	
    32	
    33	class TestWorldRuntimeLifecycleDefaults:
    34	    def test_defaults_to_autonomous_phase(self, world_harness: RuntimeHarness) -> None:
    35	        state = world_harness.runtime.run_lifecycle
    36	        assert isinstance(state, RunLifecycleState)
    37	        assert state.epoch_phase is EpochPhase.AUTONOMOUS
    38	
    39	    def test_run_lifecycle_property_returns_live_instance(
    40	        self, world_harness: RuntimeHarness
    41	    ) -> None:
    42	        """Property returns the current instance so observers can snapshot it."""
    43	        first = world_harness.runtime.run_lifecycle
    44	        second = world_harness.runtime.run_lifecycle
    45	        assert first is second
    46	
    47	
    48	class TestWorldRuntimeLifecycleAllowedTransitions:
    49	    def test_autonomous_to_q_and_a(self, world_harness: RuntimeHarness) -> None:
    50	        result = world_harness.runtime.transition_to_q_and_a()
    51	        assert result.epoch_phase is EpochPhase.Q_AND_A
    52	        assert world_harness.runtime.run_lifecycle.epoch_phase is EpochPhase.Q_AND_A
    53	
    54	    def test_q_and_a_to_evaluation(self, world_harness: RuntimeHarness) -> None:
    55	        world_harness.runtime.transition_to_q_and_a()
    56	        result = world_harness.runtime.transition_to_evaluation()
    57	        assert result.epoch_phase is EpochPhase.EVALUATION
    58	        assert world_harness.runtime.run_lifecycle.epoch_phase is EpochPhase.EVALUATION
    59	
    60	    def test_transition_replaces_lifecycle_instance(
    61	        self, world_harness: RuntimeHarness
    62	    ) -> None:
