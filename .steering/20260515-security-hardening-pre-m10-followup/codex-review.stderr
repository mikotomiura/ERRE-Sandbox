   102	    "pytest-asyncio>=0.24,<1",
   103	]
   104	dev = [
   105	    { include-group = "lint" },
   106	    { include-group = "typecheck" },
   107	    { include-group = "test" },
   108	]
   109	
   110	# m9-c-spike — sglang==0.5.10.post1 ([inference]) ships its own
   111	# transformers==5.3.0 pin which collides with both [training] (peft +
   112	# transformers>=4.45,<5) and [eval] (sentence-transformers requires
   113	# transformers<5). Operationally these stacks never co-reside on the
   114	# same GPU host anyway: training runs first (peft saves a checkpoint),
   115	# then the SGLang server boots with the adapter loaded, and Tier C
   116	# judge LLM (eval, ollama-based) lives in a separate process. uv
   117	# ``conflicts`` splits the lockfile universe pairwise so the resolver
   118	# can pin transformers per-extra without forcing a single global
   119	# version. Callers run ``uv sync --extra inference`` or
   120	# ``uv sync --extra training`` (and may combine training+eval) but not
   121	# inference+training or inference+eval. Adapter unit tests use
   122	# httpx.MockTransport and do not import sglang, so CI default install
   123	# (no extras) still exercises the SGLangChatClient surface.
   124	[tool.uv]
   125	# sglang==0.5.10.post1 transitively requires flash-attn-4>=4.0.0b4
   126	# (pre-release). uv's default prerelease policy rejects unsolicited
   127	# pre-releases; allow them so the [inference] universe can resolve.
   128	# This only affects the [inference] extras universe — core / [eval] /
   129	# [training] resolutions still prefer stable releases by other constraints.
   130	prerelease = "allow"
   131	conflicts = [
   132	    [
   133	        { extra = "inference" },
   134	        { extra = "training" },
   135	    ],
   136	    [
   137	        { extra = "inference" },
   138	        { extra = "eval" },
   139	    ],
   140	]
