   179	def _resolve_agents(
   180	    personas_arg: str | None, personas_dir: Path
   181	) -> tuple[AgentSpec, ...]:
   182	    """Expand the ``--personas`` CLI value into a tuple of :class:`AgentSpec`.
   183	
   184	    Returns an empty tuple when the argument is absent so
   185	    :class:`BootConfig.__post_init__` can supply the 1-Kant default.
   186	    Each referenced persona YAML must exist and parse; loud failure here
   187	    is preferable to a confusing error mid-startup.
   188	    """
   189	    if personas_arg is None:
   190	        return ()
   191	    if yaml is None:
   192	        msg = "PyYAML is required for --personas resolution but is not installed"
   193	        raise RuntimeError(msg)
   194	    ids = [token.strip() for token in personas_arg.split(",") if token.strip()]
   195	    if not ids:
   196	        return ()
   197	    specs: list[AgentSpec] = []
   198	    for pid in ids:
