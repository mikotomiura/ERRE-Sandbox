   184	    def test_fan_out_pushes_to_every_queue(self) -> None:
   185	        reg = Registry()
   186	        q1: asyncio.Queue[ControlEnvelope] = asyncio.Queue(maxsize=4)
   187	        q2: asyncio.Queue[ControlEnvelope] = asyncio.Queue(maxsize=4)
