   164	    subparsers = parser.add_subparsers(
   165	        dest="subcommand",
   166	        required=True,
   167	        metavar="{export-log,baseline-metrics,scaling-metrics}",
   168	    )
   169	    export_log.register(subparsers)
   170	    baseline_metrics.register(subparsers)
   171	    scaling_metrics.register(subparsers)
   172	    return parser
