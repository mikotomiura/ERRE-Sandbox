   355	# =============================================================================
   356	# Pure helpers (no I/O)
   357	# =============================================================================
   358	
   359	
   360	def _make_server_handshake() -> HandshakeMsg:
   361	    return HandshakeMsg(
   362	        tick=0,
   363	        peer="g-gear",
   364	        capabilities=list(_SERVER_CAPABILITIES),
   365	    )
   366	
   367	
   368	def _make_error(*, code: str, detail: str, tick: int = 0) -> ErrorMsg:
   369	    return ErrorMsg(tick=tick, code=code, detail=detail)
   370	
   371	
   372	class _InvalidSubscribeError(ValueError):
   373	    """Raised when ``?subscribe=`` violates a limit.
   374	
   375	    Kept as a dedicated subclass so ``ws_observe`` can distinguish
   376	    subscription errors from other client-side faults and surface a
   377	    specific error code without catching bare ``ValueError`` (which would
   378	    also catch downstream bugs).
   379	    """
   380	
   381	
   382	_SUBSCRIBE_ID_PATTERN: Final[re.Pattern[str]] = re.compile(r"\A[A-Za-z0-9_-]+\Z")
   383	"""Allowed character class for a single ``?subscribe=`` item.
   384	
   385	Matches the kebab-case / snake-case slug shape of ``PersonaSpec.persona_id``
   386	and rejects control characters, whitespace, path separators, and any
   387	Unicode that could be abused for log injection or impersonation.
   388	"""
   389	
   390	
   391	def _parse_subscribe_param(raw: str | None) -> frozenset[str] | None:
   392	    """Translate the ``?subscribe=`` URL param into a subscription set.
   393	
   394	    Returns ``None`` (broadcast) when:
   395	
   396	    * the param is absent, empty, or exactly ``*``.
   397	
   398	    Returns a ``frozenset`` of persona ids when the param is a comma-
   399	    separated list of non-empty slugs. Raises :class:`_InvalidSubscribeError`
   400	    if any limit is violated — the caller surfaces this as an
   401	    ``invalid_subscribe`` :class:`ErrorMsg` and closes the handshake.
   402	    """
   403	    if raw is None or raw in {"", "*"}:
   404	        return None
   405	    # O(1) byte-length pre-check before ``split``. Defends against a
   406	    # permissive reverse proxy passing through multi-MB query strings
   407	    # that would otherwise allocate a long list of short strings.
   408	    if len(raw) > protocol.MAX_SUBSCRIBE_RAW_LENGTH:
   409	        raise _InvalidSubscribeError(
   410	            f"subscribe param is {len(raw)} chars, max is "
   411	            f"{protocol.MAX_SUBSCRIBE_RAW_LENGTH}",
   412	        )
   413	    items = [x.strip() for x in raw.split(protocol.SUBSCRIBE_DELIMITER) if x.strip()]
   414	    if not items:
   415	        return None
   416	    if len(items) > protocol.MAX_SUBSCRIBE_ITEMS:
   417	        raise _InvalidSubscribeError(
   418	            f"subscribe has {len(items)} items, max is {protocol.MAX_SUBSCRIBE_ITEMS}",
   419	        )
   420	    for item in items:
   421	        if len(item) > protocol.MAX_SUBSCRIBE_ID_LENGTH:
   422	            raise _InvalidSubscribeError(
   423	                f"subscribe item {item[:20]!r}… exceeds "
   424	                f"{protocol.MAX_SUBSCRIBE_ID_LENGTH} chars",
   425	            )
   426	        if not _SUBSCRIBE_ID_PATTERN.match(item):
   427	            # Reject control chars / whitespace / unicode / path separators
   428	            # before they reach the log pipeline. persona_id is a slug
   429	            # (PersonaSpec) so any non-matching item is also a routing miss.
   430	            raise _InvalidSubscribeError(
   431	                f"subscribe item {item[:20]!r}… must match "
   432	                f"[A-Za-z0-9_-]+ (persona_id slug)",
   433	            )
   434	    return frozenset(items)
   435	
   436	
   437	def _parse_envelope(raw: str) -> ControlEnvelope | None:
   438	    """Parse a client frame into a :class:`ControlEnvelope` or return ``None``.
   439	
   440	    Returns ``None`` on:
   441	
   442	    * frame size > :data:`_MAX_RAW_FRAME_BYTES`;
   443	    * JSON or Pydantic validation failure.
   444	
   445	    Callers are expected to follow a ``None`` with an
   446	    :class:`ErrorMsg` ``invalid_envelope`` (one-shot warning, not a close).
   447	    """
   448	    # Cheap char-length upper bound first (chars >= bytes for ASCII;
   449	    # rejects ASCII-only DoS payloads without paying for an encode() copy).
   450	    if len(raw) > _MAX_RAW_FRAME_BYTES:
   451	        return None
   452	    # Multibyte safety (codex F1 followup, 2026-04-28): chars <= limit but
   453	    # UTF-8 bytes can still exceed it (e.g. 3-byte CJK characters), so a
   454	    # precise byte check enforces what _MAX_RAW_FRAME_BYTES actually claims.
   455	    if len(raw.encode("utf-8")) > _MAX_RAW_FRAME_BYTES:
   456	        return None
   457	    try:
   458	        return _ENVELOPE_ADAPTER.validate_json(raw)
   459	    except ValidationError:
   460	        return None
   461	
   462	
   463	# =============================================================================
   464	# I/O helpers
   465	# =============================================================================
   466	
   467	
   468	async def _send(ws: WebSocket, env: ControlEnvelope) -> None:
   469	    await ws.send_text(env.model_dump_json())
   470	
   471	
   472	async def _send_error(ws: WebSocket, *, code: str, detail: str) -> None:
   473	    try:
   474	        await _send(ws, _make_error(code=code, detail=detail))
   475	    except Exception:  # noqa: BLE001 — best-effort, the socket may already be gone
   476	        logger.debug("could not surface ErrorMsg(%s) — socket likely closed", code)
   477	
   478	
   479	# =============================================================================
   480	# WS handler loops (called from ws_observe TaskGroup)
   481	# =============================================================================
   482	
   483	
   484	async def _recv_loop(ws: WebSocket) -> None:
   485	    """Drain client → server frames and enforce idle-disconnect.
   486	
   487	    The idle timer is expressed as a nested :func:`asyncio.timeout` around
   488	    every :meth:`WebSocket.receive_text`; each successful receive resets it.
   489	    On timeout we surface an :class:`ErrorMsg` and raise
   490	    :class:`_GracefulCloseError` so the surrounding TaskGroup exits cleanly.
   491	
   492	    For M2 clients may only meaningfully send :class:`HandshakeMsg` (already
   493	    consumed before ACTIVE). Other parsed envelopes are logged as a
   494	    warning but otherwise ignored; unparsable frames trigger a one-shot
   495	    ``invalid_envelope`` warning without closing.
   496	    """
   497	    while True:
   498	        try:
   499	            async with asyncio.timeout(protocol.IDLE_DISCONNECT_S):
   500	                raw = await ws.receive_text()
   501	        except TimeoutError:
   502	            await _send_error(
   503	                ws,
   504	                code="idle_disconnect",
   505	                detail=f"no client frame for {protocol.IDLE_DISCONNECT_S}s",
   506	            )
   507	            raise _GracefulCloseError from None
   508	        except WebSocketDisconnect as exc:
   509	            # Peer closed the socket cleanly (1000) or mid-session (1001/1006).
   510	            # All three are normal Godot lifecycles: the MacBook editor exits
   511	            # autonomously between live runs, and re-attaching produces a
   512	            # fresh session. Demoting to DEBUG so a 360s run with several
   513	            # reconnects no longer floods ERROR via the surrounding TaskGroup
   514	            # (live-fix D2).
   515	            logger.debug(
   516	                "session recv_loop: peer disconnected (code=%s) — exiting cleanly",
   517	                getattr(exc, "code", "unknown"),
   518	            )
   519	            raise _GracefulCloseError from exc
   520	        env = _parse_envelope(raw)
   521	        if env is None:
   522	            await _send_error(
   523	                ws,
   524	                code="invalid_envelope",
   525	                detail="frame too large or failed ControlEnvelope validation",
   526	            )
   527	            continue
   528	        if env.kind == "handshake":
   529	            logger.debug("duplicate handshake after ACTIVE — ignored")
   530	        else:
   531	            logger.debug("client pushed %s envelope (ignored in M2)", env.kind)
   532	
   533	
   534	async def _send_loop(
   535	    ws: WebSocket,
   536	    queue: asyncio.Queue[ControlEnvelope],
   537	) -> None:
   538	    """Drain the per-session outbound queue and write each envelope to the socket.
   539	
   540	    We do not implement batching — envelope sizes are small (<1 KB) and
   541	    Godot's client decodes one frame at a time, so the cost/benefit does not
   542	    favour batching at this stage.
   543	    """
   544	    while True:
   545	        env = await queue.get()
   546	        try:
   547	            await _send(ws, env)
   548	        except WebSocketDisconnect:
   549	            raise _GracefulCloseError from None
   550	        except (OSError, RuntimeError) as exc:
   551	            # Covers "WebSocket is not connected" and the lower-level OSErrors
   552	            # Starlette can surface when the peer vanishes mid-write. Logging
   553	            # here (rather than letting the TaskGroup surface an opaque
   554	            # ExceptionGroup) makes the close reason observable.
   555	            logger.debug("session send_loop terminating: %s", exc)
   556	            raise _GracefulCloseError from exc
   557	
   558	
   559	# =============================================================================
   560	# Broadcaster task — started by the lifespan context manager
   561	# =============================================================================
   562	
   563	
   564	async def _broadcaster(runtime: _RuntimeLike, registry: Registry) -> None:
   565	    """Forward every envelope produced by the runtime to all active sessions.
   566	
   567	    The loop lives for the lifetime of the ASGI app (started by
   568	    :func:`_lifespan`) and is cancelled on shutdown. Per-session back-pressure
   569	    is handled by :meth:`Registry.fan_out`; exceptions raised here are
   570	    intentionally surfaced so an operator notices a broken runtime source.
   571	    """
   572	    while True:
   573	        env = await runtime.recv_envelope()
   574	        registry.fan_out(env)
   575	
   576	
   577	# =============================================================================
   578	# WebSocket endpoint — the session state machine
   579	# =============================================================================
   580	
   581	
   582	async def ws_observe(  # noqa: C901, PLR0911, PLR0912, PLR0915 — protocol state machine inherently long
   583	    ws: WebSocket,
   584	) -> None:
   585	    """Top-level WS handler. Also the session state machine.
   586	
   587	    The three protocol phases map onto the function's linear control flow:
   588	
   589	    * **AWAITING_HANDSHAKE** — from :meth:`accept` up to the point we have
   590	      parsed the client :class:`HandshakeMsg` and its ``schema_version``
   591	      matches. Timeouts and mismatches surface an ErrorMsg and ``return``
   592	      before we ever touch the registry.
   593	    * **ACTIVE** — the TaskGroup section. The session queue is created here,
   594	      inserted into the registry, and removed in ``finally``.
   595	    * **CLOSING** — the outer ``finally`` blocks; ``ws.close()`` is attempted
   596	      best-effort so an already-closed socket does not raise.
   597	
   598	    SH-2 adds three independent connection-time gates **before** ``accept``:
   599	    Origin allow-list, shared-token (constant-time compare), and session
   600	    cap pre-check. Each gate closes the socket with the appropriate
   601	    WebSocket close code without consuming resources or notifying the peer
   602	    of a successful upgrade.
   603	    """
   604	    # runtime lives on app.state for the broadcaster; the handler itself
   605	    # does not need a direct reference, so we only look up the registry here.
   606	    registry: Registry = ws.app.state.registry
   607	    auth: WSAuthConfig = ws.app.state.ws_auth
   608	    session_id = secrets.token_hex(8)
   609	
   610	    # ---------- SH-2: pre-accept connection gates ----------
   611	    # Reject before accept so a denied peer never sees a successful WS
   612	    # upgrade. ``ws.close(code=...)`` issued before ``accept()`` is mapped
   613	    # by Starlette to an HTTP 403 response that carries the close code,
   614	    # which is what well-behaved WS clients (and curl probes) interpret as
   615	    # an unambiguous policy decision.
   616	
   617	    # Layer 1 — Origin allow-list (empty tuple ⇒ check disabled).
   618	    if auth.allowed_origins:
   619	        origin = ws.headers.get("origin", "")
   620	        if origin not in auth.allowed_origins:
   621	            logger.warning(
   622	                "session %s: rejected origin %r (allowed=%s)",
   623	                session_id,
   624	                origin,
   625	                auth.allowed_origins,
   626	            )
   627	            with contextlib.suppress(Exception):
   628	                await ws.close(code=1008)  # Policy Violation
   629	            return
   630	
   631	    # Layer 2 — Shared-token check (``require_token=False`` ⇒ gate disabled,
   632	    # back-compat with Mac↔G-GEAR LAN workflow).
   633	    if auth.require_token:
   634	        presented = ws.headers.get(WS_TOKEN_HEADER, "")
   635	        # Defence-in-depth: if bootstrap.py allowed ``require_token=True``
   636	        # without a token, treat every connection as unauthorised rather
   637	        # than crash. Bootstrap's startup validation should catch this
   638	        # earlier; this branch is the runtime backstop.
   639	        token = auth.token or ""
   640	        if not token or not secrets.compare_digest(presented, token):
   641	            logger.warning(
   642	                "session %s: WS token mismatch (require_token=True)",
   643	                session_id,
   644	            )
   645	            with contextlib.suppress(Exception):
   646	                await ws.close(code=1008)  # Policy Violation
   647	            return
   648	
   649	    # Layer 3 — Session cap pre-check (fast path; ``reserve_slot`` below is
   650	    # the authoritative race-safe gate).
   651	    if len(registry) >= auth.max_sessions:
   652	        logger.warning(
   653	            "session %s: cap reached (%d/%d)",
   654	            session_id,
   655	            len(registry),
   656	            auth.max_sessions,
   657	        )
   658	        with contextlib.suppress(Exception):
   659	            await ws.close(code=1013)  # Try Again Later
   660	        return
