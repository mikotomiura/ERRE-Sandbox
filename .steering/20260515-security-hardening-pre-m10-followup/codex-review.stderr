     1	"""SH-1 red-team tests for the ``pre_tool_use_policy.py`` Codex hook.
     2	
     3	The hook gates ``exec_command`` / ``Bash`` tool calls that would write into
     4	``src/erre_sandbox/`` via shell redirects, ``sed -i``, ``tee``, heredocs,
     5	or inline Python literals. Each case below invokes the hook as a fresh
     6	subprocess with a synthetic Codex-style payload on stdin and asserts the
     7	hook emits the JSON ``permissionDecision="deny"`` envelope (the canonical
     8	Codex hook protocol; the helper-level ``deny()`` returns exit 0 with the
     9	structured stdout so downstream telemetry stays parseable).
    10	"""
    11	
    12	from __future__ import annotations
    13	
    14	import json
    15	import subprocess
    16	import sys
    17	from pathlib import Path
    18	from typing import Any
    19	
    20	import pytest
    21	
    22	REPO_ROOT = Path(__file__).resolve().parents[2]
    23	HOOK_PATH = REPO_ROOT / ".codex" / "hooks" / "pre_tool_use_policy.py"
    24	
    25	
    26	def _invoke_hook(payload: dict[str, Any]) -> dict[str, Any]:
    27	    """Run the hook as a fresh subprocess and parse its JSON stdout.
    28	
    29	    The hook contract is ``exit 0`` + JSON ``permissionDecision`` envelope
    30	    in stdout (Codex protocol). The subprocess is run with the project
    31	    repo root as CWD so ``repo_root`` / ``latest_task`` resolve to the
    32	    live ``.steering/`` tree and the SH-1 guard fires on its own merit
    33	    rather than via the ``.steering`` completeness fallback.
    34	    """
    35	    result = subprocess.run(  # noqa: S603 — fixed argv to the in-repo hook
    36	        [sys.executable, str(HOOK_PATH)],
    37	        input=json.dumps(payload),
    38	        capture_output=True,
    39	        text=True,
    40	        timeout=10,
    41	        cwd=str(REPO_ROOT),
    42	        check=False,
    43	    )
    44	    assert result.returncode == 0, (
    45	        f"hook returncode={result.returncode}\n"
    46	        f"stderr={result.stderr}\nstdout={result.stdout}"
    47	    )
    48	    stdout = result.stdout.strip()
    49	    if not stdout:
    50	        # Allow path: ``main()`` returns 0 without writing to stdout when no
    51	        # rule fires. Tests checking benign commands should see this branch.
    52	        return {}
    53	    try:
    54	        return json.loads(stdout)
    55	    except json.JSONDecodeError as exc:  # pragma: no cover — diagnostic only
    56	        pytest.fail(f"hook stdout not JSON: {stdout!r} (err={exc})")
    57	
    58	
    59	def _assert_deny(envelope: dict[str, Any], *, contains: str) -> None:
    60	    """Helper: assert the hook envelope is a deny mentioning ``contains``."""
    61	    hook_output = envelope.get("hookSpecificOutput", {})
    62	    assert hook_output.get("permissionDecision") == "deny", envelope
    63	    reason = hook_output.get("permissionDecisionReason", "")
    64	    assert contains in reason, (
    65	        f"expected deny reason to mention {contains!r}, got {reason!r}"
    66	    )
    67	
    68	
    69	# ---------------------------------------------------------------------------
    70	# Red-team: 5 canonical shell-write techniques the hook must block.
    71	# ---------------------------------------------------------------------------
    72	
    73	
    74	def test_sed_in_place_into_impl_is_denied() -> None:
    75	    """``sed -i`` rewriting an impl file is denied (in-place edit bypass)."""
    76	    payload = {
    77	        "tool": "exec_command",
    78	        "tool_input": {
    79	            "command": (
    80	                "sed -i 's/from typing/from typing\\nimport openai/' "
    81	                "src/erre_sandbox/inference/sglang_adapter.py"
    82	            ),
    83	        },
    84	        "cwd": str(REPO_ROOT),
    85	    }
    86	    envelope = _invoke_hook(payload)
    87	    _assert_deny(envelope, contains="SH-1")
    88	
    89	
    90	def test_echo_append_into_impl_is_denied() -> None:
    91	    """``echo "..." >> PATH`` redirected into an impl file is denied."""
    92	    payload = {
    93	        "tool": "exec_command",
    94	        "tool_input": {
    95	            "command": ('echo "import bpy" >> src/erre_sandbox/world/tick.py'),
    96	        },
    97	        "cwd": str(REPO_ROOT),
    98	    }
    99	    envelope = _invoke_hook(payload)
   100	    _assert_deny(envelope, contains="SH-1")
   101	
   102	
   103	def test_tee_into_impl_is_denied() -> None:
   104	    """``tee PATH`` writing to an impl file is denied (even with empty stdin)."""
   105	    payload = {
   106	        "tool": "exec_command",
   107	        "tool_input": {
   108	            "command": "tee src/erre_sandbox/x.py < /dev/null",
   109	        },
   110	        "cwd": str(REPO_ROOT),
   111	    }
   112	    envelope = _invoke_hook(payload)
   113	    _assert_deny(envelope, contains="SH-1")
   114	
   115	
   116	def test_python_dash_c_open_write_into_impl_is_denied() -> None:
   117	    """``python -c "open(PATH, 'w').write(...)"`` is denied."""
   118	    payload = {
   119	        "tool": "exec_command",
   120	        "tool_input": {
   121	            "command": (
   122	                "python -c \"open('src/erre_sandbox/y.py','w').write('print(1)')\""
   123	            ),
   124	        },
   125	        "cwd": str(REPO_ROOT),
   126	    }
   127	    envelope = _invoke_hook(payload)
   128	    _assert_deny(envelope, contains="SH-1")
   129	
   130	
   131	def test_cat_heredoc_into_impl_is_denied() -> None:
   132	    """``cat > PATH << EOF ... EOF`` heredoc into an impl file is denied."""
   133	    payload = {
   134	        "tool": "exec_command",
   135	        "tool_input": {
   136	            "command": ("cat > src/erre_sandbox/z.py <<EOF\nimport anthropic\nEOF"),
   137	        },
   138	        "cwd": str(REPO_ROOT),
   139	    }
   140	    envelope = _invoke_hook(payload)
   141	    _assert_deny(envelope, contains="SH-1")
   142	
   143	
   144	# ---------------------------------------------------------------------------
   145	# Negative path: benign shell commands must NOT be denied by the SH-1 gate.
   146	# ---------------------------------------------------------------------------
   147	
   148	
   149	def test_grep_into_impl_is_allowed() -> None:
   150	    """Read-only ``grep src/erre_sandbox/...`` does not match write patterns."""
   151	    payload = {
   152	        "tool": "exec_command",
   153	        "tool_input": {
   154	            "command": "grep -rn 'WorldRuntime' src/erre_sandbox/world",
   155	        },
   156	        "cwd": str(REPO_ROOT),
   157	    }
   158	    envelope = _invoke_hook(payload)
   159	    # No write into impl → empty target_map → main() returns 0 with empty
   160	    # stdout. JSON parse of an empty stdout raises — handle that fall-back.
   161	    hook_output = envelope.get("hookSpecificOutput") if envelope else None
   162	    if hook_output is not None:
   163	        # If the hook emitted anything, it must NOT be a deny for SH-1.
   164	        decision = hook_output.get("permissionDecision")
   165	        if decision == "deny":
   166	            reason = hook_output.get("permissionDecisionReason", "")
   167	            assert "SH-1" not in reason, (
   168	                "grep read-only command must not trip the SH-1 shell-write guard"
   169	            )
   170	
   171	
   172	def test_shell_write_outside_impl_is_allowed() -> None:
   173	    """Writing to /tmp or var/ via shell is allowed (not in src/erre_sandbox/)."""
   174	    payload = {
   175	        "tool": "exec_command",
   176	        "tool_input": {
   177	            "command": 'echo "junk" > /tmp/scratch.txt',
   178	        },
   179	        "cwd": str(REPO_ROOT),
   180	    }
   181	    envelope = _invoke_hook(payload)
   182	    hook_output = envelope.get("hookSpecificOutput") if envelope else None
   183	    if hook_output is not None:
   184	        decision = hook_output.get("permissionDecision")
   185	        if decision == "deny":
   186	            reason = hook_output.get("permissionDecisionReason", "")
   187	            assert "SH-1" not in reason, (
   188	                "shell-write to /tmp must not trip the SH-1 src/erre_sandbox/ guard"
   189	            )

