    96	    )
    97	    parser.add_argument(
    98	        "--personas",
    99	        default=None,
   100	        help=(
   101	            "Comma-separated persona_ids to boot as parallel agents, e.g. "
   102	            "'kant,nietzsche,rikyu'. Each persona's first preferred_zone is "
   103	            "used as its initial_zone. Omit for the default 1-Kant config."
   104	        ),
   105	    )
   106	    # SH-2 — WS connection-time auth gates. All three default to disabled
   107	    # for back-compat (Mac↔G-GEAR LAN, no Origin / no token). ``bootstrap``
   108	    # refuses to start with ``host=0.0.0.0`` plus all three gates off so a
   109	    # bare ``--host=0.0.0.0`` cannot silently expose the server.
