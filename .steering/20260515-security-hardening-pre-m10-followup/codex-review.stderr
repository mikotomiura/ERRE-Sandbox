   721	    Uses ``asyncio.wait(FIRST_COMPLETED)`` rather than ``TaskGroup`` so that
   722	    a runtime exception propagates after graceful uvicorn shutdown instead
   723	    of being wrapped in ``ExceptionGroup`` (which is noisier at the CLI).
   724	    """
   725	    runtime_task = asyncio.create_task(runtime.run(), name="world-runtime")
   726	    server_task = asyncio.create_task(server.serve(), name="uvicorn")
   727	    stop_task = asyncio.create_task(stop_event.wait(), name="signal-wait")
   728	
   729	    done, pending = await asyncio.wait(
   730	        {runtime_task, server_task, stop_task},
   731	        return_when=asyncio.FIRST_COMPLETED,
   732	    )
   733	
   734	    # Trigger graceful shutdown of both tasks regardless of who finished first.
   735	    server.should_exit = True
   736	    runtime.stop()
   737	
   738	    # The stop_task is a pure ``stop_event.wait()`` — if we didn't exit via
   739	    # signal, it will never complete, so cancel it explicitly before awaiting.
   740	    if not stop_task.done():
   741	        stop_task.cancel()
   742	
   743	    awaitables: list[Awaitable[object]] = list(pending)
   744	    for task in awaitables:
   745	        try:
   746	            await task
   747	        except asyncio.CancelledError:
   748	            # Expected: we cancelled runtime_task via runtime.stop() above,
   749	            # or stop_task via the explicit cancel() just above.
   750	            pass
   751	        except Exception:
   752	            # Unexpected: log so operators can debug instead of swallowing
   753	            # the failure silently (T19 ghost session class of bugs).
   754	            logger.exception(
   755	                "pending task %s raised during shutdown",
   756	                getattr(task, "get_name", lambda: "?")(),
   757	            )
   758	
   759	    # Re-raise the first task exception (if any) so the CLI exits non-zero.
   760	    for task in done:
   761	        if task is stop_task:
   762	            continue
   763	        exc = task.exception()
   764	        if exc is not None:
   765	            raise exc
   766	
   767	
   768	__all__ = ["BootConfig", "bootstrap"]

