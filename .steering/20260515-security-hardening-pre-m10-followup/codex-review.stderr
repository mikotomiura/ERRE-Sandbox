    60	@dataclass(frozen=True)
    61	class BootConfig:
    62	    """Immutable orchestrator configuration.
    63	
    64	    Instantiated once by ``__main__.cli`` from argparse, then passed into
    65	    :func:`bootstrap`. Kept frozen so tests cannot mutate it across awaits.
    66	
    67	    ``agents`` is the M4-foundation extension: an empty tuple keeps the
    68	    M2 single-Kant flow working unchanged. N-agent boot wiring is the
    69	    responsibility of ``m4-multi-agent-orchestrator``.
    70	    """
    71	
    72	    host: str = "0.0.0.0"  # noqa: S104 — LAN only by design
    73	    port: int = 8000
    74	    db_path: str = "var/kant.db"
    75	    chat_model: str = "qwen3:8b"
    76	    embed_model: str = "nomic-embed-text"
    77	    ollama_url: str = "http://127.0.0.1:11434"
    78	    check_ollama: bool = True
    79	    log_level: str = "info"
    80	    personas_dir: Path = field(default_factory=lambda: Path("personas"))
    81	    agents: tuple[AgentSpec, ...] = ()
    82	    # SH-2 — WS connection-time auth. All three gates default to disabled
    83	    # so back-compat workflows (Mac↔G-GEAR LAN, no Origin / no token) keep
    84	    # working without flag changes. ``bootstrap()`` rejects the combination
    85	    # ``host="0.0.0.0"`` + all three gates disabled at startup so a careless
    86	    # ``--host=0.0.0.0`` flag cannot silently expose the server.
    87	    ws_token: str | None = None
    88	    require_token: bool = False
    89	    allowed_origins: tuple[str, ...] = ()
    90	    max_sessions: int = protocol.MAX_ACTIVE_SESSIONS
    91	
    92	    def __post_init__(self) -> None:
    93	        """Fill ``agents`` with the 1-Kant default when the caller omitted it.
    94	
    95	        Keeping the default inside the config (rather than branching inside
    96	        :func:`bootstrap`) means the orchestrator body stays a single
    97	        ``for spec in cfg.agents`` loop and both CI and live paths exercise
    98	        the same code. ``object.__setattr__`` is the idiomatic escape hatch
    99	        for mutating a ``frozen=True`` dataclass during init.
   100	        """
   101	        if not self.agents:
   102	            default = (AgentSpec(persona_id="kant", initial_zone=Zone.PERIPATOS),)
   103	            object.__setattr__(self, "agents", default)
   104	
   105	
   106	_PERSONA_ID_RE: Final[re.Pattern[str]] = re.compile(r"\A[a-z][a-z0-9_-]{0,63}\Z")
   107	"""Path-traversal guard for ``persona_id``; mirrors the CLI-side regex."""
   108	
   109	
   110	_WS_TOKEN_FILE_PATH: Final[Path] = Path("var/secrets/ws_token")
   111	"""Default on-disk location for the SH-2 shared WS token.
   112	
   113	Provisioned via ``mkdir -p var/secrets && chmod 700 var/secrets`` + writing
   114	the token (a high-entropy string ≥ 32 chars). File reads strip trailing
   115	whitespace so ``echo TOKEN > file`` works without surprises. Lives at
   116	``var/`` so it is excluded from VCS by the existing ``.gitignore`` rule.
   117	"""
   118	
   119	_WS_TOKEN_ENV: Final[str] = "ERRE_WS_TOKEN"  # noqa: S105 — env-var name, not the secret
   120	"""Environment-variable fallback when the on-disk token file is absent.
   121	
   122	Prefer the file path over the env var in production so the token does not
   123	leak into shell history or process inspections (``ps -E``). The env var
   124	is the convenient escape hatch for short-lived CI / smoke runs.
   125	"""
   126	
   127	
   128	def _resolve_ws_token(cfg: BootConfig) -> str | None:
   129	    """Resolve the WS shared token from explicit / env / file in that order.
   130	
   131	    Returns ``None`` when no source carries a non-empty token. ``cfg.ws_token``
   132	    wins so tests can override without touching the filesystem. The env var
   133	    is consulted next for CI ergonomics; the file is the production source
   134	    of truth. File read errors are not silently swallowed — they propagate
   135	    so an operator notices a permissions / encoding regression.
   136	    """
   137	    if cfg.ws_token:
   138	        return cfg.ws_token
   139	    env_value = os.environ.get(_WS_TOKEN_ENV)
   140	    if env_value:
   141	        return env_value.strip() or None
   142	    if _WS_TOKEN_FILE_PATH.is_file():
   143	        contents = _WS_TOKEN_FILE_PATH.read_text(encoding="utf-8").strip()
   144	        return contents or None
   145	    return None
   146	
   147	
   148	def _validate_ws_auth_config(cfg: BootConfig, *, token: str | None) -> None:
   149	    """Reject the unsafe default combination so misconfig is loud (SH-2).
   150	
   151	    The combination is ``host=0.0.0.0`` (LAN-accessible) **and** every
   152	    independent auth gate disabled: no Origin allow-list, no required token.
   153	    With all three off any peer on the LAN can connect and observe every
   154	    envelope; the ADR (SH-2) requires operators to consciously opt out of
   155	    safety, not into it.
   156	
   157	    Operator escape hatches:
   158	
   159	    * ``--allowed-origins=http://mac.local,http://g-gear.local`` (Origin gate)
   160	    * ``--require-token`` plus a provisioned ``var/secrets/ws_token`` (token gate)
   161	    * ``--host=127.0.0.1`` (loopback only; breaks Mac↔G-GEAR LAN rsync workflow)
   162	    """
   163	    if cfg.host != "0.0.0.0":  # noqa: S104 — string compare, not bind
   164	        return
   165	    if cfg.allowed_origins:
   166	        return
   167	    if cfg.require_token and token:
   168	        return
   169	    msg = (
   170	        "SH-2: refusing to start with host=0.0.0.0 and all three WS auth "
   171	        "gates disabled. Pick one of:\n"
   172	        "  --allowed-origins=http://mac.local,http://g-gear.local  (Origin gate)\n"
   173	        "  --require-token  (with var/secrets/ws_token or ERRE_WS_TOKEN env)\n"
   174	        "  --host=127.0.0.1  (loopback only; breaks LAN rsync workflow)"
   175	    )
   176	    raise RuntimeError(msg)
   177	
   178	
   179	def _load_persona_yaml(personas_dir: Path, persona_id: str) -> PersonaSpec:
   180	    """Load ``personas/<persona_id>.yaml`` into a :class:`PersonaSpec`.
   181	
   182	    Raises ``FileNotFoundError`` with a friendly message when the file is
   183	    absent — orchestrator startup fails loudly rather than surfacing an
   184	    opaque stack trace several levels deep.
   185	
   186	    ``persona_id`` is validated against :data:`_PERSONA_ID_RE` so that the
   187	    derived path cannot escape ``personas_dir`` (defence in depth: the CLI
   188	    already validates, but callers could construct :class:`BootConfig`
   189	    programmatically).
   190	    """
   191	    if not _PERSONA_ID_RE.fullmatch(persona_id):
   192	        msg = (
   193	            f"persona_id {persona_id!r} is not a safe YAML filename "
   194	            f"(required: {_PERSONA_ID_RE.pattern})"
   195	        )
   196	        raise ValueError(msg)
   197	    path = personas_dir / f"{persona_id}.yaml"
   198	    try:
   199	        raw = path.read_text(encoding="utf-8")
   200	    except FileNotFoundError as exc:
   201	        raise FileNotFoundError(
   202	            f"Persona YAML not found at {path!s}. "
   203	            "Check cwd or pass --personas-dir pointing at the repository's "
   204	            "personas/ directory.",
   205	        ) from exc
   206	    data = yaml.safe_load(raw)
   207	    return PersonaSpec.model_validate(data)
   208	
   209	
   210	def _load_persona_registry(cfg: BootConfig) -> dict[str, PersonaSpec]:
   211	    """Load every persona referenced by ``cfg.agents`` into a ``{id: spec}`` dict.
   212	
   213	    The dict is passed to :class:`OllamaDialogTurnGenerator` so the generator
   214	    can resolve the addressee's ``display_name`` when building prompts
   215	    (see ``.steering/20260421-m5-dialog-turn-generator/decisions.md`` §4).
   216	    Duplicate ``persona_id`` entries in ``cfg.agents`` collapse to a single
   217	    registry entry — the registry is keyed by id, not by agent instance.
   218	
   219	    The same YAML will be re-read in ``bootstrap()``'s agent registration
   220	    loop, but that is intentional: personas are tiny (<10 KB) and the two
   221	    reads live in different phases (bootstrap wiring vs. per-agent init).
   222	    The dedup happens here so the registration loop can stay a simple
   223	    ``for spec in cfg.agents`` without caring about duplicates.
   224	    """
   225	    registry: dict[str, PersonaSpec] = {}
   226	    for spec in cfg.agents:
   227	        if spec.persona_id in registry:
   228	            continue
   229	        registry[spec.persona_id] = _load_persona_yaml(
   230	            cfg.personas_dir,
   231	            spec.persona_id,
   232	        )
   233	    return registry
   234	
   235	
   236	def _build_initial_state(spec: AgentSpec, persona: PersonaSpec) -> AgentState:
   237	    """Expand an :class:`AgentSpec` into the initial :class:`AgentState`.
   238	
   239	    ``agent_id`` is derived as ``a_<persona_id>_001``. A future milestone
   240	    can make this CLI-configurable if we need multiple instances of the
   241	    same persona (unlikely for M4).
