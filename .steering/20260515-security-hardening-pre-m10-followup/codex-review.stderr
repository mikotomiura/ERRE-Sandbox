   838	
   839	
   840	class _NullRuntime:
   841	    """Placeholder runtime that never emits envelopes.
   842	
   843	    Allows ``uvicorn --factory`` runs to succeed without binding to a live
   844	    :class:`WorldRuntime`. All production starts should inject a real
   845	    runtime via :func:`make_app`.
   846	    """
   847	
   848	    DESCRIPTION: ClassVar[str] = "gateway started without a WorldRuntime"
   849	
   850	    async def recv_envelope(self) -> ControlEnvelope:
   851	        # Sleep forever — the broadcaster awaits this and simply never wakes.
   852	        await asyncio.Event().wait()
   853	        # Unreachable but type-level satisfying return.
   854	        return WorldTickMsg(tick=0, active_agents=0)  # pragma: no cover
   855	
   856	    def layout_snapshot(self, *, tick: int = 0) -> WorldLayoutMsg:
   857	        """Return an empty layout snapshot.
   858	
   859	        The ``_NullRuntime`` carries no zone or prop state, so the snapshot
   860	        is intentionally empty. Real :class:`WorldRuntime` instances build
   861	        the message from :data:`erre_sandbox.world.zones.ZONE_CENTERS` /
   862	        :data:`~erre_sandbox.world.zones.ZONE_PROPS`.
   863	        """
   864	        return WorldLayoutMsg(tick=tick)
