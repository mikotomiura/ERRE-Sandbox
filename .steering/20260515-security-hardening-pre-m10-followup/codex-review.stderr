    92	[dependency-groups]
    93	lint = [
    94	    "ruff>=0.6,<1.0",
    95	]
    96	typecheck = [
    97	    "mypy>=1.11,<2",
    98	    "types-pyyaml>=6,<7",
    99	]
   100	test = [
