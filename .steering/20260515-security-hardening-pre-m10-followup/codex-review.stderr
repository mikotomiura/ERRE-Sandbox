   884	
   885	def make_app(
   886	    runtime: _RuntimeLike | None = None,
   887	    *,
   888	    auth_config: WSAuthConfig | None = None,
   889	) -> FastAPI:
   890	    """ASGI factory — the canonical entry point.
   891	
   892	    The runtime dependency is injected so tests can swap a :class:`MockRuntime`
   893	    via fixture. The default :class:`_NullRuntime` makes the app runnable
   894	    standalone (useful for curl probes of ``/health``).
   895	
   896	    SH-2: ``auth_config`` carries the WS connection-time gates. ``None``
   897	    yields :class:`WSAuthConfig` defaults (back-compat: no Origin / no
   898	    token / cap=8) so existing tests and the standalone debug entry stay
   899	    unaffected.
   900	    """
   901	    app = FastAPI(lifespan=_lifespan)
   902	    app.state.runtime = runtime if runtime is not None else _NullRuntime()
   903	    cfg = auth_config if auth_config is not None else WSAuthConfig()
   904	    app.state.ws_auth = cfg
   905	    app.state.registry = Registry(max_sessions=cfg.max_sessions)
   906	
   907	    async def health_endpoint() -> dict[str, object]:
   908	        return await _health(app)
   909	
   910	    app.add_api_route("/health", health_endpoint, methods=["GET"])
   911	    app.add_api_websocket_route("/ws/observe", ws_observe)
   912	    return app
   913	
