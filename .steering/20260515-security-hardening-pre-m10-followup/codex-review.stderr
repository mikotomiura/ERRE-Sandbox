   225	def cli(argv: list[str] | None = None) -> int:
   226	    # argv dispatch: if the first positional token is a known sub-command
   227	    # name we route to a dedicated sub-command parser. Otherwise we keep
   228	    # the pre-M8 behaviour (boot the orchestrator directly). Using two
   229	    # separate parsers instead of argparse sub-parsers avoids prefix-match
   230	    # ambiguity between root ``--personas`` and export-log's ``--persona``.
   231	    effective_argv = list(sys.argv[1:]) if argv is None else list(argv)
   232	    if effective_argv and effective_argv[0] in _SUBCOMMANDS:
   233	        args = _build_subcommand_parser().parse_args(effective_argv)
   234	        if args.subcommand == "export-log":
   235	            return export_log.run(args)
   236	        if args.subcommand == "baseline-metrics":
   237	            return baseline_metrics.run(args)
   238	        if args.subcommand == "scaling-metrics":
   239	            return scaling_metrics.run(args)
   240	        msg = f"unknown subcommand: {args.subcommand!r}"  # pragma: no cover
   241	        raise SystemExit(msg)
   242	
   243	    args = _build_run_parser().parse_args(effective_argv)
   244	    personas_dir = Path(args.personas_dir)
   245	    agents = _resolve_agents(args.personas, personas_dir)
   246	    allowed_origins = tuple(
   247	        token.strip() for token in args.allowed_origins.split(",") if token.strip()
   248	    )
   249	    cfg = BootConfig(
   250	        host=args.host,
   251	        port=args.port,
   252	        db_path=args.db_path,
   253	        chat_model=args.chat_model,
   254	        embed_model=args.embed_model,
   255	        ollama_url=args.ollama_url,
   256	        check_ollama=args.check_ollama,
   257	        log_level=args.log_level,
   258	        personas_dir=personas_dir,
   259	        agents=agents,
   260	        ws_token=args.ws_token,
   261	        require_token=args.require_token,
   262	        allowed_origins=allowed_origins,
   263	        max_sessions=args.max_sessions,
   264	    )
   265	    try:
   266	        asyncio.run(bootstrap(cfg))
   267	    except KeyboardInterrupt:
   268	        return 130
   269	    return 0
   270	
   271	
   272	if __name__ == "__main__":
   273	    sys.exit(cli())

