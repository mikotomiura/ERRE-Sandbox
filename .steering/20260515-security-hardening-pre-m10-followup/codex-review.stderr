     1	"""Session lifecycle constants and phase enum for the T14 gateway (WS).
     2	
     3	This module augments :mod:`erre_sandbox.schemas` §7 ``ControlEnvelope`` with the
     4	**operational parameters** that the wire-type definitions intentionally do not
     5	encode:
     6	
     7	* heartbeat cadence — how often the server must push :class:`WorldTickMsg`
     8	* handshake / idle-disconnect timeouts — session lifecycle bounds
     9	* ``SessionPhase`` — explicit enum of session states, consumed by the T14
    10	  gateway implementation and the T19 skeleton scenario tests
    11	
    12	The wire types themselves (``HandshakeMsg``, ``AgentUpdateMsg``, ...) are **not**
    13	redefined here. They live in :mod:`erre_sandbox.schemas` and are imported by
    14	consumers directly — this module only owns timing and state-machine rules.
    15	
    16	See ``.steering/20260419-m2-integration-e2e/decisions.md`` D3 for why the
    17	contract is split this way.
    18	"""
    19	
    20	from __future__ import annotations
    21	
    22	from enum import StrEnum
    23	from typing import Final
    24	
    25	# =============================================================================
    26	# Session lifecycle constants
    27	# =============================================================================
    28	
    29	HEARTBEAT_INTERVAL_S: Final[float] = 1.0
    30	"""Expected cadence of :class:`~erre_sandbox.schemas.WorldTickMsg` heartbeat.
    31	
    32	Matches ``WorldRuntime._heartbeat_period`` default in :mod:`erre_sandbox.world.tick`.
    33	Consumers (Godot client, monitor dashboards) may tolerate up to
    34	``HEARTBEAT_INTERVAL_S * 3`` without raising a liveness alarm.
    35	"""
    36	
    37	HANDSHAKE_TIMEOUT_S: Final[float] = 5.0
    38	"""Maximum time a peer has to send :class:`~erre_sandbox.schemas.HandshakeMsg`.
    39	
    40	Measured from TCP accept / WS upgrade completion. Exceeding it causes the
    41	gateway to close the socket with :class:`~erre_sandbox.schemas.ErrorMsg`
    42	``code="handshake_timeout"``.
    43	"""
    44	
    45	IDLE_DISCONNECT_S: Final[float] = 60.0
    46	"""Inactivity ceiling after which the gateway voluntarily closes a session.
    47	
    48	Applies only once the session is :attr:`SessionPhase.ACTIVE`. During
    49	``AWAITING_HANDSHAKE`` the stricter :data:`HANDSHAKE_TIMEOUT_S` governs.
    50	"""
    51	
    52	MAX_ENVELOPE_BACKLOG: Final[int] = 256
    53	"""Maximum number of pending envelopes before the gateway drops the oldest.
    54	
    55	The runtime queue (``WorldRuntime._envelopes``) is now bounded as well
    56	(SH-5: ``maxsize=1024`` for the main queue plus a ``maxsize=1`` coalescing
    57	heartbeat queue). The two layers stack: this gateway bound applies
    58	per-client so a slow Godot viewer cannot exhaust server memory, while the
    59	runtime bound protects against an upstream that never drains.
    60	"""
    61	
    62	DEFAULT_ALLOWED_ORIGINS: Final[tuple[str, ...]] = ()
    63	"""Default origin allow-list — empty tuple disables Origin check (SH-2).
    64	
    65	LAN-internal deployment runs without a reverse proxy so Godot's native WS
    66	client sends no Origin header. Operators that expose the gateway through a
    67	browser-driven dashboard (M10+) pass a non-empty tuple via ``BootConfig``
    68	to enable per-Origin filtering. An empty tuple combined with
    69	``host=0.0.0.0`` and ``require_token=False`` triggers a startup
    70	``RuntimeError`` in :func:`erre_sandbox.bootstrap.bootstrap` so a careless
    71	``--host=0.0.0.0`` flag cannot silently expose the server.
    72	"""
    73	
    74	MAX_ACTIVE_SESSIONS: Final[int] = 8
    75	"""Session-count cap enforced by :class:`Registry` (SH-2).
    76	
    77	Sized for the M10 working assumption: Mac+G-GEAR Godot viewers + curl probe
    78	+ Slack bridge + 3 per-persona UI panels = 7, plus headroom = 8. The cap
    79	is reached only when an attacker (or buggy client) opens connections in a
    80	tight loop; legitimate UI clients reconnect, not stack. On overflow the
    81	gateway closes the new socket with WebSocket close code ``1013``
    82	(Try Again Later) so well-behaved clients back off instead of looping.
    83	"""
    84	
    85	SCHEMA_VERSION_HEADER: Final[str] = "X-Erre-Schema-Version"
    86	"""HTTP header the gateway sets on the WS upgrade response.
    87	
    88	Peers that don't send :class:`~erre_sandbox.schemas.HandshakeMsg` (e.g. debug
    89	curl probes) can still discover the server's
    90	:data:`~erre_sandbox.schemas.SCHEMA_VERSION` this way.
    91	"""
    92	
    93	SUBSCRIBE_QUERY_PARAM: Final[str] = "subscribe"
    94	"""URL query-parameter name controlling per-session agent filtering.
    95	
    96	Added by ``m4-gateway-multi-agent-stream``. Clients connecting to
    97	``/ws/observe`` without this parameter receive every envelope (broadcast,
    98	preserving M2 behaviour). A comma-separated list of ``persona_id`` values
    99	restricts the session to envelopes whose routing set intersects the list.
   100	The literal ``*`` is equivalent to omission.
   101	"""
   102	
   103	SUBSCRIBE_DELIMITER: Final[str] = ","
   104	"""Delimiter used inside the ``?subscribe=`` query parameter."""
   105	
   106	MAX_SUBSCRIBE_ITEMS: Final[int] = 32
   107	"""Upper bound on the number of agent ids permitted in one ``?subscribe=``.
   108	
