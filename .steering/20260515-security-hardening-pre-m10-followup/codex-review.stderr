   311	class TestHandshakeErrors:
   312	    def test_handshake_timeout_emits_error_and_closes(
   313	        self,
   314	        client: TestClient,
   315	        fast_timeouts: None,  # noqa: ARG002 — used for its side effect
   316	    ) -> None:
   317	        with client.websocket_connect("/ws/observe") as ws:
   318	            _ = _recv_envelope(ws)  # server handshake
   319	            # Do NOT reply; wait for handshake_timeout.
   320	            err = _recv_envelope(ws)
   321	            assert isinstance(err, ErrorMsg)
   322	            assert err.code == "handshake_timeout"
   323	            with pytest.raises(WebSocketDisconnect):
   324	                ws.receive_text()
   325	
   326	    def test_schema_mismatch_emits_error_and_closes(
   327	        self,
   328	        client: TestClient,
   329	    ) -> None:
   330	        with client.websocket_connect("/ws/observe") as ws:
   331	            _ = _recv_envelope(ws)
