ERRE-Sandbox_v0.2.pdf
MEMO
.claude/commands/commands_setup

# macOS Finder metadata
.DS_Store
**/.DS_Store

# PDF から pdftotext で生成した派生物 (T03 pdf-extract-baseline で生成)
docs/_pdf_derived/

# Python / uv / ツールキャッシュ (T04 pyproject-scaffold で追加)
# 注: uv.lock は意図的にコミットする (decisions.md 判断 6 参照)
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# Secrets / credentials (T04 security-review で追加)
# python-dotenv が推移依存として入るため .env の誤コミット対策
.env
.env.*
!.env.example
*.key
*.pem
*.p12
credentials*
secrets/

# Godot cache / generated (T15 godot-project-init で追加)
godot_project/.godot/
godot_project/.import/
godot_project/*.import
godot_project/export_presets.cfg

# M2 acceptance / smoke run logs (T19 実行フェーズで追加)
# env var M2_LOG_PATH を設定時のみ生成される jsonl / txt ログ
logs/
# ただし acceptance evidence の `logs/` サブディレクトリは commit 対象
# (M5 m5-acceptance-live で追加)
!.steering/**/evidence/logs/
!.steering/**/evidence/logs/**

# T21 runtime artifacts
var/
.claude/scheduled_tasks.lock

# Per-run DB snapshots inside .steering/ are local-only (3MB each, not portable
# beyond the run; metric reproducibility uses the journal + scaling_metrics.json).
.steering/**/runs/**/*.db

# Throwaway spike / ad-hoc scripts (M5 m5-llm-spike で追加)
# commit 対象外の spike 成果物を誤 commit しないための隔離ディレクトリ
_ad_hoc/

# m9-c-spike LoRA adapter checkpoints (mock + future real Kant rank=8 PEFT
# directories). adapter_model.safetensors は再生成可能、metadata sentinel と
# build script (tools/spike/build_mock_lora.py) でのみ整合保証する。
checkpoints/

# m9-eval-system P3a pilot capture (large DuckDB binaries + per-run logs).
# Only `_summary.json` is committed; raw DuckDB snapshots stay local + rsync
# to Mac via ME-2 protocol.
data/eval/pilot/*.duckdb
data/eval/pilot/*.duckdb.tmp
data/eval/pilot/*.log
data/eval/pilot/*.snapshot.duckdb

# m9-eval-system P3 production Golden baseline (30 cells × ~1MB).
# Only `_rsync_receipt.txt` and `_audit.json` are committed; DuckDB binaries
# stay local + rsync via ME-2 (HTTP server pattern validated 2026-05-05).
data/eval/golden/*.duckdb
data/eval/golden/*.duckdb.tmp
data/eval/golden/*.log
data/eval/golden/*.snapshot.duckdb

# m9-eval-system Phase 2 run1 calibration (kant-only × 5 wall sequential、
# 2026-05-07 起点)。DuckDB binaries + sidecar JSON は local のみ、empirical
# table と receipt のみ commit する (PR #140 blockers.md D-8、本 PR で適用)。
data/eval/calibration/**/*.duckdb
data/eval/calibration/**/*.duckdb.tmp
data/eval/calibration/**/*.duckdb.capture.json
data/eval/calibration/**/*.log
data/eval/calibration/**/*.snapshot.duckdb

# m9-eval-system partial captures (run0 incident 隔離など)。同 policy。
data/eval/partial/**/*.duckdb
data/eval/partial/**/*.duckdb.tmp
data/eval/partial/**/*.duckdb.capture.json
data/eval/partial/**/*.log
data/eval/partial/**/*.snapshot.duckdb

# m9-eval-system P3 dry-run artifacts (Phase 0 sanity capture).
data/eval/_dryrun/

# m9-eval-system P3 natural memory sqlite (per-cell agent memory backing
# store, ~10MB each). Only the rescue verify report is committed; sqlite
# binaries stay local.
data/eval/_natural_memory/

# m9-eval-system Phase 2 run0 rescue stash (.duckdb copies from .tmp).
# Only `_rescue_*` text artifacts are committed; the duckdb binaries are
# excluded same as data/eval/golden/ policy.
data/eval/partial-stash-*/*.duckdb
data/eval/partial-stash-*/*.duckdb.wal

# Codex independent review raw logs (large transcripts of model reasoning;
# the verbatim final answer is saved separately in `codex-review-*.md`).
.steering/**/codex-review-*.raw.log
